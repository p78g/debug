-- Desync state
local Toggled = false
local markerPart = nil
local refreshLoop = nil
local heartbeatHook = nil

-- Marker creation (old red part + decal)
local function createMarker()
    if markerPart then markerPart:Destroy() end
    local pos = root.Position
    markerPart = Instance.new("Part")
    markerPart.Size = Vector3.new(2.5, 0.5, 2.5)
    markerPart.Position = pos
    markerPart.Anchored = true
    markerPart.CanCollide = false
    markerPart.BrickColor = BrickColor.new("Bright red")
    markerPart.Material = Enum.Material.Neon
    markerPart.Transparency = 0.3
    local decal = Instance.new("Decal")
    decal.Texture = "rbxassetid://160501115" -- red circle
    decal.Face = Enum.NormalId.Top
    decal.Parent = markerPart
    markerPart.Parent = Workspace
    -- Fade in
    markerPart.Transparency = 0.8
    TweenService:Create(markerPart, TweenInfo.new(0.3), {Transparency = 0.3}):Play()
end

local function removeMarker()
    if markerPart then
        TweenService:Create(markerPart, TweenInfo.new(0.2), {Transparency = 1}):Play()
        task.wait(0.2)
        markerPart:Destroy()
        markerPart = nil
    end
end

-- Improved desync core: prevents server from correcting
local function startDesync()
    if not plsraknet.desync then return end
    plsraknet.desync(true)
    -- Additional hardening: force platform stand and freeze root velocity
    humanoid.PlatformStand = true
    -- Spoof movement packets (send fake position every frame)
    local frozenCFrame = root.CFrame
    local heartbeat = RunService.Heartbeat:Connect(function()
        if not Toggled then return end
        root.CFrame = frozenCFrame
        root.Velocity = Vector3.new(0,0,0)
        root.RotVelocity = Vector3.new(0,0,0)
        -- Optionally send a fake remote to keep connection alive
    end)
    heartbeatHook = heartbeat
    -- Refresh desync every 2.5 seconds to avoid stale state
    refreshLoop = task.spawn(function()
        while Toggled do
            task.wait(2.5)
            plsraknet.desync(false)
            task.wait(0.05)
            plsraknet.desync(true)
        end
    end)
end

local function stopDesync()
    if heartbeatHook then heartbeatHook:Disconnect() heartbeatHook = nil end
    if refreshLoop then task.cancel(refreshLoop) refreshLoop = nil end
    if plsraknet.desync then plsraknet.desync(false) end
    humanoid.PlatformStand = false
end

-- UI toggle handler
local function updateToggle(state)
    local knobPos = state and UDim2.new(1, -22, 0.5, -10) or UDim2.new(0, 2, 0.5, -10)
    local bgColor = state and Color3.fromRGB(80,80,80) or Color3.fromRGB(40,40,40)
    TweenService:Create(Knob, TweenInfo.new(0.2), {Position = knobPos}):Play()
    TweenService:Create(ToggleButton, TweenInfo.new(0.2), {BackgroundColor3 = bgColor}):Play()
    if state then
        createMarker()
        startDesync()
    else
        removeMarker()
        stopDesync()
    end
end

ToggleButton.MouseButton1Click:Connect(function()
    Toggled = not Toggled
    updateToggle(Toggled)
end)

-- Draggable UI
local dragging, dragInput, dragStart, startPos
Frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = Frame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)
Frame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        dragInput = input
    end
end)
UIS.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        Frame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

-- Cleanup on character respawn
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    root = character:WaitForChild("HumanoidRootPart")
    humanoid = character:WaitForChild("Humanoid")
    if Toggled then
        Toggled = false
        updateToggle(false)
    end
    if markerPart then markerPart:Destroy() end
end)

