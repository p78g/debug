-- Load Rayfield and the original silent aim script
local Rayfield = loadstring(game:HttpGet("https://raw.githubusercontent.com/SiriusSoftwareLtd/Rayfield/main/source.lua"))()
local SilentAim = loadstring(game:HttpGet("https://rawscripts.net/raw/Street-Life-Remastered-OPEN-SOURCE-Silent-Aim-204997"))()

-- Check if the silent aim script was loaded correctly
if not SilentAim then
    warn("Failed to load silent aim script")
    return
end

-- Create the Rayfield window
local Window = Rayfield:CreateWindow({
    Name = "Silent Aim Control",
    LoadingTitle = "Loading Aimbot",
    Theme = "Default"
})

local MainTab = Window:CreateTab("Aimbot")

-- Add a toggle to enable/disable aimbot
local aimbotEnabled = true
MainTab:CreateToggle({
    Name = "Enable Silent Aim",
    CurrentValue = aimbotEnabled,
    Callback = function(Value)
        aimbotEnabled = Value
        -- Update the global variable that the silent aim script uses
        _G.SilentAimEnabled = aimbotEnabled
        print("Silent Aim Enabled:", Value)
    end
})

-- Optional: Add a slider for FOV (if the original script supports it)
-- Note: The original script uses a hardcoded FOV of 200px
-- If you want to change it, you might need to modify the original script
-- For now, we'll just display the current FOV
MainTab:CreateParagraph({
    Name = "Info",
    Content = "Original Silent Aim FOV: 200px\nToggle above to enable/disable"
})

-- Add a dropdown for target body part (if the original script supports it)
-- The original script only aims for the head, so this might not work without modification
-- We'll include it for future use
local bodyPartOptions = {"Head", "UpperTorso", "LowerTorso", "HumanoidRootPart"}
MainTab:CreateDropdown({
    Name = "Target Body Part (Not yet implemented)",
    Options = bodyPartOptions,
    CurrentOption = "Head",
    Callback = function(Option)
        warn("Body part selection not supported by the original silent aim script")
    end
})

-- Example: Send a notification when the script loads
Rayfield:Notify({
    Title = "Silent Aim Loaded",
    Content = "Toggle the aimbot using the Rayfield menu",
    Duration = 3
})
