-- Now override the original script's getClosestTarget or projectile hook to use our settings.
-- We'll find the module they hooked and re-hook it with our settings.

-- Services
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- Our own silent aim logic (based on original but with settings)
local function getClosestTarget()
    if not settings.enabled then return nil end
    local mousePos = UserInputService:GetMouseLocation()
    local bestDist = settings.fov
    local bestTarget = nil

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local targetPart = player.Character:FindFirstChild(settings.targetPart)
            local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
            if targetPart and humanoid and humanoid.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        bestTarget = targetPart
                    end
                end
            end
        end
    end
    return bestTarget
end

-- Re-hook the projectile module (original script likely did this, we override)
local function hookProjectiles()
    local replicatedStorage = game:GetService("ReplicatedStorage")
    local module = replicatedStorage:FindFirstChild("Modules")
    if module then module = module:FindFirstChild("GunFramework") end
    if module then module = module:FindFirstChild("Modules") end
    if not module then 
        warn("Projectile module not found")
        return false
    end
    
    local success, Projectile = pcall(require, module.Projectile)
    if not success or not Projectile then 
        warn("Failed to require Projectile")
        return false
    end
    
    local originalNew = Projectile.new
    Projectile.new = function(params)
        if params and params.Origin and params.Direction and settings.enabled then
            local target = getClosestTarget()
            if target then
                params.Direction = (target.Position - params.Origin).Unit
            end
        end
        return originalNew(params)
    end
    print("Silent aim re-hooked with Rayfield settings")
    return true
end

-- Try to hook (if original already hooked, this overrides)
hookProjectiles()

