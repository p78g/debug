-- Load Rayfield (official repo)
local Rayfield = loadstring(game:HttpGet("https://raw.githubusercontent.com/SiriusSoftwareLtd/Rayfield/main/source.lua"))()

-- Services
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- Settings (controlled by Rayfield)
local Settings = {
    Enabled = true,
    FOV = 150,
    TargetPart = "Head",
}

-- Silent aim logic (same as the original script)
local function getClosestTarget()
    if not Settings.Enabled then return nil end
    local mousePos = UserInputService:GetMouseLocation()
    local bestDist = Settings.FOV
    local bestTarget = nil

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local targetPart = player.Character:FindFirstChild(Settings.TargetPart)
            local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
            if targetPart and humanoid and humanoid.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        bestTarget = targetPart
                    end
                end
            end
        end
    end
    return bestTarget
end

-- Hook into the game's projectile system (exactly like the raw script)
local function hookProjectiles()
    local success, Projectile = pcall(require, 
        game:GetService("ReplicatedStorage").Modules.GunFramework.Modules.Projectile
    )
    if not success then
        warn("[Rayfield] Projectile module not found. Aimbot will not work.")
        return
    end
    
    local originalNew = Projectile.new
    Projectile.new = function(params)
        if params and params.Origin and params.Direction and Settings.Enabled then
            local target = getClosestTarget()
            if target then
                params.Direction = (target.Position - params.Origin).Unit
            end
        end
        return originalNew(params)
    end
    print("[Rayfield] Silent aim hooked successfully.")
end
hookProjectiles()

-- Create Rayfield window
local Window = Rayfield:CreateWindow({
    Name = "Silent Aim",
    LoadingTitle = "Aimbot",
    Theme = "Default",
})

local MainTab = Window:CreateTab("Aimbot")

MainTab:CreateToggle({
    Name = "Enable Silent Aim",
    CurrentValue = Settings.Enabled,
    Callback = function(v)
        Settings.Enabled = v
    end,
})

MainTab:CreateSlider({
    Name = "FOV Radius",
    Range = {50, 400},
    Increment = 1,
    Suffix = "px",
    CurrentValue = Settings.FOV,
    Callback = function(v)
        Settings.FOV = v
    end,
})

MainTab:CreateDropdown({
    Name = "Target Body Part",
    Options = {"Head", "UpperTorso", "LowerTorso", "HumanoidRootPart"},
    CurrentOption = Settings.TargetPart,
    Callback = function(v)
        Settings.TargetPart = v
    end,
})

print("Rayfield menu loaded. Use it to control silent aim.")
