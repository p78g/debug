-- // Load Iris GUI Library
local Iris = loadstring(game:HttpGet("https://raw.githubusercontent.com/x0581/Iris-Exploit-Bundle/main/bundle.lua"))().Init(game.CoreGui)

-- // Services & Variables
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- // -------------------- Silent Aim Core (Modified) -------------------- //

-- Configurable settings (will be linked to the UI)
local Settings = {
    Enabled = true,
    FOV_Size = 200,      -- base default
    TargetPart = "Head", -- options: "Head", "UpperTorso", "LowerTorso", "HumanoidRootPart"
}

-- Visual FOV circle
local fovGui = Instance.new("ScreenGui")
fovGui.Name = "SilentAimFOV"
fovGui.ResetOnSpawn = false
fovGui.IgnoreGuiInset = true
fovGui.Parent = LocalPlayer.PlayerGui

local fovCircle = Instance.new("Frame")
fovCircle.BackgroundTransparency = 1
fovCircle.BorderSizePixel = 0
fovCircle.AnchorPoint = Vector2.new(0.5, 0.5)
fovCircle.Parent = fovGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(1, 0)
corner.Parent = fovCircle

local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(255, 0, 0)
stroke.Thickness = 2
stroke.Transparency = 0.4
stroke.Parent = fovCircle

local function updateFOVVisual()
    fovCircle.Size = UDim2.fromOffset(Settings.FOV_Size * 2, Settings.FOV_Size * 2)
end
updateFOVVisual()

-- Function to get the closest target based on FOV and selected body part
local function getClosestTarget()
    if not Settings.Enabled then return nil, nil end
    local mousePos = UserInputService:GetMouseLocation()
    local bestDist = Settings.FOV_Size
    local bestTarget = nil
    local bestScreen = nil

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local targetPart = player.Character:FindFirstChild(Settings.TargetPart)
            local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
            if targetPart and humanoid and humanoid.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        bestTarget = targetPart
                        bestScreen = Vector2.new(screenPos.X, screenPos.Y)
                    end
                end
            end
        end
    end
    return bestTarget, bestScreen
end

-- Hook into the projectile system
local ok, Projectile = pcall(require, game:GetService("ReplicatedStorage").Modules.GunFramework.Modules.Projectile)
if ok then
    local originalNew = Projectile.new
    Projectile.new = function(params)
        if params and params.Origin and params.Direction and Settings.Enabled then
            local target = getClosestTarget()
            if target then
                local newDir = (target.Position - params.Origin).Unit
                params.Direction = newDir
            end
        end
        return originalNew(params)
    end
else
    warn("Projectile module not found – aimbot may not work in this game.")
end

-- Update FOV circle and UI dot each frame
RunService.RenderStepped:Connect(function()
    local mousePos = UserInputService:GetMouseLocation()
    fovCircle.Position = UDim2.fromOffset(mousePos.X, mousePos.Y)

    local target, screenPos = getClosestTarget()
    if target and screenPos and Settings.Enabled then
        stroke.Color = Color3.fromRGB(255, 50, 50)   -- red when a target is inside FOV
    else
        stroke.Color = Color3.fromRGB(255, 255, 255) -- white when no target
    end
end)

-- // -------------------- Iris GUI -------------------- //

Iris:Connect(function()
    Iris.Window({"Silent Aim Control Panel"})
    Iris.Checkbox({"Enable Silent Aim", "Toggle aimbot on/off"}, function(state)
        Settings.Enabled = state
    end).state = Settings.Enabled

    Iris.SameLine()
    Iris.Text({"   FOV Size"})
    Iris.SliderNum({"", Settings.FOV_Size, 50, 400, true}, function(value)
        Settings.FOV_Size = value
        updateFOVVisual()
    end)

    -- Target body part dropdown
    local partOptions = {
        "Head",
        "UpperTorso",
        "LowerTorso",
        "HumanoidRootPart"
    }
    local selectedIndex = 1  -- default "Head"
    Iris.DropdownString({"Target Body Part", partOptions, selectedIndex}, function(option, idx)
        Settings.TargetPart = option
        selectedIndex = idx
    end)

    Iris.Separator()
    Iris.Text({"FOV Circle Color: Red = target inside, White = no target"})
    Iris.End()
end)

print("Silent aim script loaded! Use the Iris GUI to control it.")
