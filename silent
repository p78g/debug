-- Update FOV circle size when slider changes
local function updateFOVSize()
    fovCircle.Size = UDim2.fromOffset(Settings.FOV * 2, Settings.FOV * 2)
end

-- ========== Silent Aim Logic ==========
-- Finds the closest target relative to the mouse position and current FOV.
-- Returns the target part (Head, UpperTorso, etc.) and its screen position.
local function getClosestTarget()
    if not Settings.Enabled then return nil, nil end
    local mousePos = UserInputService:GetMouseLocation()
    local bestDist = Settings.FOV
    local bestPart = nil
    local bestScreen = nil

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local targetPart = player.Character:FindFirstChild(Settings.TargetPart)
            local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
            if targetPart and humanoid and humanoid.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        bestPart = targetPart
                        bestScreen = Vector2.new(screenPos.X, screenPos.Y)
                    end
                end
            end
        end
    end
    return bestPart, bestScreen
end

-- Hook into the game's projectile system (same as the original script)
local function hookProjectiles()
    local success, Projectile = pcall(require, 
        game:GetService("ReplicatedStorage").Modules.GunFramework.Modules.Projectile
    )
    if not success then
        warn("[Rayfield Silent Aim] Projectile module not found – aimbot will not work.")
        return
    end

    local originalNew = Projectile.new
    Projectile.new = function(params)
        if params and params.Origin and params.Direction and Settings.Enabled then
            local target = getClosestTarget()
            if target then
                -- Redirect the projectile toward the chosen body part
                params.Direction = (target.Position - params.Origin).Unit
            end
        end
        return originalNew(params)
    end
    print("[Rayfield Silent Aim] Successfully hooked into projectile system.")
end

hookProjectiles()

-- ========== Visual Update Loop ==========
RunService.RenderStepped:Connect(function()
    local mousePos = UserInputService:GetMouseLocation()
    fovCircle.Position = UDim2.fromOffset(mousePos.X, mousePos.Y)

    local target, screenPos = getClosestTarget()
    if target and screenPos and Settings.Enabled then
        dot.Visible = true
        dot.Position = UDim2.fromOffset(screenPos.X, screenPos.Y)
        stroke.Color = Color3.fromRGB(255, 50, 50)   -- Red = target inside FOV
    else
        dot.Visible = false
        stroke.Color = Color3.fromRGB(255, 255, 255) -- White = no target
    end
end)

