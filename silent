-- // Load Iris GUI Library (from x0581/Iris-Exploit-Bundle)
local Iris = loadstring(game:HttpGet("https://raw.githubusercontent.com/x0581/Iris-Exploit-Bundle/main/bundle.lua"))().Init(game.CoreGui)

-- // Services
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- // Settings (defaults)
local Settings = {
    Enabled = true,
    FOV_Size = 150,
    TargetPart = "Head",
    PartIndex = 1, -- 1=Head,2=UpperTorso,3=LowerTorso,4=HumanoidRootPart
}

-- // Create FOV Circle UI (ScreenGui)
local fovGui = Instance.new("ScreenGui")
fovGui.Name = "SilentAimFOV"
fovGui.ResetOnSpawn = false
fovGui.Parent = LocalPlayer.PlayerGui

local fovCircle = Instance.new("Frame")
fovCircle.BackgroundTransparency = 1
fovCircle.BorderSizePixel = 0
fovCircle.AnchorPoint = Vector2.new(0.5, 0.5)
fovCircle.Size = UDim2.fromOffset(Settings.FOV_Size * 2, Settings.FOV_Size * 2)
fovCircle.Parent = fovGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(1, 0)
corner.Parent = fovCircle

local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(255, 0, 0)
stroke.Thickness = 2
stroke.Transparency = 0.4
stroke.Parent = fovCircle

local function updateFOVCircle()
    fovCircle.Size = UDim2.fromOffset(Settings.FOV_Size * 2, Settings.FOV_Size * 2)
end

-- // Silent Aim Core (intercepts projectiles)
local function getClosestTarget()
    if not Settings.Enabled then return nil end
    local mousePos = UserInputService:GetMouseLocation()
    local bestDist = Settings.FOV_Size
    local bestTarget = nil

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local targetPart = player.Character:FindFirstChild(Settings.TargetPart)
            local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
            if targetPart and humanoid and humanoid.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        bestTarget = targetPart
                    end
                end
            end
        end
    end
    return bestTarget
end

-- Hook the projectile module
local success, Projectile = pcall(require, game:GetService("ReplicatedStorage").Modules.GunFramework.Modules.Projectile)
if success then
    local originalNew = Projectile.new
    Projectile.new = function(params)
        if params and params.Origin and params.Direction and Settings.Enabled then
            local target = getClosestTarget()
            if target then
                local newDir = (target.Position - params.Origin).Unit
                params.Direction = newDir
            end
        end
        return originalNew(params)
    end
else
    warn("Projectile module not found – silent aim may not work.")
end

-- // Update FOV circle position and color each frame
RunService.RenderStepped:Connect(function()
    local mousePos = UserInputService:GetMouseLocation()
    fovCircle.Position = UDim2.fromOffset(mousePos.X, mousePos.Y)

    -- Change color if target is inside FOV
    if getClosestTarget() and Settings.Enabled then
        stroke.Color = Color3.fromRGB(255, 50, 50)   -- red
    else
        stroke.Color = Color3.fromRGB(255, 255, 255) -- white
    end
end)

-- // ==================== IRIS GUI ====================
-- We need to continuously update the GUI. Use a loop.

local window = Iris.Window({
    Title = "Silent Aim Control",
    Position = UDim2.new(0.1, 0, 0.2, 0),
    Size = UDim2.new(0, 300, 0, 250)
})

local function drawGUI()
    -- Enable Toggle
    local enabledChanged
    Settings.Enabled, enabledChanged = Iris.Toggle("Enable Silent Aim", Settings.Enabled)
    
    -- FOV Slider
    local fovChanged
    Settings.FOV_Size, fovChanged = Iris.Slider("FOV Radius", Settings.FOV_Size, 50, 400, true)
    if fovChanged then updateFOVCircle() end
    
    -- Target Body Part Dropdown
    local parts = {"Head", "UpperTorso", "LowerTorso", "HumanoidRootPart"}
    local partChanged
    Settings.PartIndex, partChanged = Iris.Dropdown("Target Body Part", parts, Settings.PartIndex)
    if partChanged then
        Settings.TargetPart = parts[Settings.PartIndex]
    end
    
    -- A separator line
    Iris.Separator()
    Iris.Text("FOV Circle: Red = target inside, White = none")
end

-- Main GUI update loop
while Iris.Enabled do
    Iris.Begin()
    if window then
        Iris.WindowContent(window, drawGUI)
    end
    Iris.End()
    task.wait() -- adjust if needed
end
