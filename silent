    Range = {50, 400},
    Increment = 1,
    Suffix = "px",
    CurrentValue = Settings.FOV,
    Callback = function(v)
        Settings.FOV = v
        updateCircleSize()
    end
})

tab:CreateDropdown({
    Name = "Target Body Part",
    Options = {"Head", "UpperTorso", "LowerTorso", "HumanoidRootPart"},
    CurrentOption = Settings.TargetPart,
    Callback = function(v) Settings.TargetPart = v end
})

