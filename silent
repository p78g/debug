-- Load Rayfield
local Rayfield = loadstring(game:HttpGet("https://raw.githubusercontent.com/SiriusSoftwareLtd/Rayfield/main/source.lua"))()

-- Services
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- Settings
local Settings = {
    Enabled = true,
    FOV = 150,
    TargetPart = "Head",
}

-- ========== FOV Circle (Native, No Extra Menu) ==========
local fovGui = Instance.new("ScreenGui")
fovGui.Name = "SilentAimFOV"
fovGui.ResetOnSpawn = false
fovGui.Parent = game:GetService("CoreGui")

local circle = Instance.new("Frame")
circle.BackgroundTransparency = 1
circle.BorderSizePixel = 0
circle.AnchorPoint = Vector2.new(0.5, 0.5)
circle.Size = UDim2.fromOffset(Settings.FOV * 2, Settings.FOV * 2)
circle.Parent = fovGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(1, 0)
corner.Parent = circle

local stroke = Instance.new("UIStroke")
stroke.Thickness = 2
stroke.Transparency = 0.4
stroke.Color = Color3.fromRGB(255, 255, 255)
stroke.Parent = circle

local function updateFOVCircle()
    circle.Size = UDim2.fromOffset(Settings.FOV * 2, Settings.FOV * 2)
end

-- ========== Silent Aim Logic ==========
local function getClosestTarget()
    if not Settings.Enabled then return nil end
    local mousePos = UserInputService:GetMouseLocation()
    local bestDist = Settings.FOV
    local bestTarget = nil

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local targetPart = player.Character:FindFirstChild(Settings.TargetPart)
            local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
            if targetPart and humanoid and humanoid.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        bestTarget = targetPart
                    end
                end
            end
        end
    end
    return bestTarget
end

-- Hook into projectile system (same as raw script)
local function hookProjectiles()
    local success, Projectile = pcall(require, 
        game:GetService("ReplicatedStorage").Modules.GunFramework.Modules.Projectile
    )
    if not success then
        warn("[Rayfield] Projectile module not found. Aimbot will not work.")
        return
    end
    
    local originalNew = Projectile.new
    Projectile.new = function(params)
        if params and params.Origin and params.Direction and Settings.Enabled then
            local target = getClosestTarget()
            if target then
                params.Direction = (target.Position - params.Origin).Unit
            end
        end
        return originalNew(params)
    end
    print("[Rayfield] Silent aim hooked.")
end
hookProjectiles()

-- Update FOV circle position and color each frame
RunService.RenderStepped:Connect(function()
    local mousePos = UserInputService:GetMouseLocation()
    circle.Position = UDim2.fromOffset(mousePos.X, mousePos.Y)
    
    local targetInside = getClosestTarget() ~= nil
    if targetInside and Settings.Enabled then
        stroke.Color = Color3.fromRGB(255, 50, 50)  -- Red = target inside
    else
        stroke.Color = Color3.fromRGB(255, 255, 255) -- White = no target
    end
end)

-- ========== Rayfield Menu ==========
local Window = Rayfield:CreateWindow({
    Name = "Silent Aim",
    LoadingTitle = "Aimbot",
    Theme = "Default",
})

local MainTab = Window:CreateTab("Aimbot")

MainTab:CreateToggle({
    Name = "Enable Silent Aim",
    CurrentValue = Settings.Enabled,
    Callback = function(v)
        Settings.Enabled = v
    end,
})

MainTab:CreateSlider({
    Name = "FOV Radius",
    Range = {50, 400},
    Increment = 1,
    Suffix = "px",
    CurrentValue = Settings.FOV,
    Callback = function(v)
        Settings.FOV = v
        updateFOVCircle()
    end,
})

MainTab:CreateDropdown({
    Name = "Target Body Part",
    Options = {"Head", "UpperTorso", "LowerTorso", "HumanoidRootPart"},
    CurrentOption = Settings.TargetPart,
    Callback = function(v)
        Settings.TargetPart = v
    end,
})

print("Rayfield menu + FOV circle loaded. FOV circle follows mouse, red = target inside.")
