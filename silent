-- Services
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- Settings
local Settings = {
    Enabled = true,
    FOV = 200,
    TargetPart = "Head"
}

-- ========== FOV CIRCLE (native) ==========
local gui = Instance.new("ScreenGui")
gui.Name = "AimbotFOV"
gui.ResetOnSpawn = false
gui.Parent = game:GetService("CoreGui")

local circle = Instance.new("Frame")
circle.BackgroundTransparency = 1
circle.Size = UDim2.fromOffset(Settings.FOV * 2, Settings.FOV * 2)
circle.AnchorPoint = Vector2.new(0.5, 0.5)
circle.Parent = gui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(1, 0)
corner.Parent = circle

local stroke = Instance.new("UIStroke")
stroke.Thickness = 2
stroke.Transparency = 0.3
stroke.Color = Color3.fromRGB(255, 255, 255)
stroke.Parent = circle

local function updateCircleSize()
    circle.Size = UDim2.fromOffset(Settings.FOV * 2, Settings.FOV * 2)
end

-- ========== SILENT AIM CORE ==========
local function getClosestTarget()
    if not Settings.Enabled then return nil end
    local mousePos = UserInputService:GetMouseLocation()
    local bestDist = Settings.FOV
    local bestTarget = nil

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local part = player.Character:FindFirstChild(Settings.TargetPart)
            local hum = player.Character:FindFirstChildWhichIsA("Humanoid")
            if part and hum and hum.Health > 0 then
                local vec, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local dist = (Vector2.new(vec.X, vec.Y) - mousePos).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        bestTarget = part
                    end
                end
            end
        end
    end
    return bestTarget
end

-- Hook projectile (original method)
local function hookProjectile()
    local repStorage = game:GetService("ReplicatedStorage")
    local projectileModule = repStorage:FindFirstChild("Modules")
    if projectileModule then projectileModule = projectileModule:FindFirstChild("GunFramework") end
    if projectileModule then projectileModule = projectileModule:FindFirstChild("Modules") end
    if not projectileModule then
        warn("Projectile module not found – aimbot won't work")
        return
    end
    local ok, Projectile = pcall(require, projectileModule.Projectile)
    if not ok then return end
    local old = Projectile.new
    Projectile.new = function(p)
        if p and p.Origin and p.Direction and Settings.Enabled then
            local target = getClosestTarget()
            if target then
                p.Direction = (target.Position - p.Origin).Unit
            end
        end
        return old(p)
    end
    print("Projectile hooked")
end
hookProjectile()

-- Update circle position and color
RunService.RenderStepped:Connect(function()
    local mouse = UserInputService:GetMouseLocation()
    circle.Position = UDim2.fromOffset(mouse.X, mouse.Y)
    local target = getClosestTarget()
    stroke.Color = (target and Settings.Enabled) and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(255,255,255)
end)

-- ========== RAYFIELD MENU (forced to appear) ==========
local window = Rayfield:CreateWindow({
    Name = "Silent Aim",
    LoadingTitle = "Aimbot Control",
    Theme = "Default"
})

local tab = window:CreateTab("Aimbot")

tab:CreateToggle({
    Name = "Enable Silent Aim",
    CurrentValue = Settings.Enabled,
    Callback = function(v) Settings.Enabled = v end
})

tab:CreateSlider({
