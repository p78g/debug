-- // Destroy any leftover Iris GUI (to prevent conflicts)
pcall(function()
    local irisGui = game.CoreGui:FindFirstChild("Iris")
    if irisGui then irisGui:Destroy() end
end)

-- // Load Rayfield
local Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/shlexware/Rayfield/main/source'))()

-- // Services
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- // Settings
local Settings = {
    Enabled = true,
    FOV_Size = 150,
    TargetPart = "Head",
}

-- // Create FOV Circle UI
local fovGui = Instance.new("ScreenGui")
fovGui.Name = "SilentAimFOV"
fovGui.ResetOnSpawn = false
fovGui.Parent = LocalPlayer.PlayerGui

local fovCircle = Instance.new("Frame")
fovCircle.BackgroundTransparency = 1
fovCircle.BorderSizePixel = 0
fovCircle.AnchorPoint = Vector2.new(0.5, 0.5)
fovCircle.Size = UDim2.fromOffset(Settings.FOV_Size * 2, Settings.FOV_Size * 2)
fovCircle.Parent = fovGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(1, 0)
corner.Parent = fovCircle

local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(255, 0, 0)
stroke.Thickness = 2
stroke.Transparency = 0.4
stroke.Parent = fovCircle

local function updateFOVCircle()
    fovCircle.Size = UDim2.fromOffset(Settings.FOV_Size * 2, Settings.FOV_Size * 2)
end

-- // Silent Aim Core
local function getClosestTarget()
    if not Settings.Enabled then return nil end
    local mousePos = UserInputService:GetMouseLocation()
    local bestDist = Settings.FOV_Size
    local bestTarget = nil

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local targetPart = player.Character:FindFirstChild(Settings.TargetPart)
            local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
            if targetPart and humanoid and humanoid.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        bestTarget = targetPart
                    end
                end
            end
        end
    end
    return bestTarget
end

-- Hook the projectile module
local function hookProjectile()
    local success, Projectile = pcall(require, game:GetService("ReplicatedStorage").Modules.GunFramework.Modules.Projectile)
    if success then
        local originalNew = Projectile.new
        Projectile.new = function(params)
            if params and params.Origin and params.Direction and Settings.Enabled then
                local target = getClosestTarget()
                if target then
                    local newDir = (target.Position - params.Origin).Unit
                    params.Direction = newDir
                end
            end
            return originalNew(params)
        end
        print("[Silent Aim] Hooked successfully!")
    else
        warn("[Silent Aim] Projectile module not found – aimbot will not work.")
    end
end
hookProjectile()

-- Update FOV circle position and color
RunService.RenderStepped:Connect(function()
    local mousePos = UserInputService:GetMouseLocation()
    fovCircle.Position = UDim2.fromOffset(mousePos.X, mousePos.Y)

    if getClosestTarget() and Settings.Enabled then
        stroke.Color = Color3.fromRGB(255, 50, 50)   -- red
    else
        stroke.Color = Color3.fromRGB(255, 255, 255) -- white
    end
end)

-- // ==================== RAYFIELD GUI ====================
local Window = Rayfield:CreateWindow({
    Name = "Silent Aim Control",
    LoadingTitle = "Loading...",
    LoadingSubtitle = "by Script",
    Theme = "Default",
})

local MainTab = Window:CreateTab("Aimbot")

MainTab:CreateToggle({
    Name = "Enable Silent Aim",
    CurrentValue = Settings.Enabled,
    Callback = function(Value)
        Settings.Enabled = Value
    end,
})

MainTab:CreateSlider({
    Name = "FOV Radius",
    Range = {50, 400},
    Increment = 1,
    Suffix = "px",
    CurrentValue = Settings.FOV_Size,
    Callback = function(Value)
        Settings.FOV_Size = Value
        updateFOVCircle()
    end,
})

MainTab:CreateDropdown({
    Name = "Target Body Part",
    Options = {"Head", "UpperTorso", "LowerTorso", "HumanoidRootPart"},
    CurrentOption = Settings.TargetPart,
    Callback = function(Option)
        Settings.TargetPart = Option
    end,
})

MainTab:CreateParagraph({
    Name = "Info",
    Content = "FOV Circle: Red = target inside, White = none\nWorks with projectile weapons only."
})

print("[Rayfield] GUI loaded successfully!")
