-- // Load Rayfield (correct URL)
local Rayfield = loadstring(game:HttpGet("https://raw.githubusercontent.com/shlexware/Rayfield/main/source.lua"))()

-- // Services
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- // Settings (linked to UI)
local Settings = {
    Enabled = true,
    FOV = 150,
    TargetPart = "Head",
}

-- // Visual FOV Circle (red when target inside)
local fovGui = Instance.new("ScreenGui")
fovGui.Name = "SilentAimFOV"
fovGui.ResetOnSpawn = false
fovGui.Parent = game:GetService("CoreGui")

local circle = Instance.new("Frame")
circle.BackgroundTransparency = 1
circle.BorderSizePixel = 0
circle.AnchorPoint = Vector2.new(0.5, 0.5)
circle.Size = UDim2.fromOffset(Settings.FOV * 2, Settings.FOV * 2)
circle.Parent = fovGui

local uiCorner = Instance.new("UICorner")
uiCorner.CornerRadius = UDim.new(1, 0)
uiCorner.Parent = circle

local stroke = Instance.new("UIStroke")
stroke.Thickness = 2
stroke.Transparency = 0.4
stroke.Color = Color3.fromRGB(255, 255, 255)
stroke.Parent = circle

local function updateFOVSize()
    circle.Size = UDim2.fromOffset(Settings.FOV * 2, Settings.FOV * 2)
end

-- // Silent Aim Logic (from your raw script)
local function getClosestTarget()
    if not Settings.Enabled then return nil end
    local mousePos = UserInputService:GetMouseLocation()
    local bestDist = Settings.FOV
    local bestPart = nil

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local part = player.Character:FindFirstChild(Settings.TargetPart)
            local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
            if part and humanoid and humanoid.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        bestPart = part
                    end
                end
            end
        end
    end
    return bestPart
end

-- Hook into projectile creation (same as raw script)
local function hookProjectiles()
    local replicatedStorage = game:GetService("ReplicatedStorage")
    local module = replicatedStorage:FindFirstChild("Modules")
    if module then module = module:FindFirstChild("GunFramework") end
    if module then module = module:FindFirstChild("Modules") end
    if not module then 
        warn("Projectile module not found")
        return 
    end
    
    local success, Projectile = pcall(require, module.Projectile)
    if not success or not Projectile then 
        warn("Failed to require Projectile")
        return
    end
    
    local originalNew = Projectile.new
    Projectile.new = function(params)
        if params and params.Origin and params.Direction and Settings.Enabled then
            local target = getClosestTarget()
            if target then
                params.Direction = (target.Position - params.Origin).Unit
            end
        end
        return originalNew(params)
    end
    print("Silent aim hooked")
end

hookProjectiles()

-- // Update FOV circle position & color
RunService.RenderStepped:Connect(function()
    local mousePos = UserInputService:GetMouseLocation()
    circle.Position = UDim2.fromOffset(mousePos.X, mousePos.Y)
    
    local targetInside = getClosestTarget() ~= nil
    stroke.Color = (targetInside and Settings.Enabled) and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(255, 255, 255)
end)

-- // ========== RAYFIELD MENU ==========
local window = Rayfield:CreateWindow({
    Name = "Silent Aim",
    LoadingTitle = "Loading...",
    Theme = "Default",
})

local mainTab = window:CreateTab("Aimbot")

mainTab:CreateToggle({
    Name = "Enable Silent Aim",
    CurrentValue = Settings.Enabled,
    Callback = function(v)
        Settings.Enabled = v
    end,
})

mainTab:CreateSlider({
    Name = "FOV Radius",
    Range = {50, 400},
    Increment = 1,
    Suffix = "px",
    CurrentValue = Settings.FOV,
    Callback = function(v)
        Settings.FOV = v
        updateFOVSize()
    end,
})

mainTab:CreateDropdown({
    Name = "Target Body Part",
    Options = {"Head", "UpperTorso", "LowerTorso", "HumanoidRootPart"},
    CurrentOption = Settings.TargetPart,
    Callback = function(v)
        Settings.TargetPart = v
    end,
})

print("Rayfield menu loaded. Use it to control silent aim.")
