-- Load Rayfield
local Rayfield = loadstring(game:HttpGet("https://raw.githubusercontent.com/SiriusSoftwareLtd/Rayfield/main/source.lua"))()

-- Services
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- Settings (controlled by Rayfield)
local Settings = {
    Enabled = true,
    FOV = 200,
    TargetPart = "Head",
}

-- ========== VISUAL FOV CIRCLE ==========
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "SilentAimFOV"
screenGui.ResetOnSpawn = false
screenGui.Parent = game:GetService("CoreGui")

local circle = Instance.new("Frame")
circle.BackgroundTransparency = 1
circle.BorderSizePixel = 0
circle.AnchorPoint = Vector2.new(0.5, 0.5)
circle.Size = UDim2.fromOffset(Settings.FOV * 2, Settings.FOV * 2)
circle.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(1, 0)
corner.Parent = circle

local stroke = Instance.new("UIStroke")
stroke.Thickness = 2
stroke.Transparency = 0.4
stroke.Color = Color3.fromRGB(255, 255, 255) -- white default
stroke.Parent = circle

local function updateFOVSize()
    circle.Size = UDim2.fromOffset(Settings.FOV * 2, Settings.FOV * 2)
end

-- ========== SILENT AIM LOGIC (same as raw script) ==========
local function getClosestTarget()
    if not Settings.Enabled then return nil end
    local mousePos = UserInputService:GetMouseLocation()
    local bestDist = Settings.FOV
    local bestTarget = nil

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local targetPart = player.Character:FindFirstChild(Settings.TargetPart)
            local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
            if targetPart and humanoid and humanoid.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        bestTarget = targetPart
                    end
                end
            end
        end
    end
    return bestTarget
end

-- Hook projectile system (same as original script)
local function hookProjectiles()
    local replicatedStorage = game:GetService("ReplicatedStorage")
    local modulePath = replicatedStorage:FindFirstChild("Modules")
    if modulePath then modulePath = modulePath:FindFirstChild("GunFramework") end
    if modulePath then modulePath = modulePath:FindFirstChild("Modules") end
    if not modulePath then
        warn("[FOV Circle] Projectile module not found. Aimbot may not work.")
        return
    end
    
    local success, Projectile = pcall(require, modulePath.Projectile)
    if not success or not Projectile then
        warn("[FOV Circle] Failed to require Projectile.")
        return
    end
    
    local originalNew = Projectile.new
    Projectile.new = function(params)
        if params and params.Origin and params.Direction and Settings.Enabled then
            local target = getClosestTarget()
            if target then
                params.Direction = (target.Position - params.Origin).Unit
            end
        end
        return originalNew(params)
    end
    print("[FOV Circle] Silent aim hooked.")
end
hookProjectiles()

-- Update circle position and color each frame
RunService.RenderStepped:Connect(function()
    local mousePos = UserInputService:GetMouseLocation()
    circle.Position = UDim2.fromOffset(mousePos.X, mousePos.Y)
    
    local target = getClosestTarget()
    if target and Settings.Enabled then
        stroke.Color = Color3.fromRGB(255, 50, 50)  -- Red when target inside
    else
        stroke.Color = Color3.fromRGB(255, 255, 255) -- White when no target
    end
end)

-- ========== RAYFIELD MENU ==========
local Window = Rayfield:CreateWindow({
    Name = "Silent Aim + FOV Circle",
    LoadingTitle = "Aimbot",
    Theme = "Default",
})

local MainTab = Window:CreateTab("Aimbot")

MainTab:CreateToggle({
    Name = "Enable Silent Aim",
    CurrentValue = Settings.Enabled,
    Callback = function(v)
        Settings.Enabled = v
    end,
})

MainTab:CreateSlider({
    Name = "FOV Radius (px)",
    Range = {50, 400},
    Increment = 1,
    Suffix = "px",
    CurrentValue = Settings.FOV,
    Callback = function(v)
        Settings.FOV = v
        updateFOVSize()
    end,
})

MainTab:CreateDropdown({
    Name = "Target Body Part",
    Options = {"Head", "UpperTorso", "LowerTorso", "HumanoidRootPart"},
    CurrentOption = Settings.TargetPart,
    Callback = function(v)
        Settings.TargetPart = v
    end,
})

print("Rayfield menu + FOV circle loaded. Circle follows mouse, red = target inside.")
