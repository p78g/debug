--[[
    Simple Automation Script
    Steps:
    1. Withdraw 5050
    2. Respawn (0.6s wait)
    3. Teleport to Gun Store (CFrame)
    4. Fire proximity prompt
    5. Teleport back to original position
    6. Buy SkiMask (50)
    7. Equip Mask (fire remote directly)
]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

-- Helper: wait with custom delay
local function Wait(delay)
    task.wait(delay)
end

-- Helper: wait for character and return its HumanoidRootPart
local function GetCharacter()
    local character = LocalPlayer.Character
    if not character or not character.Parent then
        character = LocalPlayer.CharacterAdded:Wait()
    end
    local rootPart = character:WaitForChild("HumanoidRootPart", 10)
    return character, rootPart
end

-- Step 0: Save original position BEFORE any changes
local character, rootPart = GetCharacter()
local originalPosition = rootPart.Position
print("Original position saved:", originalPosition)

-- Wait for remotes
local Remotes = ReplicatedStorage:WaitForChild("Remotes", 10)
local ATM = Remotes:WaitForChild("ATM", 10)
local ControllerRemote = Remotes:WaitForChild("ControllerRemote", 10)
local BuyRemote = Remotes:WaitForChild("Buy", 10)

-- Step 1: Withdraw
print("Step 1: Withdraw 5050")
ATM:FireServer("Withdraw", 5050)
Wait(0.3)

-- Step 2: Respawn
print("Step 2: Respawn")
ControllerRemote:FireServer("/respawn")
Wait(0.6)  -- extra time for respawn to complete

-- Step 3: Get new character after respawn
print("Waiting for new character...")
character, rootPart = GetCharacter()
print("New character loaded, teleporting to Gun Store")

-- Teleport to Gun Store (CFrame)
rootPart.CFrame = CFrame.new(1053, 54, -104)
Wait(0.3)

-- Step 4: Fire proximity prompt
print("Step 4: Firing proximity prompt")
local prompt = workspace:WaitForChild("Map", 10):WaitForChild("GunStore", 10):WaitForChild("GunTable", 10):WaitForChild("ProPad", 10):WaitForChild("Handle", 10):WaitForChild("ProximityPrompt", 10)
prompt:Prompt()  -- directly fire, no fallback
Wait(0.3)

-- Step 5: Teleport back to original position
print("Step 5: Returning to original position")
rootPart.CFrame = CFrame.new(originalPosition.X, originalPosition.Y, originalPosition.Z)
Wait(0.3)

-- Step 6: Buy SkiMask
print("Step 6: Buy SkiMask (50)")
BuyRemote:FireServer("SkiMask", 50)
Wait(0.3)

-- Step 7: Equip mask – fire remote directly
print("Step 7: Equip mask")
local maskedFolder = character:WaitForChild("MASKED", 10)
local maskRemote = maskedFolder:WaitForChild("RemoteEvent", 10)
maskRemote:FireServer("Equip")

print("All steps completed.")
