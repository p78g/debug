--[[
    Full Automation Script
    Steps:
    1. Withdraw 5050 from ATM
    2. Respawn
    3. Teleport to Gun Store (1053, 54, -104)
    4. Fire proximity prompt
    5. Teleport back to original position
    6. Buy SkiMask (50)
    7. Equip Mask
]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

-- Helper: wait with print
local function Cooldown(seconds)
    task.wait(seconds or 0.2)
end

-- Helper: wait for character and essential parts
local function GetCharacter()
    local character = LocalPlayer.Character
    if not character or not character.Parent then
        character = LocalPlayer.CharacterAdded:Wait()
    end
    local rootPart = character:WaitForChild("HumanoidRootPart", 10)
    local humanoid = character:WaitForChild("Humanoid", 10)
    return character, rootPart, humanoid
end

-- Helper: safe teleport
local function TeleportTo(character, x, y, z)
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if rootPart then
        rootPart.CFrame = CFrame.new(x, y, z)
        Cooldown(0.1) -- let physics settle
        return true
    end
    return false
end

-- Get initial character
local character, rootPart, humanoid = GetCharacter()
if not character then error("Character not loaded") end
local originalPosition = rootPart.Position
print("Original position:", originalPosition)

-- Wait for remotes
local Remotes = ReplicatedStorage:WaitForChild("Remotes", 10)
local ATM = Remotes:WaitForChild("ATM", 10)
local ControllerRemote = Remotes:WaitForChild("ControllerRemote", 10)
local BuyRemote = Remotes:WaitForChild("Buy", 10)

-- Step 1: Withdraw
print("Step 1: Withdrawing 5050...")
ATM:FireServer("Withdraw", 5050)
Cooldown()

-- Step 2: Respawn
print("Step 2: Respawning...")
ControllerRemote:FireServer("/respawn")
Cooldown(1) -- wait for respawn to start

-- Wait for new character after respawn
print("Waiting for new character...")
character, rootPart, humanoid = GetCharacter()
print("New character loaded")

-- Get MaskRemote from the new character
local maskedFolder = character:WaitForChild("MASKED", 10)
local MaskRemote = maskedFolder and maskedFolder:WaitForChild("RemoteEvent", 10)
if not MaskRemote then
    warn("MaskRemote not found! Step 7 may fail.")
end

-- Step 3: Teleport to Gun Store
print("Step 3: Teleporting to (1053, 54, -104)...")
TeleportTo(character, 1053, 54, -104)
Cooldown()

-- Step 4: Fire proximity prompt
print("Step 4: Firing proximity prompt...")
local promptPath = workspace:WaitForChild("Map", 10):WaitForChild("GunStore", 10):WaitForChild("GunTable", 10):WaitForChild("ProPad", 10):WaitForChild("Handle", 10):WaitForChild("ProximityPrompt", 10)
if promptPath then
    -- Use Prompt() to simulate interaction
    local success, err = pcall(function()
        promptPath:Prompt()
    end)
    if success then
        print("Prompt fired successfully")
    else
        warn("Failed to fire prompt:", err)
    end
else
    warn("ProximityPrompt not found in workspace")
end
Cooldown()

-- Step 5: Teleport back to original position
print("Step 5: Returning to original position...")
TeleportTo(character, originalPosition.X, originalPosition.Y, originalPosition.Z)
Cooldown()

-- Step 6: Buy SkiMask
print("Step 6: Buying SkiMask (50)...")
BuyRemote:FireServer("SkiMask", 50)
Cooldown()

-- Step 7: Equip Mask
print("Step 7: Equipping mask...")
if MaskRemote then
    MaskRemote:FireServer("Equip")
    print("Equip fired")
else
    warn("MaskRemote missing – skipping equip")
end

print("All steps completed!")
