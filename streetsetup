--[[
    Auto Buy & Equip SkiMask (No duplicate guards)
]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")

local function Wait(sec) task.wait(sec or 0.3) end

local function GetCharacter()
    local char = LocalPlayer.Character
    if not char or not char.Parent then
        char = LocalPlayer.CharacterAdded:Wait()
    end
    local rootPart = char:WaitForChild("HumanoidRootPart", 10)
    return char, rootPart
end

-- Remotes
local remotes = ReplicatedStorage:WaitForChild("Remotes", 10)
local ATM = remotes:WaitForChild("ATM", 10)
local ControllerRemote = remotes:WaitForChild("ControllerRemote", 10)
local BuyRemote = remotes:WaitForChild("Buy", 10)

-- Step 1: Withdraw
print("[1] Withdraw 5050")
ATM:FireServer("Withdraw", 5050)
Wait(0.3)

-- Step 2: Respawn
print("[2] Respawn")
ControllerRemote:FireServer("/respawn")
Wait(1.5)

-- Step 3: Get new character
print("[3] Getting new character")
local char, rootPart = GetCharacter()
print("New character loaded")

-- Step 4: Teleport to Gun Store
print("[4] Teleport to Gun Store")
rootPart.CFrame = CFrame.new(1053, 54, -104)
Wait(0.5)

-- Step 5: Buy SkiMask
print("[5] Buying SkiMask (50)")
local args = {
	"SkiMask",
	50
}
game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("Buy"):FireServer(unpack(args))

wait(0.5)

-- Step 6: Equip mask
print("[6] Equipping mask")
function getNil(name,class) 
    for _,v in next, getnilinstances() do 
        if v.ClassName == class and v.Name == name then 
            return v
        end 
    end 
end

local args = {
	"Equip"
}
game:GetService("Players").LocalPlayer:WaitForChild("Backpack"):WaitForChild("MASKED"):WaitForChild("RemoteEvent"):FireServer(unpack(args))

print("✅ All steps completed.")
