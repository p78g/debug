-- Town Build Copier - Most Aggressive Final Attempt

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Town Plot Copier - Aggressive Final",
    LoadingTitle = "Loading...",
    Theme = "Default"
})

local Tab = Window:CreateTab("Copier", "hammer")

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

local BUILDING_AREAS = Workspace:WaitForChild("Private Building Areas")

local DebugLog = {}

local function log(msg)
    local line = os.date("%X") .. " | " .. msg
    table.insert(DebugLog, line)
    print("[Copier] " .. msg)
end

local function getRemote()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local tool = char:WaitForChild("Building Tools", 5)
    if not tool then error("Equip Building Tools!") end
    return tool:WaitForChild("SyncAPI"):WaitForChild("ServerEndpoint")
end

local localBuildArea = BUILDING_AREAS:WaitForChild(LocalPlayer.Name .. "BuildArea")
local localBuildFolder = localBuildArea:WaitForChild("Build")

local selectedPlayer = nil

local playerOptions = {}

local function refreshPlayers()
    playerOptions = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and BUILDING_AREAS:FindFirstChild(plr.Name .. "BuildArea") then
            table.insert(playerOptions, plr.Name)
        end
    end
end
refreshPlayers()

Tab:CreateSection("Player")
local Dropdown = Tab:CreateDropdown({
    Name = "Select Player to Copy From",
    Options = playerOptions,
    CurrentOption = {},
    MultipleOptions = false,
    Callback = function(Option)
        selectedPlayer = (typeof(Option) == "table" and #Option > 0) and Players:FindFirstChild(Option[1]) or nil
    end,
})

Tab:CreateButton({
    Name = "🔄 Copy Build (Aggressive Final)",
    Description = "Maximum force on rotation and resize",
    Callback = function()
        if not selectedPlayer then
            Rayfield:Notify({Title = "Error", Content = "Select player first!"})
            return
        end

        DebugLog = {}
        log("=== COPY STARTED ===")
        log("Target player: " .. selectedPlayer.Name)

        local remote = getRemote()
        local sourceArea = BUILDING_AREAS:FindFirstChild(selectedPlayer.Name .. "BuildArea")
        if not sourceArea then
            log("ERROR: Source area not found")
            return
        end

        local sourceBuild = sourceArea:WaitForChild("Build")
        log("Source build folder located")

        local allParts = {}
        local function collect(obj)
            for _, v in ipairs(obj:GetDescendants()) do
                if v:IsA("BasePart") then table.insert(allParts, v) end
            end
        end
        collect(sourceBuild)

        log("Found " .. #allParts .. " BaseParts")

        local sumX, sumY, sumZ = 0, 0, 0
        for _, p in ipairs(allParts) do
            local pos = p.Position
            sumX += pos.X; sumY += pos.Y; sumZ += pos.Z
        end
        local sourceCenter = Vector3.new(sumX/#allParts, sumY/#allParts, sumZ/#allParts)

        local destOrigin = localBuildArea.Position + Vector3.new(0, sourceCenter.Y - localBuildArea.Position.Y, 0)

        local createdParts = {}
        local processed = {}

        for i, sourcePart in ipairs(allParts) do
            local offset = sourcePart.Position - sourceCenter
            local targetPos = destOrigin + offset

            local rotX, rotY, rotZ = 0, 0, 0
            if sourcePart.Rotation and typeof(sourcePart.Rotation) == "Vector3" then
                rotX = sourcePart.Rotation.X
                rotY = sourcePart.Rotation.Y
                rotZ = sourcePart.Rotation.Z
                log(string.format("Part %d | Rotation: %.2f, %.2f, %.2f", i, rotX, rotY, rotZ))
            end

            local targetCFrame = CFrame.new(targetPos) * CFrame.fromEulerAnglesXYZ(math.rad(rotX), math.rad(rotY), math.rad(rotZ))

            local partType = "Normal"
            local class = sourcePart.ClassName
            if class == "TrussPart" then partType = "Truss"
            elseif class == "WedgePart" then partType = "Wedge"
            elseif class == "CornerWedgePart" then partType = "Corner"
            elseif class == "Cylinder" or sourcePart.Shape == Enum.PartType.Cylinder then partType = "Cylinder"
            elseif sourcePart.Shape == Enum.PartType.Ball then partType = "Ball"
            elseif class == "Seat" then partType = "Seat"
            elseif class == "VehicleSeat" then partType = "Vehicle Seat"
            elseif class == "SpawnLocation" then partType = "Spawn"
            end

            local newPart = remote:InvokeServer("CreatePart", partType, CFrame.new(targetPos), localBuildFolder)

            if newPart and newPart:IsA("BasePart") then
                table.insert(createdParts, newPart)
                table.insert(processed, {newPart = newPart, sourcePart = sourcePart, targetCFrame = targetCFrame})

                local sourceSize = sourcePart.Size

                -- Extremely aggressive resize
                task.wait(0.5)
                for _ = 1, 5 do
                    remote:InvokeServer("SyncResize", {{ Part = newPart, CFrame = targetCFrame, Size = sourceSize }}, { "Direct", Vector3.new(sourceSize.X - newPart.Size.X, 0, 0), "X", sourceSize })
                    task.wait(0.2)
                    remote:InvokeServer("SyncResize", {{ Part = newPart, CFrame = targetCFrame, Size = sourceSize }}, { "Direct", Vector3.new(0, sourceSize.Y - newPart.Size.Y, 0), "Y", sourceSize })
                    task.wait(0.2)
                    remote:InvokeServer("SyncResize", {{ Part = newPart, CFrame = targetCFrame, Size = sourceSize }}, { "Direct", Vector3.new(0, 0, sourceSize.Z - newPart.Size.Z), "Z", sourceSize })
                    task.wait(0.2)
                end

                log("  Resize finished | Final Size: " .. tostring(newPart.Size))

                -- Strong rotation attempt
                local nonZero = (math.abs(rotX) > 1) + (math.abs(rotY) > 1) + (math.abs(rotZ) > 1)
                if nonZero <= 1 then
                    log("  Single-axis - Direct")
                    remote:InvokeServer("SyncRotate", {{ Part = newPart, CFrame = targetCFrame }}, { "Direct", math.rad(rotX), "X" })
                    task.wait(0.3)
                    remote:InvokeServer("SyncRotate", {{ Part = newPart, CFrame = targetCFrame }}, { "Direct", math.rad(rotY), "Y" })
                    task.wait(0.3)
                    remote:InvokeServer("SyncRotate", {{ Part = newPart, CFrame = targetCFrame }}, { "Direct", math.rad(rotZ), "Z" })
                    task.wait(0.3)
                else
                    log("  Mixed - AroundPivot full")
                    remote:InvokeServer("SyncRotate", 
                        {{ Part = newPart, CFrame = targetCFrame }},
                        { "AroundPivot", targetCFrame.Rotation, "Center", CFrame.new(), "Center" }
                    )
                    task.wait(0.6)
                end

                -- Final move
                remote:InvokeServer("SyncMove", {{Part = newPart, CFrame = targetCFrame}}, {"AlongFace", Vector3.new(), "Global", CFrame.new()})
                task.wait(0.4)

                log("  Part " .. i .. " complete")
            end
        end

        if #createdParts > 0 then
            remote:InvokeServer("CreateGroup", "Model", localBuildFolder, createdParts)
        end

        log("=== COPY FINISHED ===")
        Rayfield:Notify({Title = "Finished", Content = #createdParts .. " parts created", Duration = 10})
    end,
})

Tab:CreateButton({
    Name = "📋 Copy Debug Log",
    Callback = function()
        local text = table.concat(DebugLog, "\n")
        if setclipboard then setclipboard(text) end
        Rayfield:Notify({Title = "Copied", Content = "Debug log copied", Duration = 5})
    end,
})

Tab:CreateButton({ Name = "Refresh Player List", Callback = function()
    refreshPlayers()
    Dropdown:Refresh(playerOptions)
end })

Rayfield:Notify({Title = "Loaded", Content = "Aggressive resize + smart rotation", Duration = 8})
