-- Town Build Copier - Final Version

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Town Plot Copier",   -- Changed name
    LoadingTitle = "Loading Copier...",
    Theme = "Default"
})

local Tab = Window:CreateTab("Copier", "hammer")

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

local BUILDING_AREAS = Workspace:WaitForChild("Private Building Areas")

local function getRemote()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local tool = char:WaitForChild("Building Tools", 5)
    if not tool then error("Equip Building Tools!") end
    return tool:WaitForChild("SyncAPI"):WaitForChild("ServerEndpoint")
end

local localBuildArea = BUILDING_AREAS:WaitForChild(LocalPlayer.Name .. "BuildArea")
local localBuildFolder = localBuildArea:WaitForChild("Build")

local BASE_Y = 4
local X_OFFSET = -28.637
local Z_OFFSET = -17.512
local EXTRA_Y = 0

local selectedPlayer = nil

local playerOptions = {}

local function refreshPlayers()
    playerOptions = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and BUILDING_AREAS:FindFirstChild(plr.Name .. "BuildArea") then
            table.insert(playerOptions, plr.Name)
        end
    end
end
refreshPlayers()

Tab:CreateSection("Player")
local Dropdown = Tab:CreateDropdown({
    Name = "Select Player to Copy From",
    Options = playerOptions,
    CurrentOption = {},
    MultipleOptions = false,
    Callback = function(Option)
        selectedPlayer = (typeof(Option) == "table" and #Option > 0) and Players:FindFirstChild(Option[1]) or nil
    end,
})

Tab:CreateSection("Offsets")
Tab:CreateSlider({ Name = "X Offset", Range = {-100, 100}, Increment = 0.01, CurrentValue = X_OFFSET, Callback = function(v) X_OFFSET = v end })
Tab:CreateSlider({ Name = "Extra Y", Range = {-20, 50}, Increment = 0.1, CurrentValue = EXTRA_Y, Callback = function(v) EXTRA_Y = v end })
Tab:CreateSlider({ Name = "Z Offset", Range = {-100, 100}, Increment = 0.01, CurrentValue = Z_OFFSET, Callback = function(v) Z_OFFSET = v end })

Tab:CreateButton({
    Name = "🔄 Copy Build",
    Description = "Resize → Rotate → Move | Height = 4",
    Callback = function()
        if not selectedPlayer then
            Rayfield:Notify({Title = "Error", Content = "Select player first!"})
            return
        end

        local remote = getRemote()
        local sourceArea = BUILDING_AREAS:FindFirstChild(selectedPlayer.Name .. "BuildArea")
        if not sourceArea then 
            Rayfield:Notify({Title = "Error", Content = "Source not found"}) 
            return 
        end

        local sourceBuild = sourceArea:WaitForChild("Build")

        local allParts = {}
        local function collect(obj)
            for _, v in ipairs(obj:GetDescendants()) do
                if v:IsA("BasePart") then table.insert(allParts, v) end
            end
        end
        collect(sourceBuild)

        if #allParts == 0 then
            Rayfield:Notify({Title = "Error", Content = "No parts found"})
            return
        end

        local sumX, sumY, sumZ = 0, 0, 0
        for _, p in ipairs(allParts) do
            local pos = p.Position
            sumX += pos.X; sumY += pos.Y; sumZ += pos.Z
        end
        local sourceCenter = Vector3.new(sumX/#allParts, sumY/#allParts, sumZ/#allParts)

        local destOrigin = localBuildArea.Position + Vector3.new(X_OFFSET, BASE_Y + EXTRA_Y, Z_OFFSET)

        Rayfield:Notify({Title = "Copying...", Content = "Processing build...", Duration = 6})

        local createdParts = {}

        for _, sourcePart in ipairs(allParts) do
            local offset = sourcePart.Position - sourceCenter
            local targetPos = destOrigin + offset
            local targetCFrame = CFrame.new(targetPos) * sourcePart.CFrame.Rotation

            local partType = "Normal"
            local class = sourcePart.ClassName
            if class == "TrussPart" then partType = "Truss"
            elseif class == "WedgePart" then partType = "Wedge"
            elseif class == "CornerWedgePart" then partType = "Corner"
            elseif class == "Cylinder" or sourcePart.Shape == Enum.PartType.Cylinder then partType = "Cylinder"
            elseif sourcePart.Shape == Enum.PartType.Ball then partType = "Ball"
            elseif class == "Seat" then partType = "Seat"
            elseif class == "VehicleSeat" then partType = "Vehicle Seat"
            elseif class == "SpawnLocation" then partType = "Spawn"
            end

            local newPart = remote:InvokeServer("CreatePart", partType, CFrame.new(targetPos), localBuildFolder)

            if newPart and newPart:IsA("BasePart") then
                table.insert(createdParts, newPart)

                -- Resize First
                remote:InvokeServer("SyncResize",
                    {{ Part = newPart, CFrame = targetCFrame, Size = sourcePart.Size }},
                    { "ResizeFace", Enum.NormalId.Right, sourcePart.Size.X - newPart.Size.X, Vector3.new(sourcePart.Size.X - newPart.Size.X, 0, 0), "X", Vector3.xAxis, "Normal" }
                )
                task.wait(0.5)

                -- Rotate
                remote:InvokeServer("SyncRotate", {{Part = newPart, CFrame = targetCFrame}}, {"AroundPivot", CFrame.new(), "Center", CFrame.new(), "Center"})
                task.wait(0.5)

                -- Move
                remote:InvokeServer("SyncMove", {{Part = newPart, CFrame = targetCFrame}}, {"AlongFace", Vector3.new(), "Global", CFrame.new()})
                task.wait(0.5)
            end
        end

        if #createdParts > 0 then
            remote:InvokeServer("CreateGroup", "Model", localBuildFolder, createdParts)
        end

        Rayfield:Notify({Title = "Finished", Content = #createdParts .. " parts created", Duration = 8})
    end,
})

Tab:CreateButton({ Name = "Refresh Player List", Callback = function()
    refreshPlayers()
    Dropdown:Refresh(playerOptions)
end })

Rayfield:Notify({Title = "Town Plot Copier", Content = "Ready - Select player and copy", Duration = 8})
