-- Town Plot Copier - SaveInstance Method (Experimental)

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Town Plot Copier - SaveInstance",
    LoadingTitle = "Loading...",
    Theme = "Default"
})

local Tab = Window:CreateTab("Copier", "hammer")

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

local BUILDING_AREAS = Workspace:WaitForChild("Private Building Areas")

local selectedPlayer = nil

local playerOptions = {}

local function refreshPlayers()
    playerOptions = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and BUILDING_AREAS:FindFirstChild(plr.Name .. "BuildArea") then
            table.insert(playerOptions, plr.Name)
        end
    end
end
refreshPlayers()

Tab:CreateSection("SaveInstance Method")
local Dropdown = Tab:CreateDropdown({
    Name = "Select Player to Copy From",
    Options = playerOptions,
    CurrentOption = {},
    MultipleOptions = false,
    Callback = function(Option)
        selectedPlayer = (typeof(Option) == "table" and #Option > 0) and Players:FindFirstChild(Option[1]) or nil
    end,
})

Tab:CreateButton({
    Name = "📥 Save & Load Build (SaveInstance)",
    Description = "Experimental: Save source Build folder and load into your plot",
    Callback = function()
        if not selectedPlayer then
            Rayfield:Notify({Title = "Error", Content = "Select a player first!"})
            return
        end

        local sourceArea = BUILDING_AREAS:FindFirstChild(selectedPlayer.Name .. "BuildArea")
        if not sourceArea then
            Rayfield:Notify({Title = "Error", Content = "Source plot not found"})
            return
        end

        local sourceBuild = sourceArea:WaitForChild("Build")

        Rayfield:Notify({Title = "Saving...", Content = "Saving source build...", Duration = 5})

        -- Save the source Build folder
        local savedBuild = sourceBuild:Clone()
        savedBuild.Name = "SavedBuild_" .. selectedPlayer.Name

        -- Clear any existing saved build
        if Workspace:FindFirstChild("SavedBuild_" .. selectedPlayer.Name) then
            Workspace:FindFirstChild("SavedBuild_" .. selectedPlayer.Name):Destroy()
        end

        savedBuild.Parent = Workspace

        Rayfield:Notify({Title = "Saved", Content = "Source build saved. Now loading into your plot...", Duration = 5})

        -- Load into your plot
        local myArea = BUILDING_AREAS:FindFirstChild(LocalPlayer.Name .. "BuildArea")
        local myBuild = myArea:WaitForChild("Build")

        -- Clear your current build first (optional - comment out if you don't want to clear)
        for _, v in ipairs(myBuild:GetChildren()) do
            v:Destroy()
        end

        -- Clone and parent to your build folder
        local cloned = savedBuild:Clone()
        for _, part in ipairs(cloned:GetChildren()) do
            part.Parent = myBuild
        end
        cloned:Destroy()

        Rayfield:Notify({Title = "Loaded", Content = "Build loaded into your plot using SaveInstance", Duration = 10})

        -- Optional: Try to make parts editable again
        for _, part in ipairs(myBuild:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Anchored = false
            end
        end
    end,
})

Tab:CreateButton({ Name = "Refresh Player List", Callback = function()
    refreshPlayers()
    Dropdown:Refresh(playerOptions)
end })

Rayfield:Notify({Title = "SaveInstance Mode", Content = "This method may not work perfectly with F3X", Duration = 8})
