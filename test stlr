--[[
    Roblox Execution Script
    Description: A multi-step script that performs various actions,
    including remote execution, character manipulation, and a player
    selection GUI with orbiting functionality.
--]]

-- Wait for required services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

-- Local player
local localPlayer = Players.LocalPlayer
local playerName = localPlayer.Name

-- Function to ensure character exists and is loaded
local function waitForCharacter()
    local character = localPlayer.Character
    if not character or character.Parent == nil then
        localPlayer.CharacterAdded:Wait()
    end
    return localPlayer.Character
end

-- Step 1: Fire respawn remote
local function respawn()
    local args = {"/respawn"}
    ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("ControllerRemote"):FireServer(unpack(args))
end

-- Step 2: Buy SkiMask
local function buySkiMask()
    local args = {"SkiMask", 50}
    ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Buy"):FireServer(unpack(args))
end

-- Step 3: Teleport to coordinates
local function teleportTo(x, y, z)
    local character = waitForCharacter()
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if rootPart then
        rootPart.CFrame = CFrame.new(x, y, z)
    end
end

-- Step 4: Hold proximity prompt on scooter
local function holdScooterPrompt()
    local scooter = workspace:WaitForChild("Map"):WaitForChild("Scooters"):FindFirstChild("Scooter1")
    if not scooter then return end
    local prompt = scooter:FindFirstChild("ProximityPrompt") or (scooter:FindFirstChild("Position") and scooter.Position:FindFirstChild("ProximityPrompt"))
    if prompt then
        prompt:InputHoldBegin()
        wait(1)  -- hold for 1 second
        prompt:InputHoldEnd()
    end
end

-- Step 5: Delete wheels of player's car
local function deleteCarWheels()
    local car = workspace:WaitForChild("Vehicles"):FindFirstChild(playerName .. "'s Car")
    if not car then return end
    local wheels = car:FindFirstChild("Wheels")
    if wheels then
        local wheelNames = {"FL", "FR", "RL", "RR"}
        for _, wheelName in ipairs(wheelNames) do
            local wheel = wheels:FindFirstChild(wheelName)
            if wheel then wheel:Destroy() end
        end
    end
end

-- Step 6: Modify weight part (transparency and cancollide)
local function modifyWeight()
    local car = workspace:WaitForChild("Vehicles"):FindFirstChild(playerName .. "'s Car")
    if not car then return end
    local body = car:FindFirstChild("Body")
    if body then
        local weight = body:FindFirstChild("#Weight")
        if weight then
            weight.Transparency = 0.7
            weight.CanCollide = true
        end
    end
end

-- Perform initial actions in sequence
respawn()
wait(1.6)
buySkiMask()
teleportTo(541, 52, -93)
holdScooterPrompt()
wait(2)
deleteCarWheels()
modifyWeight()

-- ------------------------------------------------------------------
-- GUI Creation: Player selection menu with orbit button
-- ------------------------------------------------------------------

