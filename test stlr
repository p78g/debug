Iris.UpdateGlobalConfig(Iris.TemplateConfig.colorDark)

Iris:Connect(function()
    Iris.Window({"Player Orbit Control"}, {size = Iris.State(Vector2.new(360, 520))})
        
        Iris.Text({"Select Target Player:"})
        
        Iris.Tree({"Players List"})
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= localPlayer then
                    local btn = Iris.Button({plr.Name})
