local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local localPlayer = Players.LocalPlayer
local playerName = localPlayer.Name

-- ========== Helper functions ==========
local function waitForCharacter()
    local character = localPlayer.Character
    if not character or character.Parent == nil then
        character = localPlayer.CharacterAdded:Wait()
    end
    return character
end

local function safeFind(instance, path)
    if type(path) == "string" then
        path = path:split(".")
    end
    local current = instance
    for _, part in ipairs(path) do
        if not current then return nil end
        current = current:FindFirstChild(part)
    end
    return current
end

-- ========== Initial actions ==========
local function respawn()
    local args = {"/respawn"}
    ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("ControllerRemote"):FireServer(unpack(args))
end

local function buySkiMask()
    local args = {"SkiMask", 50}
    ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Buy"):FireServer(unpack(args))
end

local function teleportTo(x, y, z)
    local character = waitForCharacter()
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if rootPart then
        rootPart.CFrame = CFrame.new(x, y, z)
    end
end

local function holdScooterPrompt()
    -- Locate the scooter and prompt
    local scooter = safeFind(workspace, {"Map", "Scooters", "Scooter1"})
    if not scooter then
        warn("[Proximity] Scooter not found")
        return
    end

    local prompt = scooter:FindFirstChild("ProximityPrompt")
    if not prompt then
        prompt = safeFind(scooter, {"Position", "ProximityPrompt"})
    end
    if not prompt then
        warn("[Proximity] Proximity prompt not found on scooter")
        return
    end

    -- Get the part that contains the prompt
    local promptParent = prompt.Parent
    local targetPart = promptParent:IsA("BasePart") and promptParent or promptParent:FindFirstChildWhichIsA("BasePart")
    if not targetPart then
        warn("[Proximity] Cannot find a part to move to")
        return
    end

    local character = waitForCharacter()
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    -- Move directly onto the part
    rootPart.CFrame = CFrame.new(targetPart.Position)
    wait(0.2) -- allow physics to settle

    print("[Proximity] Holding prompt for 1 second...")
    prompt:InputHoldBegin()
    wait(1)
    prompt:InputHoldEnd()
    print("[Proximity] Prompt released")
end

local function deleteCarWheels()
    local car = safeFind(workspace, {"Vehicles", playerName .. "'s Car"})
    if not car then return end
    local wheels = car:FindFirstChild("Wheels")
    if wheels then
        local wheelNames = {"FL", "FR", "RL", "RR"}
        for _, name in ipairs(wheelNames) do
            local wheel = wheels:FindFirstChild(name)
            if wheel then wheel:Destroy() end
        end
    end
end

local function modifyWeight()
    local car = safeFind(workspace, {"Vehicles", playerName .. "'s Car"})
    if not car then return end
    local weight = safeFind(car, {"Body", "#Weight"})
    if weight then
        weight.Transparency = 0.7
        weight.CanCollide = true
    end
end

-- Execute initial steps
respawn()
wait(1.6)
buySkiMask()
teleportTo(541, 52, -93)
wait(0.5)   -- delay before prompt
holdScooterPrompt()
wait(2)
deleteCarWheels()
modifyWeight()

-- ========== Orbit logic ==========
local currentTarget = nil
local orbiting = false
local orbitConnection = nil
local selectedPlayerName = nil

local ORBIT_RADIUS = 12
local VERTICAL_OFFSET = -5
local ANGULAR_SPEED = 8

local function stopOrbitAndTeleport()
    if orbitConnection then
        orbitConnection:Disconnect()
        orbitConnection = nil
    end
    if orbiting then
        orbiting = false
        local char = localPlayer.Character
        if char then
            local rootPart = char:FindFirstChild("HumanoidRootPart")
            if rootPart then
                rootPart.CFrame = CFrame.new(rootPart.Position.X, 1000, rootPart.Position.Z)
                wait(0.2)                -- wait 0.2 seconds before anchoring
                rootPart.Anchored = true
            end
        end
    end
end

local function startOrbit(targetPlayer)
    if not targetPlayer then return end
    if orbitConnection then
        orbitConnection:Disconnect()
        orbitConnection = nil
    end

    orbiting = true

    -- Fire combat remote once
    local targetChar = targetPlayer.Character
    if targetChar then
        local humanoid = targetChar:FindFirstChild("Humanoid")
        local head = targetChar:FindFirstChild("Head")
        if humanoid and head then
            ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Combat"):FireServer("Hit", humanoid, head)
        end
    end

    -- Unanchor local player
    local localChar = localPlayer.Character
    if localChar then
        local rootPart = localChar:FindFirstChild("HumanoidRootPart")
        if rootPart then
            rootPart.Anchored = false
        end
    end

    local angle = 0
    local lastUpdate = os.clock()

    orbitConnection = RunService.RenderStepped:Connect(function()
        if not orbiting or not targetPlayer or not targetPlayer.Character then
            stopOrbitAndTeleport()
            return
        end

        local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local localRoot = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not targetRoot or not localRoot then return end

        local now = os.clock()
        local dt = math.min(now - lastUpdate, 0.1)
        lastUpdate = now
        angle = angle + ANGULAR_SPEED * dt

        local offsetX = ORBIT_RADIUS * math.cos(angle)
        local offsetZ = ORBIT_RADIUS * math.sin(angle)
        local targetPos = targetRoot.Position
        local newPos = targetPos + Vector3.new(offsetX, VERTICAL_OFFSET, offsetZ)

        if newPos.Y > targetPos.Y then
            newPos = Vector3.new(newPos.X, targetPos.Y - 0.5, newPos.Z)
        end

        localRoot.CFrame = CFrame.new(newPos)
    end)
end

-- ========== GUI Setup ==========
-- Wait for PlayerGui to exist before creating GUI
local playerGui = localPlayer:WaitForChild("PlayerGui")

-- Try to load Iris
local Iris = nil
local irisPaths = {
    ReplicatedStorage:FindFirstChild("Iris"),
    localPlayer:FindFirstChild("PlayerScripts") and localPlayer.PlayerScripts:FindFirstChild("Iris"),
    game:GetService("StarterPlayer").StarterPlayerScripts:FindFirstChild("Iris"),
    game:GetService("CoreGui"):FindFirstChild("Iris"),
}
for _, irisModule in ipairs(irisPaths) do
    if irisModule then
        local success, result = pcall(require, irisModule)
        if success and result then
            Iris = result.Init()
            break
        end
    end
end

if Iris then
    -- Use Iris GUI
    print("Using Iris GUI")
    Iris:Connect(function()
        local windowOpen = Iris.State(true)
        local windowSize = Iris.State(Vector2.new(300, 450))
        Iris.Window({"Player Orbit"}, {open = windowOpen, size = windowSize})
            Iris.BeginChild({"playerList"}, {size = Vector2.new(0, 300)})
                local players = Players:GetPlayers()
                for _, player in ipairs(players) do
                    if player ~= localPlayer then
                        if Iris.Button({player.Name}).clicked() then
                            selectedPlayerName = player.Name
                            if orbiting then stopOrbitAndTeleport() end
                            currentTarget = player
                            local char = localPlayer.Character
                            if char then
                                local root = char:FindFirstChild("HumanoidRootPart")
                                if root then root.Anchored = false end
                            end
                        end
                        if selectedPlayerName == player.Name then
                            Iris.SameLine()
                            Iris.Text({"[✓]"})
                        end
                    end
                end
            Iris.EndChild()
            if Iris.Button({orbiting and "Stop Orbit" or "Start Orbit"}).clicked() then
                if not currentTarget then
                    print("No target selected")
                else
                    if orbiting then stopOrbitAndTeleport() else startOrbit(currentTarget) end
                end
            end
            if selectedPlayerName then
                Iris.Text({"Selected: " .. selectedPlayerName})
            else
                Iris.Text({"No target selected"})
            end
        Iris.End()
    end)
else
    -- Fallback to a simple, stable ScreenGui (ensuring it is visible)
    print("Iris not found. Using fallback ScreenGui.")
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "PlayerSelectorGUI"
    screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    screenGui.Parent = playerGui

    -- Main frame
    local mainFrame = Instance.new("Frame")
    mainFrame.Size = UDim2.new(0, 300, 0, 450)
    mainFrame.Position = UDim2.new(0, 10, 0, 10)
    mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    mainFrame.BackgroundTransparency = 0.15
    mainFrame.BorderSizePixel = 0
    mainFrame.ClipsDescendants = false
    mainFrame.Parent = screenGui

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 30)
    title.BackgroundTransparency = 1
    title.Text = "Player List"
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.Font = Enum.Font.GothamBold
    title.TextSize = 18
    title.Parent = mainFrame

    local scrollFrame = Instance.new("ScrollingFrame")
    scrollFrame.Size = UDim2.new(1, 0, 1, -80)
    scrollFrame.Position = UDim2.new(0, 0, 0, 30)
    scrollFrame.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    scrollFrame.BackgroundTransparency = 0.5
    scrollFrame.BorderSizePixel = 0
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    scrollFrame.ScrollBarThickness = 8
    scrollFrame.Parent = mainFrame

    local listLayout = Instance.new("UIListLayout")
    listLayout.SortOrder = Enum.SortOrder.Name
    listLayout.Padding = UDim.new(0, 2)
    listLayout.Parent = scrollFrame

    local orbitButton = Instance.new("TextButton")
    orbitButton.Size = UDim2.new(1, -20, 0, 40)
    orbitButton.Position = UDim2.new(0, 10, 1, -50)
    orbitButton.BackgroundColor3 = Color3.fromRGB(0, 120, 200)
    orbitButton.Text = "Start Orbit"
    orbitButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    orbitButton.Font = Enum.Font.GothamBold
    orbitButton.TextSize = 16
    orbitButton.AutoButtonColor = false  -- Prevents hover shrinking
    orbitButton.Parent = mainFrame

    local selectedButton = nil

    local function refreshPlayerList()
        local currentPlayers = {}
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= localPlayer then
                currentPlayers[player.Name] = player
            end
        end

        -- Remove buttons for players that left
        for _, child in ipairs(scrollFrame:GetChildren()) do
            if child:IsA("TextButton") then
                if not currentPlayers[child.Name] then
                    child:Destroy()
                else
                    currentPlayers[child.Name] = nil
                end
            end
        end

        -- Add buttons for new players
        for name, player in pairs(currentPlayers) do
            local button = Instance.new("TextButton")
            button.Name = name
            button.Size = UDim2.new(1, 0, 0, 30)
            button.Text = name
            button.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
            button.TextColor3 = Color3.fromRGB(255, 255, 255)
            button.Font = Enum.Font.Gotham
            button.TextSize = 14
            button.AutoButtonColor = false
            button.Parent = scrollFrame

            button.MouseButton1Click:Connect(function()
                if selectedButton then
                    selectedButton.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
                end
                selectedButton = button
                selectedButton.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
                if orbiting then stopOrbitAndTeleport() end
                currentTarget = player
                selectedPlayerName = player.Name
                local char = localPlayer.Character
                if char then
                    local root = char:FindFirstChild("HumanoidRootPart")
                    if root then root.Anchored = false end
                end
            end)
        end

        -- Update canvas size
        local buttonCount = 0
        for _, child in ipairs(scrollFrame:GetChildren()) do
            if child:IsA("TextButton") then buttonCount = buttonCount + 1 end
        end
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, buttonCount * 32)
    end

    refreshPlayerList()
    Players.PlayerAdded:Connect(refreshPlayerList)
    Players.PlayerRemoving:Connect(refreshPlayerList)

    orbitButton.MouseButton1Click:Connect(function()
        if not currentTarget then
            orbitButton.Text = "Select target first"
            wait(1)
            orbitButton.Text = orbiting and "Stop Orbit" or "Start Orbit"
            return
        end
        if orbiting then
            stopOrbitAndTeleport()
        else
            startOrbit(currentTarget)
        end
    end)

    print("Fallback GUI created. It should now be visible.")
end

-- Initial teleport high and anchor
local function initialTeleport()
    local char = waitForCharacter()
    local root = char:FindFirstChild("HumanoidRootPart")
    if root then
        root.CFrame = CFrame.new(root.Position.X, 1000, root.Position.Z)
        root.Anchored = true
    end
end
initialTeleport()

