local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local localPlayer = Players.LocalPlayer
local playerName = localPlayer.Name

-- ========== Helper functions ==========
local function waitForCharacter()
    local character = localPlayer.Character
    if not character or character.Parent == nil then
        character = localPlayer.CharacterAdded:Wait()
    end
    return character
end

local function safeFind(instance, path)
    if type(path) == "string" then path = path:split(".") end
    local current = instance
    for _, part in ipairs(path) do
        if not current then return nil end
        current = current:FindFirstChild(part)
    end
    return current
end

-- ========== Inventory spam ==========
local function enableInventorySpam()
    local inventoryRemote = safeFind(ReplicatedStorage, {"Remotes", "Inventory"}) or safeFind(ReplicatedStorage, {"Inventory", "Enable"})
    while true do
        task.wait(0.5)
        if inventoryRemote then
            pcall(function()
                inventoryRemote:FireServer("EnableInventory")
            end)
        end
        local humanoid = localPlayer.Character and localPlayer.Character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid:SetAttribute("InventoryEnabled", true)
        end
    end
end
coroutine.wrap(enableInventorySpam)()

-- ========== Initial actions ==========
local function respawn()
    ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("ControllerRemote"):FireServer("/respawn")
end

local function buySkiMask()
    ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Buy"):FireServer("SkiMask", 50)
end

local function teleportTo(x, y, z)
    local root = waitForCharacter():FindFirstChild("HumanoidRootPart")
    if root then root.CFrame = CFrame.new(x, y, z) end
end

local function holdScooterPrompt()
    local scooter = safeFind(workspace, {"Map", "Scooters", "Scooter1"})
    if not scooter then warn("[Scooter] Not found") return end
    
    local prompt = scooter:FindFirstChild("ProximityPrompt") or safeFind(scooter, {"Position", "ProximityPrompt"})
    if not prompt then warn("[Scooter] ProximityPrompt not found") return end
    
    local targetPart = prompt.Parent:IsA("BasePart") and prompt.Parent or prompt.Parent:FindFirstChildWhichIsA("BasePart")
    if not targetPart then warn("[Scooter] No target part") return end
    
    local root = waitForCharacter():FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    root.CFrame = CFrame.new(targetPart.Position + Vector3.new(0, 3, 0)) -- slightly above
    task.wait(0.3)
    
    print("[Scooter] Holding prompt...")
    prompt:InputHoldBegin()
    task.wait(1)
    prompt:InputHoldEnd()
    print("[Scooter] Prompt released")
end

local function deleteCarWheels()
    local car = safeFind(workspace, {"Vehicles", playerName .. "'s Car"})
    if not car then return end
    local wheels = car:FindFirstChild("Wheels")
    if wheels then
        for _, name in {"FL", "FR", "RL", "RR"} do
            local wheel = wheels:FindFirstChild(name)
            if wheel then wheel:Destroy() end
        end
    end
end

local function modifyWeight()
    local car = safeFind(workspace, {"Vehicles", playerName .. "'s Car"})
    if not car then return end
    local weight = safeFind(car, {"Body", "#Weight"})
    if weight then
        weight.Transparency = 0.7
        weight.CanCollide = true
    end
end

-- ========== Orbit logic (unchanged) ==========
local currentTarget = nil
local orbiting = false
local orbitConnection = nil
local selectedPlayerName = nil

local ORBIT_RADIUS = 12
local VERTICAL_OFFSET = -5
local ANGULAR_SPEED = 8

local function stopOrbitAndTeleport()
    if orbitConnection then
        orbitConnection:Disconnect()
        orbitConnection = nil
    end
    orbiting = false
    local root = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
    if root then
        root.CFrame = CFrame.new(root.Position.X, 1000, root.Position.Z)
        task.wait(0.2)
        root.Anchored = true
    end
end

local function startOrbit(targetPlayer)
    if not targetPlayer then return end
    if orbitConnection then orbitConnection:Disconnect() end
    
    orbiting = true
    selectedPlayerName = targetPlayer.Name
    currentTarget = targetPlayer
    
    -- Initial hit
    local tChar = targetPlayer.Character
    if tChar then
        local hum = tChar:FindFirstChild("Humanoid")
        local head = tChar:FindFirstChild("Head")
        if hum and head then
            ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Combat"):FireServer("Hit", hum, head)
        end
    end
    
    local lRoot = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
    if lRoot then lRoot.Anchored = false end
    
    local angle = 0
    local lastUpdate = os.clock()
    
    orbitConnection = RunService.RenderStepped:Connect(function()
        if not orbiting or not targetPlayer.Character then
            stopOrbitAndTeleport()
            return
        end
        local tRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local lRoot = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not tRoot or not lRoot then return end
        
        local dt = math.min(os.clock() - lastUpdate, 0.1)
        lastUpdate = os.clock()
        angle += ANGULAR_SPEED * dt
        
        local offset = Vector3.new(ORBIT_RADIUS * math.cos(angle), VERTICAL_OFFSET, ORBIT_RADIUS * math.sin(angle))
        local newPos = tRoot.Position + offset
        if newPos.Y > tRoot.Position.Y then
            newPos = Vector3.new(newPos.X, tRoot.Position.Y - 0.5, newPos.Z)
        end
        lRoot.CFrame = CFrame.new(newPos)
    end)
end

-- ========== Iris GUI (Fixed) ==========
local Iris = loadstring(game:HttpGet("https://raw.githubusercontent.com/x0581/Iris-Exploit-Bundle/main/bundle.lua"))().Init(game.CoreGui)

Iris.UpdateGlobalConfig(Iris.TemplateConfig.colorDark)

Iris:Connect(function()
    Iris.Window({"Player Orbit Control"}, {size = Iris.State(Vector2.new(340, 520))})
        
        -- Player List
        Iris.Text({"Select a player:"})
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= localPlayer then
                local clicked = Iris.Button({player.Name}).clicked
                if clicked then
                    if orbiting then stopOrbitAndTeleport() end
                    currentTarget = player
                    selectedPlayerName = player.Name
                    local root = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if root then root.Anchored = false end
                end
                
                if selectedPlayerName == player.Name then
                    Iris.SameLine()
                    Iris.Text({" ✓ Selected"})
                end
            end
        end
        
        Iris.Separator()
        
        -- Orbit Control
        local btnText = orbiting and "Stop Orbit" or "Start Orbit"
        if Iris.Button({btnText}).clicked then
            if not currentTarget then
                print("No target selected!")
            elseif orbiting then
                stopOrbitAndTeleport()
            else
                startOrbit(currentTarget)
            end
        end
        
        if Iris.Button({"Refresh Player List"}).clicked then
            -- Just forces re-render
        end
        
        -- Status
        Iris.Text({"Selected: " .. (selectedPlayerName or "None")})
        if orbiting then
            Iris.Text({"Status: Orbiting active"})
        end
        Iris.Text({"Inventory spam: Active"})
        
    Iris.End()
end)

