    local remotesFolder = ReplicatedStorage:FindFirstChild("Remotes") or ReplicatedStorage
    local possibleRemotes = {
        safeFind(remotesFolder, "Inventory"),
        safeFind(remotesFolder, {"Inventory", "Enable"}),
        safeFind(remotesFolder, "ToggleInventory"),
        safeFind(ReplicatedStorage, {"Inventory", "Remote"}),
        safeFind(ReplicatedStorage, "EnableInventory")
    }

    while true do
        task.wait(0.1)  -- Much faster spam

        for _, remote in ipairs(possibleRemotes) do
            if remote and (remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction")) then
                pcall(function()
                    remote:FireServer("EnableInventory")
                    remote:FireServer(true)
                    remote:FireServer("Enable")
                end)
            end
        end

        -- Direct attribute / property spam on Humanoid and Player
        local character = localPlayer.Character
        if character then
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid then
                humanoid:SetAttribute("InventoryEnabled", true)
                humanoid:SetAttribute("CanOpenInventory", true)
                pcall(function() humanoid:FindFirstChild("InventoryEnabled").Value = true end)
            end
        end

        -- Also try on LocalPlayer
        pcall(function()
            localPlayer:SetAttribute("InventoryEnabled", true)
        end)
    end
end

