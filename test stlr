-- ========== Orbit logic ==========
local currentTarget = nil
local orbiting = false
local orbitConnection = nil
local selectedPlayerName = nil
local ORBIT_RADIUS = 12
local VERTICAL_OFFSET = -5
local ANGULAR_SPEED = 8

local function stopOrbitAndTeleport()
    if orbitConnection then
        orbitConnection:Disconnect()
        orbitConnection = nil
    end
    if orbiting then
        orbiting = false
        local char = localPlayer.Character
        if char then
            local rootPart = char:FindFirstChild("HumanoidRootPart")
            if rootPart then
                rootPart.CFrame = CFrame.new(rootPart.Position.X, 1000, rootPart.Position.Z)
                wait(0.2)
                rootPart.Anchored = true
            end
        end
    end
end

local function startOrbit(targetPlayer)
    if not targetPlayer then return end
    if orbitConnection then
        orbitConnection:Disconnect()
        orbitConnection = nil
    end
    orbiting = true
    -- Fire combat remote once
    local targetChar = targetPlayer.Character
    if targetChar then
        local humanoid = targetChar:FindFirstChild("Humanoid")
        local head = targetChar:FindFirstChild("Head")
        if humanoid and head then
            ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Combat"):FireServer("Hit", humanoid, head)
        end
    end
    -- Unanchor local player
    local localChar = localPlayer.Character
    if localChar then
        local rootPart = localChar:FindFirstChild("HumanoidRootPart")
        if rootPart then
            rootPart.Anchored = false
        end
    end
    local angle = 0
    local lastUpdate = os.clock()
    orbitConnection = RunService.RenderStepped:Connect(function()
        if not orbiting or not targetPlayer or not targetPlayer.Character then
            stopOrbitAndTeleport()
            return
        end
        local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local localRoot = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not targetRoot or not localRoot then return end
        local now = os.clock()
        local dt = math.min(now - lastUpdate, 0.1)
        lastUpdate = now
        angle = angle + ANGULAR_SPEED * dt
        local offsetX = ORBIT_RADIUS * math.cos(angle)
        local offsetZ = ORBIT_RADIUS * math.sin(angle)
        local targetPos = targetRoot.Position
        local newPos = targetPos + Vector3.new(offsetX, VERTICAL_OFFSET, offsetZ)
        if newPos.Y > targetPos.Y then
            newPos = Vector3.new(newPos.X, targetPos.Y - 0.5, newPos.Z)
        end
        localRoot.CFrame = CFrame.new(newPos)
    end)
end

