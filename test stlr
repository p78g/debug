-- Orbit button
local orbitButton = Instance.new("TextButton")
orbitButton.Size = UDim2.new(1, -20, 0, 40)
orbitButton.Position = UDim2.new(0, 10, 1, -50)
orbitButton.BackgroundColor3 = Color3.fromRGB(0, 120, 200)
orbitButton.Text = "Start Orbit"
orbitButton.TextColor3 = Color3.fromRGB(255, 255, 255)
orbitButton.Font = Enum.Font.GothamBold
orbitButton.TextSize = 16
orbitButton.Parent = mainFrame

-- Variables for orbiting
local currentTarget = nil
local orbiting = false
local orbitConnection = nil

-- Function to stop orbit (if active) and teleport high & anchor
local function stopOrbitAndTeleport()
    if orbitConnection then
        orbitConnection:Disconnect()
        orbitConnection = nil
    end
    if orbiting then
        orbiting = false
        orbitButton.Text = "Start Orbit"
        -- Teleport local player high up and anchor
        local character = localPlayer.Character
        if character then
            local rootPart = character:FindFirstChild("HumanoidRootPart")
            if rootPart then
                rootPart.CFrame = CFrame.new(rootPart.Position.X, 1000, rootPart.Position.Z)
                rootPart.Anchored = true
            end
        end
    end
end

-- Function to start orbiting a target
local function startOrbit(targetPlayer)
    if not targetPlayer then return end
    if orbitConnection then
        orbitConnection:Disconnect()
        orbitConnection = nil
    end
    
    orbiting = true
    orbitButton.Text = "Stop Orbit"
    
    -- Fire combat remote once
    local targetCharacter = targetPlayer.Character
    if targetCharacter then
        local humanoid = targetCharacter:FindFirstChild("Humanoid")
        local head = targetCharacter:FindFirstChild("Head")
        if humanoid and head then
            local args = {"Hit", humanoid, head}
            ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Combat"):FireServer(unpack(args))
        end
    end
    
    -- Unanchor local player
    local localChar = localPlayer.Character
    if localChar then
        local rootPart = localChar:FindFirstChild("HumanoidRootPart")
        if rootPart then
            rootPart.Anchored = false
        end
    end
    
    -- Orbit loop (updates every frame)
    orbitConnection = RunService.RenderStepped:Connect(function()
        if not orbiting or not targetPlayer or not targetPlayer.Character then
            -- Stop orbiting if conditions fail
            if orbiting then
                stopOrbitAndTeleport()
            end
            return
        end
        
        local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local localRoot = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not targetRoot or not localRoot then return end
        
        -- Random hemisphere below target: angles: vertical from -pi/2 to 0, horizontal from 0 to 2pi
        local radius = 12
        local vertAngle = math.rad(math.random(-90, 0))  -- -90 to 0 degrees
        local horzAngle = math.rad(math.random(0, 360))
        
        -- Compute offset vector
        local offsetX = radius * math.cos(vertAngle) * math.cos(horzAngle)
        local offsetY = radius * math.sin(vertAngle)  -- always <= 0
        local offsetZ = radius * math.cos(vertAngle) * math.sin(horzAngle)
        
        -- Apply offset to target's position
        local newPos = targetRoot.Position + Vector3.new(offsetX, offsetY, offsetZ)
        localRoot.CFrame = CFrame.new(newPos)
    end)
end

-- Function to update player list UI
local function updatePlayerList()
    -- Clear existing buttons (except maybe keep a reference)
    for _, child in ipairs(scrollFrame:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    -- Add a button for each player
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= localPlayer then
            local button = Instance.new("TextButton")
            button.Size = UDim2.new(1, 0, 0, 30)
            button.Text = player.Name
            button.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
            button.TextColor3 = Color3.fromRGB(255, 255, 255)
            button.Font = Enum.Font.Gotham
            button.TextSize = 14
            button.Parent = scrollFrame
            
            button.MouseButton1Click:Connect(function()
                -- Select new target: stop current orbit, teleport high, then set new target
                if orbiting then
                    stopOrbitAndTeleport()
                end
                currentTarget = player
                -- Unanchor after teleport (the stopOrbitAndTeleport anchors, so unanchor when new target is selected)
                local char = localPlayer.Character
                if char then
                    local root = char:FindFirstChild("HumanoidRootPart")
                    if root then root.Anchored = false end
                end
                -- Optionally show a temporary selection feedback
                button.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
                wait(0.2)
                button.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
            end)
        end
    end
    
    -- Update canvas size
    local childrenCount = #scrollFrame:GetChildren()
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, childrenCount * 32)
end

-- Initial population
updatePlayerList()

-- Listen for new players
Players.PlayerAdded:Connect(function()
    updatePlayerList()
end)
Players.PlayerRemoving:Connect(function()
    updatePlayerList()
end)

-- Orbit button click handler
orbitButton.MouseButton1Click:Connect(function()
    if not currentTarget then
        -- No target selected, maybe show a hint
        orbitButton.Text = "Select a target first"
        wait(1)
        orbitButton.Text = orbiting and "Stop Orbit" or "Start Orbit"
        return
    end
    
    if orbiting then
        -- Stop orbiting
        stopOrbitAndTeleport()
    else
        -- Start orbiting the current target
        startOrbit(currentTarget)
    end
end)

-- Optional: initial teleport to set up anchored state (if desired)
local function initialTeleportHigh()
    local character = waitForCharacter()
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if rootPart then
        rootPart.CFrame = CFrame.new(rootPart.Position.X, 1000, rootPart.Position.Z)
        rootPart.Anchored = true
    end
end
initialTeleportHigh()

