-- Orbit variables
local currentTarget = nil
local orbiting = false
local orbitConnection = nil
local selectedButton = nil

-- Function to stop orbit and teleport high + anchor
local function stopOrbitAndTeleport()
    if orbitConnection then
        orbitConnection:Disconnect()
        orbitConnection = nil
    end
    if orbiting then
        orbiting = false
        orbitButton.Text = "Start Orbit"
        local char = localPlayer.Character
        if char then
            local rootPart = char:FindFirstChild("HumanoidRootPart")
            if rootPart then
                rootPart.CFrame = CFrame.new(rootPart.Position.X, 1000, rootPart.Position.Z)
                rootPart.Anchored = true
            end
        end
    end
end

-- Function to start orbiting a target (smooth circle at high speed, always below)
local function startOrbit(targetPlayer)
    if not targetPlayer then return end
    if orbitConnection then
        orbitConnection:Disconnect()
        orbitConnection = nil
    end
    
    orbiting = true
    orbitButton.Text = "Stop Orbit"
    
    -- Fire combat remote once
    local targetChar = targetPlayer.Character
    if targetChar then
        local humanoid = targetChar:FindFirstChild("Humanoid")
        local head = targetChar:FindFirstChild("Head")
        if humanoid and head then
            ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Combat"):FireServer("Hit", humanoid, head)
        end
    end
    
    -- Unanchor local player
    local localChar = localPlayer.Character
    if localChar then
        local rootPart = localChar:FindFirstChild("HumanoidRootPart")
        if rootPart then
            rootPart.Anchored = false
        end
    end
    
    -- Orbit parameters
    local radius = 12
    local verticalOffset = -5  -- always below target's feet
    local angularSpeed = 8     -- radians per second (fast)
    local angle = 0
    local lastUpdate = os.clock()
    
    -- Update loop
    orbitConnection = RunService.RenderStepped:Connect(function()
        if not orbiting or not targetPlayer or not targetPlayer.Character then
            stopOrbitAndTeleport()
            return
        end
        
        local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local localRoot = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not targetRoot or not localRoot then return end
        
        -- Update angle based on time delta
        local now = os.clock()
        local dt = math.min(now - lastUpdate, 0.1)
        lastUpdate = now
        angle = angle + angularSpeed * dt
        
        -- Compute circular position around target, staying below
        local offsetX = radius * math.cos(angle)
        local offsetZ = radius * math.sin(angle)
        local targetPos = targetRoot.Position
        local newPos = targetPos + Vector3.new(offsetX, verticalOffset, offsetZ)
        
        -- Ensure local player is not above target (just in case)
        if newPos.Y > targetPos.Y then
            newPos = Vector3.new(newPos.X, targetPos.Y - 0.5, newPos.Z)
        end
        
        localRoot.CFrame = CFrame.new(newPos)
    end)
end

-- Function to rebuild the player list (without destroying everything)
local function refreshPlayerList()
    -- Gather current player names
    local currentPlayers = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= localPlayer then
            currentPlayers[player.Name] = player
        end
    end
    
    -- Remove buttons for players that left
    for _, child in ipairs(scrollFrame:GetChildren()) do
        if child:IsA("TextButton") then
            if not currentPlayers[child.Name] then
                child:Destroy()
            else
                currentPlayers[child.Name] = nil -- mark as kept
            end
        end
    end
    
    -- Add buttons for new players
    for name, player in pairs(currentPlayers) do
        local button = Instance.new("TextButton")
        button.Name = name
        button.Size = UDim2.new(1, 0, 0, 30)
        button.Text = name
        button.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
        button.TextColor3 = Color3.fromRGB(255, 255, 255)
        button.Font = Enum.Font.Gotham
        button.TextSize = 14
        button.Parent = scrollFrame
        
        button.MouseButton1Click:Connect(function()
            -- Update selection highlight
            if selectedButton then
                selectedButton.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
            end
            selectedButton = button
            selectedButton.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
            
            -- Stop current orbit if active
            if orbiting then
                stopOrbitAndTeleport()
            end
            currentTarget = player
            -- Unanchor (since stopOrbitAndTeleport anchored, we need to unanchor)
            local char = localPlayer.Character
            if char then
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then root.Anchored = false end
            end
        end)
    end
    
    -- Update canvas size
    local children = scrollFrame:GetChildren()
    local buttonCount = 0
    for _, child in ipairs(children) do
        if child:IsA("TextButton") then buttonCount = buttonCount + 1 end
    end
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, buttonCount * 32)
end

-- Initial refresh
refreshPlayerList()

-- Watch for player joins/leaves
Players.PlayerAdded:Connect(refreshPlayerList)
Players.PlayerRemoving:Connect(refreshPlayerList)

-- Orbit button click
orbitButton.MouseButton1Click:Connect(function()
    if not currentTarget then
        orbitButton.Text = "Select a target first"
        wait(1)
        orbitButton.Text = orbiting and "Stop Orbit" or "Start Orbit"
        return
    end
    
    if orbiting then
        stopOrbitAndTeleport()
    else
        startOrbit(currentTarget)
    end
end)

