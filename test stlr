--[[
    Full Execution Script with Iris GUI
    - Performs initial actions (respawn, buy, teleport, prompt, car mods)
    - Opens an Iris window to select target and orbit
    - Orbit stays below target at 12 stud radius, high speed
    - Stops orbiting → teleports high → wait 0.2s → anchor
--]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local localPlayer = Players.LocalPlayer
local playerName = localPlayer.Name

-- ========== Helper functions ==========
local function waitForCharacter()
    local character = localPlayer.Character
    if not character or character.Parent == nil then
        character = localPlayer.CharacterAdded:Wait()
    end
    return character
end

local function safeFind(instance, path)
    if type(path) == "string" then
        path = path:split(".")
    end
    local current = instance
    for _, part in ipairs(path) do
        if not current then return nil end
        current = current:FindFirstChild(part)
    end
    return current
end

-- ========== Initial actions ==========
local function respawn()
    local args = {"/respawn"}
    ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("ControllerRemote"):FireServer(unpack(args))
end

local function buySkiMask()
    local args = {"SkiMask", 50}
    ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Buy"):FireServer(unpack(args))
end

local function teleportTo(x, y, z)
    local character = waitForCharacter()
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if rootPart then
        rootPart.CFrame = CFrame.new(x, y, z)
    end
end

local function holdScooterPrompt()
    local scooter = safeFind(workspace, {"Map", "Scooters", "Scooter1"})
    if not scooter then
        warn("Scooter not found")
        return
    end

    local prompt = scooter:FindFirstChild("ProximityPrompt")
    if not prompt then
        prompt = safeFind(scooter, {"Position", "ProximityPrompt"})
    end
    if not prompt then
        warn("Proximity prompt not found on scooter")
        return
    end

    local character = waitForCharacter()
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    local promptParent = prompt.Parent
    local targetPosition = promptParent:IsA("BasePart") and promptParent.Position or promptParent:FindFirstChildWhichIsA("BasePart").Position

    rootPart.CFrame = CFrame.new(targetPosition)
    wait(0.1)

    prompt:InputHoldBegin()
    wait(1)
    prompt:InputHoldEnd()
end

local function deleteCarWheels()
    local car = safeFind(workspace, {"Vehicles", playerName .. "'s Car"})
    if not car then return end
    local wheels = car:FindFirstChild("Wheels")
    if wheels then
        local wheelNames = {"FL", "FR", "RL", "RR"}
        for _, name in ipairs(wheelNames) do
            local wheel = wheels:FindFirstChild(name)
            if wheel then wheel:Destroy() end
        end
    end
end

local function modifyWeight()
    local car = safeFind(workspace, {"Vehicles", playerName .. "'s Car"})
    if not car then return end
    local weight = safeFind(car, {"Body", "#Weight"})
    if weight then
        weight.Transparency = 0.7
        weight.CanCollide = true
    end
end

-- Execute initial steps with added 0.5s delay before scooter prompt
respawn()
wait(1.6)
buySkiMask()
teleportTo(541, 52, -93)
wait(0.5)                      -- <-- added delay
holdScooterPrompt()
wait(2)
deleteCarWheels()
modifyWeight()

-- ========== Iris GUI Setup ==========
local Iris = nil
-- Try to find Iris in common locations
local irisPaths = {
    ReplicatedStorage:FindFirstChild("Iris"),
    localPlayer:FindFirstChild("PlayerScripts") and localPlayer.PlayerScripts:FindFirstChild("Iris"),
    game:GetService("StarterPlayer").StarterPlayerScripts:FindFirstChild("Iris"),
    game:GetService("CoreGui"):FindFirstChild("Iris"),
}
for _, irisModule in ipairs(irisPaths) do
    if irisModule then
        Iris = require(irisModule).Init()
        break
    end
end

if not Iris then
    error("Iris not found. Please install Iris (e.g., in ReplicatedStorage) and try again.")
end

-- Orbit state variables
local currentTarget = nil
local orbiting = false
local orbitConnection = nil
local selectedPlayerName = nil

-- Orbit parameters
local ORBIT_RADIUS = 12
local VERTICAL_OFFSET = -5      -- always below target
local ANGULAR_SPEED = 8          -- radians per second

-- Function to stop orbit, teleport high, wait 0.2s, then anchor
local function stopOrbitAndTeleport()
    if orbitConnection then
        orbitConnection:Disconnect()
        orbitConnection = nil
    end
    if orbiting then
        orbiting = false
        local char = localPlayer.Character
        if char then
            local rootPart = char:FindFirstChild("HumanoidRootPart")
            if rootPart then
                rootPart.CFrame = CFrame.new(rootPart.Position.X, 1000, rootPart.Position.Z)
                wait(0.2)                -- <-- wait 0.2 seconds
                rootPart.Anchored = true
            end
        end
    end
end

-- Start orbiting a target
local function startOrbit(targetPlayer)
    if not targetPlayer then return end
    if orbitConnection then
        orbitConnection:Disconnect()
        orbitConnection = nil
    end

    orbiting = true

    -- Fire combat remote once
    local targetChar = targetPlayer.Character
    if targetChar then
        local humanoid = targetChar:FindFirstChild("Humanoid")
        local head = targetChar:FindFirstChild("Head")
        if humanoid and head then
            ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Combat"):FireServer("Hit", humanoid, head)
        end
    end

    -- Unanchor local player (in case they were anchored)
    local localChar = localPlayer.Character
    if localChar then
        local rootPart = localChar:FindFirstChild("HumanoidRootPart")
        if rootPart then
            rootPart.Anchored = false
        end
    end

    -- Orbit loop (updates every frame)
    local angle = 0
    local lastUpdate = os.clock()

    orbitConnection = RunService.RenderStepped:Connect(function()
        if not orbiting or not targetPlayer or not targetPlayer.Character then
            stopOrbitAndTeleport()
            return
        end

        local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local localRoot = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not targetRoot or not localRoot then return end

        -- Update angle based on time
        local now = os.clock()
        local dt = math.min(now - lastUpdate, 0.1)
        lastUpdate = now
        angle = angle + ANGULAR_SPEED * dt

        -- Compute circular position below target
        local offsetX = ORBIT_RADIUS * math.cos(angle)
        local offsetZ = ORBIT_RADIUS * math.sin(angle)
        local targetPos = targetRoot.Position
        local newPos = targetPos + Vector3.new(offsetX, VERTICAL_OFFSET, offsetZ)

        -- Safety: never go above target
        if newPos.Y > targetPos.Y then
            newPos = Vector3.new(newPos.X, targetPos.Y - 0.5, newPos.Z)
        end

        localRoot.CFrame = CFrame.new(newPos)
    end)
end

-- Iris UI
Iris:Connect(function()
    -- Main window
    local windowOpen = Iris.State(true)
    local windowSize = Iris.State(Vector2.new(300, 450))
    Iris.Window({"Player Orbit"}, {open = windowOpen, size = windowSize})

        -- Scrolling list of players
        Iris.BeginChild({"playerList"}, {size = Vector2.new(0, 300)})

            local players = Players:GetPlayers()
            for _, player in ipairs(players) do
                if player ~= localPlayer then
                    -- Button for each player
                    local clicked = Iris.Button({player.Name}).clicked()
                    if clicked then
                        selectedPlayerName = player.Name
                        -- Stop any current orbit
                        if orbiting then
                            stopOrbitAndTeleport()
                        end
                        currentTarget = player
                        -- Unanchor local player after teleport
                        local char = localPlayer.Character
                        if char then
                            local root = char:FindFirstChild("HumanoidRootPart")
                            if root then
                                root.Anchored = false
                            end
                        end
                    end
                    -- Highlight selected player
                    if selectedPlayerName == player.Name then
                        -- Iris doesn't have direct highlight; we can use same line color change if needed
                        -- but a simple visual marker can be added with SameLine + Text, but we'll keep simple
                    end
                end
            end

        Iris.EndChild() -- end player list

        -- Orbit button (separate)
        local orbitButtonText = orbiting and "Stop Orbit" or "Start Orbit"
        if Iris.Button({orbitButtonText}).clicked() then
            if not currentTarget then
                -- Show temporary message that no target selected
                print("No target selected")
            else
                if orbiting then
                    stopOrbitAndTeleport()
                else
                    startOrbit(currentTarget)
                end
            end
        end

        -- Optional: show currently selected target
        if selectedPlayerName then
            Iris.Text({"Selected: " .. selectedPlayerName})
        else
            Iris.Text({"No target selected"})
        end

    Iris.End() -- end window
end)

-- Initial teleport high and anchor (start anchored)
local function initialTeleport()
    local char = waitForCharacter()
    local root = char:FindFirstChild("HumanoidRootPart")
    if root then
        root.CFrame = CFrame.new(root.Position.X, 1000, root.Position.Z)
        root.Anchored = true
    end
end
initialTeleport()

print("Script loaded with Iris GUI. Select a player from the list and click Start Orbit.")
