DropdownObject = CopySection:CreateDropdown({
    Name = "Select Player Build",
    Options = options,
    CurrentOption = options[1] or "",
    Callback = function(option)
        selectedPlayer = option
        print("[Build Copier] Selected:", option)
    end
})
if options[1] then selectedPlayer = options[1] end

-- Create copy button
CopySection:CreateButton({
    Name = "Copy Build",
    Callback = function()
        if selectedPlayer and selectedPlayer ~= "" then
            copyBuild(selectedPlayer)
        else
            Rayfield:Notify({Title = "Error", Content = "Select a player first!", Duration = 3})
        end
    end
})

-- Create refresh button
CopySection:CreateButton({
    Name = "Refresh Player List",
    Callback = function()
        refreshDropdown()
        Rayfield:Notify({Title = "Refreshed", Content = "Player list updated.", Duration = 2})
    end
})

