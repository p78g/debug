-- =============================================
-- BUILD COPIER – Perfect Copy Using Ghost Method
-- Live sliders, direct cloning (no remote issues)
-- =============================================

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Build Copier",
    ConfigurationSaving = { Enabled = true, FolderName = "BuildCopier" },
    Theme = "Default",
})

local MainTab = Window:CreateTab("Copy Build")
MainTab:CreateSection("Alignment Offsets (studs)")

local xOffset = 0
local zOffset = 0
local yExtra = 0

MainTab:CreateSlider({ Name = "X Offset (left/right)", Range = {-100, 100}, Increment = 1, CurrentValue = 0, Callback = function(v) xOffset = v end })
MainTab:CreateSlider({ Name = "Z Offset (forward/back)", Range = {-100, 100}, Increment = 1, CurrentValue = 0, Callback = function(v) zOffset = v end })
MainTab:CreateSlider({ Name = "Extra Y Offset (up/down)", Range = {-10, 10}, Increment = 0.5, CurrentValue = 0, Callback = function(v) yExtra = v end })

MainTab:CreateSection("Player Selection")

local selectedPlayer = nil
local playerMapping = {}
local dropdown = nil

local function getBuildArea(folderName)
    local pa = workspace:FindFirstChild("Private Building Areas")
    return pa and pa:FindFirstChild(folderName)
end

local function refreshPlayers()
    local pa = workspace:FindFirstChild("Private Building Areas")
    if not pa then return {} end
    local opts = {}
    playerMapping = {}
    for _, c in ipairs(pa:GetChildren()) do
        local name = c.Name
        if name:sub(-9) == "BuildArea" then
            local pn = name:sub(1, -10)
            table.insert(opts, pn)
            playerMapping[pn] = name
        end
    end
    return opts
end

-- Clear your local Build folder
local function clearLocalBuild()
    local localName = game.Players.LocalPlayer.Name .. "BuildArea"
    local localBA = getBuildArea(localName)
    if localBA and localBA:FindFirstChild("Build") then
        for _, p in ipairs(localBA.Build:GetChildren()) do p:Destroy() end
        Rayfield:Notify({ Title = "Cleared", Content = "Your build folder emptied." })
    end
end

-- Compute average centre of all parts in source Build (recursive)
local function computeCentre(buildArea)
    local buildFolder = buildArea:FindFirstChild("Build")
    if not buildFolder then return buildArea.Position end
    local parts = {}
    local function collect(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then
                table.insert(parts, child)
            elseif child:IsA("Model") then
                collect(child)
            end
        end
    end
    collect(buildFolder)
    if #parts == 0 then return buildArea.Position end
    local sum = Vector3.new(0,0,0)
    for _, p in ipairs(parts) do sum = sum + p.Position end
    return sum / #parts
end

-- Ghost preview (live with sliders – updates when you re-show)
local ghostModel = nil
local function updateGhost()
    if ghostModel then ghostModel:Destroy() end
    if not selectedPlayer then
        Rayfield:Notify({ Title = "Error", Content = "Select a player first." })
        return
    end
    local srcFolder = playerMapping[selectedPlayer]
    local srcBA = getBuildArea(srcFolder)
    local dstBA = getBuildArea(game.Players.LocalPlayer.Name .. "BuildArea")
    if not srcBA or not dstBA then
        Rayfield:Notify({ Title = "Error", Content = "BuildAreas not found." })
        return
    end
    local srcBuild = srcBA:FindFirstChild("Build")
    if not srcBuild then
        Rayfield:Notify({ Title = "Error", Content = "Source has no Build folder." })
        return
    end

    local srcCentre = computeCentre(srcBA)
    local baseY = 3 + yExtra
    local srcOrigin = srcCentre + Vector3.new(0, baseY, 0)
    local dstOrigin = dstBA.Position + Vector3.new(xOffset, baseY, zOffset)

    ghostModel = Instance.new("Model")
    ghostModel.Name = "BuildGhost"

    local function cloneParts(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then
                local offset = child.Position - srcOrigin
                local targetPos = dstOrigin + offset
                local clone = child:Clone()
                clone.Position = targetPos
                clone.CFrame = CFrame.new(targetPos) * (child.CFrame - child.CFrame.Position)
                clone.Anchored = true
                clone.CanCollide = false
                clone.Transparency = 0.7
                clone.Material = Enum.Material.ForceField
                clone.Parent = ghostModel
            elseif child:IsA("Model") then
                cloneParts(child)
            end
        end
    end
    cloneParts(srcBuild)
    ghostModel.Parent = workspace
    Rayfield:Notify({ Title = "Ghost Updated", Content = "Use sliders to adjust." })
end

local function hideGhost()
    if ghostModel then ghostModel:Destroy() end
end

-- Direct copy (same as ghost, but places unanchored parts into your Build folder)
local function copyAsDirect()
    if not selectedPlayer then
        Rayfield:Notify({ Title = "Error", Content = "Select a player first." })
        return
    end
    hideGhost()
    clearLocalBuild()
    task.wait(0.5)

    local srcFolder = playerMapping[selectedPlayer]
    local srcBA = getBuildArea(srcFolder)
    local dstBA = getBuildArea(game.Players.LocalPlayer.Name .. "BuildArea")
    if not srcBA or not dstBA then
        Rayfield:Notify({ Title = "Error", Content = "BuildAreas missing." })
        return
    end
    local srcBuild = srcBA:FindFirstChild("Build")
    local dstBuild = dstBA:FindFirstChild("Build")
    if not srcBuild or not dstBuild then
        Rayfield:Notify({ Title = "Error", Content = "Build folders missing." })
        return
    end

    local srcCentre = computeCentre(srcBA)
    local baseY = 3 + yExtra
    local srcOrigin = srcCentre + Vector3.new(0, baseY, 0)
    local dstOrigin = dstBA.Position + Vector3.new(xOffset, baseY, zOffset)

    local allParts = {}
    local function collect(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then
                table.insert(allParts, child)
            elseif child:IsA("Model") then
                collect(child)
            end
        end
    end
    collect(srcBuild)
    if #allParts == 0 then
        Rayfield:Notify({ Title = "Info", Content = "No parts found." })
        return
    end

    Rayfield:Notify({ Title = "Copying", Content = #allParts .. " parts..." })
    local success = 0
    for _, part in ipairs(allParts) do
        local offset = part.Position - srcOrigin
        local targetPos = dstOrigin + offset
        local clone = part:Clone()
        clone.Position = targetPos
        clone.CFrame = CFrame.new(targetPos) * (part.CFrame - part.CFrame.Position)
        clone.Anchored = false  -- let them be movable
        clone.CanCollide = true
        clone.Transparency = 0
        clone.Parent = dstBuild
        success = success + 1
        task.wait(0.02)
    end
    Rayfield:Notify({ Title = "Done", Content = success .. "/" .. #allParts .. " parts placed." })
end

-- Build UI
local initOpts = refreshPlayers()
dropdown = MainTab:CreateDropdown({
    Name = "Select Player",
    Options = initOpts,
    CurrentOption = initOpts[1] or "",
    Callback = function(opt) selectedPlayer = opt end
})
if initOpts[1] then selectedPlayer = initOpts[1] end

MainTab:CreateButton({ Name = "Clear Your Build", Callback = clearLocalBuild })
MainTab:CreateButton({ Name = "Show Ghost Preview", Callback = updateGhost })
MainTab:CreateButton({ Name = "Hide Ghost", Callback = hideGhost })
MainTab:CreateButton({ Name = "Copy as Direct Clones (Perfect)", Callback = copyAsDirect })
MainTab:CreateButton({ Name = "Refresh Players", Callback = function()
    local newOpts = refreshPlayers()
    dropdown:SetOptions(newOpts)
    if newOpts[1] then dropdown:SetValue(newOpts[1]); selectedPlayer = newOpts[1] end
end })

Rayfield:Notify({ Title = "Ready", Content = "Adjust sliders, show ghost, then use 'Copy as Direct Clones'." })
