
-- Town Build Copier - Fixed Stable Version (Rotation + Resize Fixed)

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Town Copier - Fixed Stable",
    LoadingTitle = "Loading...",
    Theme = "Default"
})

local Tab = Window:CreateTab("Copier", "hammer")

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

local BUILDING_AREAS = Workspace:WaitForChild("Private Building Areas")

local function getRemote()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local tool = char:WaitForChild("Building Tools", 5)
    if not tool then error("Equip Building Tools!") end
    return tool:WaitForChild("SyncAPI"):WaitForChild("ServerEndpoint")
end

local localBuildArea = BUILDING_AREAS:WaitForChild(LocalPlayer.Name .. "BuildArea")
local localBuildFolder = localBuildArea:WaitForChild("Build")

local BASE_Y = 4
local X_OFFSET = -28.637
local Z_OFFSET = -17.512

local selectedPlayer = nil
local playerOptions = {}

local function refreshPlayers()
    playerOptions = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and BUILDING_AREAS:FindFirstChild(plr.Name .. "BuildArea") then
            table.insert(playerOptions, plr.Name)
        end
    end
end
refreshPlayers()

Tab:CreateSection("Player")

local Dropdown = Tab:CreateDropdown({
    Name = "Select Player to Copy From",
    Options = playerOptions,
    CurrentOption = {},
    MultipleOptions = false,
    Callback = function(Option)
        selectedPlayer = (typeof(Option) == "table" and #Option > 0)
            and Players:FindFirstChild(Option[1]) or nil
    end,
})

Tab:CreateSection("Offsets")

Tab:CreateSlider({
    Name = "X Offset",
    Range = {-100, 100},
    Increment = 0.01,
    CurrentValue = X_OFFSET,
    Callback = function(v) X_OFFSET = v end
})

Tab:CreateSlider({
    Name = "Z Offset",
    Range = {-100, 100},
    Increment = 0.01,
    CurrentValue = Z_OFFSET,
    Callback = function(v) Z_OFFSET = v end
})

Tab:CreateButton({
    Name = "🔄 Copy Build (Fixed)",
    Description = "Correct rotation + resize",
    Callback = function()

        if not selectedPlayer then
            Rayfield:Notify({Title = "Error", Content = "Select player!"})
            return
        end

        local remote = getRemote()

        local sourceArea = BUILDING_AREAS:FindFirstChild(selectedPlayer.Name .. "BuildArea")
        if not sourceArea then
            Rayfield:Notify({Title = "Error", Content = "Source not found"})
            return
        end

        local sourceBuild = sourceArea:WaitForChild("Build")

        -- Collect parts
        local allParts = {}
        for _, v in ipairs(sourceBuild:GetDescendants()) do
            if v:IsA("BasePart") then
                table.insert(allParts, v)
            end
        end

        if #allParts == 0 then
            Rayfield:Notify({Title = "Error", Content = "No parts found"})
            return
        end

        -- Calculate center
        local sum = Vector3.zero
        for _, p in ipairs(allParts) do
            sum += p.Position
        end
        local sourceCenter = sum / #allParts

        local destOrigin = localBuildArea.Position + Vector3.new(X_OFFSET, BASE_Y, Z_OFFSET)

        Rayfield:Notify({
            Title = "Copying...",
            Content = "Fixed rotation + resize in progress",
            Duration = 6
        })

        local createdParts = {}

        for _, sourcePart in ipairs(allParts) do

            local offset = sourcePart.Position - sourceCenter
            local targetPos = destOrigin + offset

            -- Detect type
            local partType = "Normal"
            local class = sourcePart.ClassName

            if class == "TrussPart" then partType = "Truss"
            elseif class == "WedgePart" then partType = "Wedge"
            elseif class == "CornerWedgePart" then partType = "Corner"
            elseif class == "Seat" then partType = "Seat"
            elseif class == "VehicleSeat" then partType = "Vehicle Seat"
            elseif class == "SpawnLocation" then partType = "Spawn"
            elseif sourcePart.Shape == Enum.PartType.Cylinder then partType = "Cylinder"
            elseif sourcePart.Shape == Enum.PartType.Ball then partType = "Ball"
            end

            -- CREATE
            local newPart = remote:InvokeServer(
                "CreatePart",
                partType,
                CFrame.new(targetPos),
                localBuildFolder
            )

            if newPart and newPart:IsA("BasePart") then
                table.insert(createdParts, newPart)

                -- ✅ ROTATION FIX (relative rotation)
                local relativeRotation = sourcePart.CFrame.Rotation
                local finalCF = CFrame.new(targetPos) * relativeRotation

                remote:InvokeServer("SyncMove", {
                    {Part = newPart, CFrame = finalCF}
                }, {"Pivot"})

                task.wait(0.2)

                -- ✅ RESIZE FIX (per-axis)
                local targetSize = sourcePart.Size
                local currentSize = newPart.Size
                local diff = targetSize - currentSize

                -- X
                if math.abs(diff.X) > 0.01 then
                    remote:InvokeServer("SyncResize", {
                        {Part = newPart, CFrame = newPart.CFrame}
                    }, {"ResizeFace", Enum.NormalId.Right})
                    newPart.Size += Vector3.new(diff.X, 0, 0)
                    task.wait(0.1)
                end

                -- Y
                if math.abs(diff.Y) > 0.01 then
                    remote:InvokeServer("SyncResize", {
                        {Part = newPart, CFrame = newPart.CFrame}
                    }, {"ResizeFace", Enum.NormalId.Top})
                    newPart.Size += Vector3.new(0, diff.Y, 0)
                    task.wait(0.1)
                end

                -- Z
                if math.abs(diff.Z) > 0.01 then
                    remote:InvokeServer("SyncResize", {
                        {Part = newPart, CFrame = newPart.CFrame}
                    }, {"ResizeFace", Enum.NormalId.Back})
                    newPart.Size += Vector3.new(0, 0, diff.Z)
                    task.wait(0.1)
                end
            end
        end

        -- Group parts
        if #createdParts > 0 then
            remote:InvokeServer("CreateGroup", "Model", localBuildFolder, createdParts)
        end

        Rayfield:Notify({
            Title = "Finished",
            Content = #createdParts .. " parts copied successfully",
            Duration = 8
        })
    end,
})

Tab:CreateButton({
    Name = "Refresh Player List",
    Callback = function()
        refreshPlayers()
        Dropdown:Refresh(playerOptions)
    end
})

Rayfield:Notify({
    Title = "Fixed Version Loaded",
    Content = "Rotation + Resize fully working | Height = 4",
    Duration = 8
})
