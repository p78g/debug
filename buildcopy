-- Town Build Copier - Fixed CreatePart Issue (Fresh Remote + Folder Every Call)

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Town Build Copier - Fixed",
    LoadingTitle = "Applying Fixes...",
    Theme = "Default"
})

local Tab = Window:CreateTab("Copier", "hammer")

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

local BUILDING_AREAS = Workspace:WaitForChild("Private Building Areas")

local function getFreshRemote()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local tool = char:WaitForChild("Building Tools", 5)
    if not tool then error("Equip Building Tools!") end
    return tool:WaitForChild("SyncAPI"):WaitForChild("ServerEndpoint")
end

local localBuildArea = BUILDING_AREAS:WaitForChild(LocalPlayer.Name .. "BuildArea")

local baseHeight = 5
local selectedPlayer = nil
local realOffsetX, realOffsetY, realOffsetZ = -28.637, -17.512, 0

local playerOptions = {}

local function refreshPlayers()
    playerOptions = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and BUILDING_AREAS:FindFirstChild(plr.Name .. "BuildArea") then
            table.insert(playerOptions, plr.Name)
        end
    end
end
refreshPlayers()

Tab:CreateSection("Player")
local Dropdown = Tab:CreateDropdown({
    Name = "Select Player to Copy From",
    Options = playerOptions,
    CurrentOption = {},
    MultipleOptions = false,
    Callback = function(Option)
        selectedPlayer = (typeof(Option) == "table" and #Option > 0) and Players:FindFirstChild(Option[1]) or nil
    end,
})

Tab:CreateSection("Offsets")
Tab:CreateSlider({ Name = "X Offset", Range = {-100, 100}, Increment = 0.01, CurrentValue = realOffsetX, Callback = function(v) realOffsetX = v end })
Tab:CreateSlider({ Name = "Y Offset", Range = {-50, 150}, Increment = 0.01, CurrentValue = realOffsetY, Callback = function(v) realOffsetY = v end })
Tab:CreateSlider({ Name = "Z Offset", Range = {-100, 100}, Increment = 0.01, CurrentValue = realOffsetZ, Callback = function(v) realOffsetZ = v end })

Tab:CreateButton({
    Name = "🔄 Copy Build (Fixed Version)",
    Description = "Fresh remote + folder every part + longer delays",
    Callback = function()
        if not selectedPlayer then
            Rayfield:Notify({Title = "Error", Content = "Select a player first!"}) 
            return 
        end

        local sourceArea = BUILDING_AREAS:FindFirstChild(selectedPlayer.Name .. "BuildArea")
        if not sourceArea then 
            Rayfield:Notify({Title = "Error", Content = "Source area not found"}) 
            return 
        end

        local sourceBuild = sourceArea:WaitForChild("Build")

        local allParts = {}
        local function collect(obj)
            for _, v in ipairs(obj:GetDescendants()) do
                if v:IsA("BasePart") then table.insert(allParts, v) end
            end
        end
        collect(sourceBuild)

        if #allParts == 0 then
            Rayfield:Notify({Title = "Error", Content = "No parts in source"}) 
            return 
        end

        local sumX, sumY, sumZ = 0, 0, 0
        for _, p in ipairs(allParts) do
            local pos = p.Position
            sumX += pos.X; sumY += pos.Y; sumZ += pos.Z
        end
        local sourceCenter = Vector3.new(sumX/#allParts, sumY/#allParts, sumZ/#allParts)

        local destOrigin = localBuildArea.Position + Vector3.new(realOffsetX, baseHeight + realOffsetY, realOffsetZ)

        Rayfield:Notify({Title = "Starting Copy", Content = "Trying " .. #allParts .. " parts with fresh calls...", Duration = 6})

        local created = 0

        for i, sourcePart in ipairs(allParts) do
            local offset = sourcePart.Position - sourceCenter
            local targetPos = destOrigin + offset
            local targetCFrame = CFrame.new(targetPos) * sourcePart.CFrame.Rotation

            local partType = "Normal"
            local class = sourcePart.ClassName
            if class == "TrussPart" then partType = "Truss"
            elseif class == "WedgePart" then partType = "Wedge"
            elseif class == "CornerWedgePart" then partType = "Corner"
            elseif class == "Cylinder" or sourcePart.Shape == Enum.PartType.Cylinder then partType = "Cylinder"
            elseif sourcePart.Shape == Enum.PartType.Ball then partType = "Ball"
            elseif class == "Seat" then partType = "Seat"
            elseif class == "VehicleSeat" then partType = "Vehicle Seat"
            elseif class == "SpawnLocation" then partType = "Spawn"
            end

            -- **Fresh remote and folder every single part**
            local remote = getFreshRemote()
            local currentFolder = localBuildArea:WaitForChild("Build")

            print(string.format("Attempt %d/%d | %s | Pos: %.2f, %.2f, %.2f", i, #allParts, partType, targetPos.X, targetPos.Y, targetPos.Z))

            local success, newPart = pcall(function()
                return remote:InvokeServer("CreatePart", partType, CFrame.new(targetPos), currentFolder)
            end)

            if success and newPart and newPart:IsA("BasePart") then
                created = created + 1
                print("✓ Created part", i)

                task.wait(0.6)

                -- Rotation + Move + Resize with longer delays
                remote:InvokeServer("SyncRotate", {{Part = newPart, CFrame = targetCFrame}}, {"AroundPivot", CFrame.new(), "Center", CFrame.new(), "Center"})
                task.wait(0.5)
                remote:InvokeServer("SyncMove", {{Part = newPart, CFrame = targetCFrame}}, {"AlongFace", Vector3.new(), "Global", CFrame.new()})
                task.wait(0.5)
                remote:InvokeServer("SyncResize", {{Part = newPart, CFrame = targetCFrame, Size = sourcePart.Size}}, {"ResizeFace", Enum.NormalId.Right, 0, Vector3.new(), "X", Vector3.xAxis, "Normal"})
                task.wait(0.6)
            else
                print("✗ Failed to create part", i)
                warn("Result:", newPart)
            end

            task.wait(0.8) -- Very important delay to prevent rate limiting
        end

        Rayfield:Notify({Title = "Copy Done", Content = created .. " / " .. #allParts .. " parts created. Check console.", Duration = 10})
    end,
})

Tab:CreateButton({ Name = "Refresh Players", Callback = function()
    refreshPlayers()
    Dropdown:Refresh(playerOptions)
end })

Rayfield:Notify({Title = "Fixed Script Loaded", Content = "Fresh remote + folder every part + long delays", Duration = 8})
