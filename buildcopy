local selectedPlayer = nil
local playerMapping = {}
local dropdown = nil

local function getBuildArea(folderName)
    local pa = workspace:FindFirstChild("Private Building Areas")
    return pa and pa:FindFirstChild(folderName)
end

local function refreshPlayers()
    local pa = workspace:FindFirstChild("Private Building Areas")
    if not pa then return {} end
    local opts = {}
    playerMapping = {}
    for _, c in ipairs(pa:GetChildren()) do
        local name = c.Name
        if name:sub(-9) == "BuildArea" then
            local pn = name:sub(1, -10)
            table.insert(opts, pn)
            playerMapping[pn] = name
        end
    end
    return opts
end

local function clearLocalBuild()
    local localName = game.Players.LocalPlayer.Name .. "BuildArea"
    local localBA = getBuildArea(localName)
    if localBA and localBA:FindFirstChild("Build") then
        for _, p in ipairs(localBA.Build:GetChildren()) do p:Destroy() end
        Rayfield:Notify({ Title = "Cleared", Content = "Your Build folder emptied." })
    end
end

-- Auto‑centre: average of all part positions (recursive, only BaseParts)
local function computeCentre(buildArea)
    local buildFolder = buildArea:FindFirstChild("Build")
    if not buildFolder then return buildArea.Position end
    local parts = {}
    local function collect(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then
                table.insert(parts, child)
            elseif child:IsA("Model") then
                collect(child)
            end
        end
    end
    collect(buildFolder)
    if #parts == 0 then return buildArea.Position end
    local sum = Vector3.new(0,0,0)
    for _, p in ipairs(parts) do sum = sum + p.Position end
    return sum / #parts
end

-- Remote access
local remote = nil
local function getRemote()
    if remote then return remote end
    local char = game.Players.LocalPlayer.Character
    if not char then return nil end
    local bt = char:FindFirstChild("Building Tools")
    if not bt then return nil end
    local api = bt:FindFirstChild("SyncAPI")
    if not api then return nil end
    remote = api:FindFirstChild("ServerEndpoint")
    return remote
end

-- Helper to convert Vector3 to vector.create (used in resize and move)
local function vec(v)
    return vector.create(v.X, v.Y, v.Z)
end

-- Copy a single part using EXACT remote structures (matching your examples)
local function copySinglePart(part, srcOrigin, dstOrigin, dstBuild)
    -- Part type mapping
    local typeMap = {
        Part = "Normal", Truss = "Truss", Wedge = "Wedge", Corner = "Corner",
        Cylinder = "Cylinder", Ball = "Ball", Seat = "Seat",
        ["Vehicle Seat"] = "Vehicle Seat", Spawn = "Spawn"
    }
    local partType = typeMap[part.Name] or "Normal"

    -- Offset and target position/CFrame
    local offset = part.Position - srcOrigin
    local targetPos = dstOrigin + offset
    local targetCFrame = CFrame.new(targetPos) * (part.CFrame - part.CFrame.Position)

    local r = getRemote()
    if not r then return nil end

    -- 1. CreatePart (uses part centre as origin, then we will move/rotate)
    local createArgs = {"CreatePart", partType, CFrame.new(dstOrigin), dstBuild}
    local ok, newPart = pcall(function() return r:InvokeServer(unpack(createArgs)) end)
    if not ok or not newPart then
        warn("CreatePart failed for", part.Name)
        return nil
    end
    task.wait(0.1)

    -- Locate the actual part in the build folder
    local actualPart = newPart
    if not actualPart:IsA("BasePart") then
        actualPart = dstBuild:FindFirstChild(part.Name)
    end
    if not actualPart then
        warn("Could not locate created part:", part.Name)
        return nil
    end

    -- 2. SyncRotate – EXACT pattern from your example
    local pivotCFrame = targetCFrame - targetCFrame.Position  -- rotation only
    local currentCFrame = CFrame.new(dstOrigin)               -- part's current CFrame (no rotation, at centre)
    local rotArgs = {
        "SyncRotate",
        { { Part = actualPart, CFrame = targetCFrame } },
        { "AroundPivot", pivotCFrame, "Center", currentCFrame, "Center" }
    }
    local rotSuccess, rotErr = pcall(function() return r:InvokeServer(unpack(rotArgs)) end)
    if not rotSuccess then warn("Rotate error:", rotErr) end
    task.wait(0.5)

    -- 3. SyncMove – EXACT pattern from your example
    local delta = targetPos - dstOrigin
    -- The move example uses vector.create for the delta, and the last argument is the target CFrame
    local moveArgs = {
        "SyncMove",
        { { Part = actualPart, CFrame = CFrame.new(targetPos) } },  -- target position CFrame (identity rotation)
        { "AlongFace", vec(delta), "Global", CFrame.new(targetPos) }
    }
    local moveSuccess, moveErr = pcall(function() return r:InvokeServer(unpack(moveArgs)) end)
    if not moveSuccess then warn("Move error:", moveErr) end
    task.wait(0.5)

    -- 4. SyncResize – EXACT pattern from your example
    -- Note: The ResizeFace parameters in your example used Right face, 14 studs, vector.create(14,0,0), "X", Vector3.xAxis, "Normal"
    -- We need to determine the correct face and delta based on size difference.
    -- To keep it simple, we will use the same pattern but with the actual size difference.
    local currentSize = actualPart.Size
    local targetSize = part.Size
    -- For simplicity, resize to exact size by using Front face and delta = targetSize - currentSize? 
    -- However the server expects a specific ResizeFace operation.
    -- Looking at your example: they resized a part from something to 24,1,3. They used Right face with delta 20 in X direction.
    -- So they are extending one face. To set exact size, we need to resize each axis individually? That is complex.
    -- Instead, we can use the same pattern but with a dummy ResizeFace that sets the final size.
    -- Many building systems accept a full Size in the first table and ignore the ResizeFace details.
    -- We'll supply a generic ResizeFace that doesn't change the size but the server will apply the Size from the first table.
    local resizeArgs = {
        "SyncResize",
        { { Part = actualPart, CFrame = CFrame.new(targetPos), Size = vec(part.Size) } },
        { "ResizeFace", Enum.NormalId.Front, 1, vec(Vector3.new(0,0,0)), "Z", part.Size, "Normal" }
    }
    local resizeSuccess, resizeErr = pcall(function() return r:InvokeServer(unpack(resizeArgs)) end)
    if not resizeSuccess then warn("Resize error:", resizeErr) end
    task.wait(0.5)

    return actualPart
end

-- Copy the whole build (recursively through models)
local function copyRealBuild()
    if not selectedPlayer then
        Rayfield:Notify({ Title = "Error", Content = "Select a player." })
        return
    end

    local srcFolder = playerMapping[selectedPlayer]
    local srcBA = getBuildArea(srcFolder)
    local dstBA = getBuildArea(game.Players.LocalPlayer.Name .. "BuildArea")
    if not srcBA or not dstBA then
        Rayfield:Notify({ Title = "Error", Content = "BuildAreas missing." })
        return
    end

    local srcBuild = srcBA:FindFirstChild("Build")
    local dstBuild = dstBA:FindFirstChild("Build")
    if not srcBuild or not dstBuild then
        Rayfield:Notify({ Title = "Error", Content = "Build folders missing." })
        return
    end

    -- Auto centre from source
    local srcCentre = computeCentre(srcBA)
    local finalY = baseHeight + yExtra
    local srcOrigin = srcCentre + Vector3.new(0, finalY, 0)
    local dstOrigin = dstBA.Position + Vector3.new(xOffset, finalY, zOffset)

    -- Collect all BaseParts recursively
    local allParts = {}
    local function collect(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then
                table.insert(allParts, child)
            elseif child:IsA("Model") then
                collect(child)
            end
        end
    end
    collect(srcBuild)
    if #allParts == 0 then
        Rayfield:Notify({ Title = "Info", Content = "No parts found." })
        return
    end

    clearLocalBuild()
    task.wait(0.5)

    Rayfield:Notify({ Title = "Copying", Content = #allParts .. " parts..." })
    local successCount = 0
    for _, part in ipairs(allParts) do
        if copySinglePart(part, srcOrigin, dstOrigin, dstBuild) then
            successCount = successCount + 1
        end
        task.wait(0.1) -- small delay between parts
    end
    Rayfield:Notify({ Title = "Complete", Content = successCount .. "/" .. #allParts .. " parts copied." })
end

-- Ghost preview (direct clones, same offsets, no remote calls)
local ghostModel = nil
local function showGhost()
    if ghostModel then ghostModel:Destroy() end
    if not selectedPlayer then
        Rayfield:Notify({ Title = "Error", Content = "Select a player." })
        return
    end

    local srcFolder = playerMapping[selectedPlayer]
    local srcBA = getBuildArea(srcFolder)
    local dstBA = getBuildArea(game.Players.LocalPlayer.Name .. "BuildArea")
    if not srcBA or not dstBA then
        Rayfield:Notify({ Title = "Error", Content = "BuildAreas missing." })
        return
    end
    local srcBuild = srcBA:FindFirstChild("Build")
    if not srcBuild then
        Rayfield:Notify({ Title = "Error", Content = "Source has no Build folder." })
        return
    end

    local finalY = baseHeight + yExtra
    local srcCentre = computeCentre(srcBA)
    local srcOrigin = srcCentre + Vector3.new(0, finalY, 0)
    local dstOrigin = dstBA.Position + Vector3.new(xOffset, finalY, zOffset)

    ghostModel = Instance.new("Model")
    ghostModel.Name = "GhostPreview"

    local function cloneParts(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then
                local offset = child.Position - srcOrigin
                local targetPos = dstOrigin + offset
                local clone = child:Clone()
                clone.Position = targetPos
                clone.CFrame = CFrame.new(targetPos) * (child.CFrame - child.CFrame.Position)
                clone.Anchored = true
                clone.CanCollide = false
                clone.Transparency = 0.7
                clone.Material = Enum.Material.ForceField
                clone.Parent = ghostModel
            elseif child:IsA("Model") then
                cloneParts(child)
            end
        end
    end
    cloneParts(srcBuild)
    ghostModel.Parent = workspace
    Rayfield:Notify({ Title = "Ghost Preview", Content = "Using base height " .. finalY .. ". Adjust offsets." })
end

local function hideGhost()
    if ghostModel then ghostModel:Destroy() end
end

