-- Town Build Copier - Rayfield UI Edition
-- Pure F3X Remote Calls | Works in Town

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Town Build Copier",
    LoadingTitle = "Loading Build Copier...",
    LoadingSubtitle = "by Grok",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "TownCopier",
        FileName = "Settings"
    },
    Theme = "Default"
})

local Tab = Window:CreateTab("Build Copier", "hammer") -- Lucide icon

local Section = Tab:CreateSection("Copy Settings")

-- Variables
local selectedPlayer = nil
local realOffsetX, realOffsetY, realOffsetZ = 0, 0, 0
local ghostOffsetX, ghostOffsetY, ghostOffsetZ = -28.637, -17.512, 0
local baseHeight = 5  -- as you requested (was 3 before)

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

local BUILDING_AREAS = Workspace:WaitForChild("Private Building Areas")

local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local tool = character:WaitForChild("Building Tools")
local remote = tool:WaitForChild("SyncAPI"):WaitForChild("ServerEndpoint")

local localBuildArea = BUILDING_AREAS:WaitForChild(LocalPlayer.Name .. "BuildArea")
local localBuildFolder = localBuildArea:WaitForChild("Build")

-- Refresh player list
local playerOptions = {}

local function refreshPlayers()
    playerOptions = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local area = BUILDING_AREAS:FindFirstChild(plr.Name .. "BuildArea")
            if area then
                table.insert(playerOptions, plr.Name)
            end
        end
    end
end

refreshPlayers()

local Dropdown = Tab:CreateDropdown({
    Name = "Select Player to Copy From",
    Options = playerOptions,
    CurrentOption = {},
    MultipleOptions = false,
    Flag = "SourcePlayer",
    Callback = function(Option)
        if typeof(Option) == "table" and #Option > 0 then
            selectedPlayer = Players:FindFirstChild(Option[1])
        else
            selectedPlayer = nil
        end
    end,
})

-- Real Copy Offsets
Tab:CreateSection("Real Copy Offsets (Default 0)")

Tab:CreateSlider({
    Name = "Real X Offset",
    Range = {-100, 100},
    Increment = 0.1,
    CurrentValue = 0,
    Flag = "RealX",
    Callback = function(Value) realOffsetX = Value end,
})

Tab:CreateSlider({
    Name = "Real Y Offset",
    Range = {-50, 150},
    Increment = 0.1,
    CurrentValue = 0,
    Flag = "RealY",
    Callback = function(Value) realOffsetY = Value end,
})

Tab:CreateSlider({
    Name = "Real Z Offset",
    Range = {-100, 100},
    Increment = 0.1,
    CurrentValue = 0,
    Flag = "RealZ",
    Callback = function(Value) realOffsetZ = Value end,
})

-- Ghost Preview Offsets
Tab:CreateSection("Ghost Preview Offsets")

Tab:CreateSlider({
    Name = "Ghost X Offset",
    Range = {-100, 100},
    Increment = 0.1,
    CurrentValue = -28.637,
    Flag = "GhostX",
    Callback = function(Value) ghostOffsetX = Value end,
