-- Town Build Copier - Efficient Version (Direct Mirror Position + Fixed Spawning)
-- Creates each part directly at mirrored target position

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Town Build Copier - Efficient",
    LoadingTitle = "Loading...",
    LoadingSubtitle = "Direct Mirror Positioning",
    Theme = "Default"
})

local Tab = Window:CreateTab("Copier", "hammer")

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

local BUILDING_AREAS = Workspace:WaitForChild("Private Building Areas")

local function getRemote()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local tool = char:WaitForChild("Building Tools", 8)
    if not tool then 
        Rayfield:Notify({Title = "Error", Content = "Equip Building Tools first!", Duration = 6})
        error("Building Tools not equipped")
    end
    return tool:WaitForChild("SyncAPI"):WaitForChild("ServerEndpoint")
end

local localBuildArea = BUILDING_AREAS:WaitForChild(LocalPlayer.Name .. "BuildArea")
local localBuildFolder = localBuildArea:WaitForChild("Build")

local baseHeight = 5
local selectedPlayer = nil

local realOffsetX, realOffsetY, realOffsetZ = -28.637, -17.512, 0
local ghostOffsetX, ghostOffsetY, ghostOffsetZ = -28.637, -17.512, 0

local playerOptions = {}

local function refreshPlayers()
    playerOptions = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and BUILDING_AREAS:FindFirstChild(plr.Name .. "BuildArea") then
            table.insert(playerOptions, plr.Name)
        end
    end
end
refreshPlayers()

-- ==================== TEST BUTTON ====================
Tab:CreateSection("Test Remote")

Tab:CreateButton({
    Name = "🧪 Test: Spawn ONE Part (Safe Position)",
    Callback = function()
        local remote = getRemote()
        local testPos = localBuildArea.Position + Vector3.new(0, baseHeight + 15, 0)
        
        local success, newPart = pcall(function()
            return remote:InvokeServer("CreatePart", "Normal", CFrame.new(testPos), localBuildFolder)
        end)

        if success and newPart and newPart:IsA("BasePart") then
            Rayfield:Notify({Title = "Test Success", Content = "Part spawned! Remote works.", Duration = 8})
            print("Test part created at:", newPart.Position)
        else
            Rayfield:Notify({Title = "Test Failed", Content = "Check F9 console for details", Duration = 10})
            warn("CreatePart failed | Success:", success, "| Result:", newPart)
        end
    end,
})

-- ==================== UI ====================
Tab:CreateSection("Player Selection")
local Dropdown = Tab:CreateDropdown({
    Name = "Select Player to Copy From",
    Options = playerOptions,
    CurrentOption = {},
    MultipleOptions = false,
    Callback = function(Option)
        if typeof(Option) == "table" and #Option > 0 then
            selectedPlayer = Players:FindFirstChild(Option[1])
        else
            selectedPlayer = nil
        end
    end,
})

Tab:CreateSection("Real Copy Offsets")
Tab:CreateSlider({ Name = "Real X Offset", Range = {-100, 100}, Increment = 0.01, CurrentValue = realOffsetX, Callback = function(v) realOffsetX = v end })
Tab:CreateSlider({ Name = "Real Y Offset", Range = {-50, 150}, Increment = 0.01, CurrentValue = realOffsetY, Callback = function(v) realOffsetY = v end })
Tab:CreateSlider({ Name = "Real Z Offset", Range = {-100, 100}, Increment = 0.01, CurrentValue = realOffsetZ, Callback = function(v) realOffsetZ = v end })

Tab:CreateSection("Ghost Preview Offsets")
Tab:CreateSlider({ Name = "Ghost X Offset", Range = {-100, 100}, Increment = 0.01, CurrentValue = ghostOffsetX, Callback = function(v) ghostOffsetX = v end })
Tab:CreateSlider({ Name = "Ghost Y Offset", Range = {-50, 150}, Increment = 0.01, CurrentValue = ghostOffsetY, Callback = function(v) ghostOffsetY = v end })
Tab:CreateSlider({ Name = "Ghost Z Offset", Range = {-100, 100}, Increment = 0.01, CurrentValue = ghostOffsetZ, Callback = function(v) ghostOffsetZ = v end })

-- ==================== MAIN COPY ====================
Tab:CreateButton({
    Name = "🔄 Copy Build (Real) - Direct Mirror",
    Description = "Creates parts directly at mirrored position",
    Callback = function()
        if not selectedPlayer then
            Rayfield:Notify({Title = "Error", Content = "No player selected!"}) 
            return 
        end

        local remote = getRemote()
        local sourceArea = BUILDING_AREAS:FindFirstChild(selectedPlayer.Name .. "BuildArea")
        if not sourceArea then 
            Rayfield:Notify({Title = "Error", Content = "Source plot not found"}) 
            return 
        end

        local sourceBuild = sourceArea:WaitForChild("Build")

        local allParts = {}
        local function collect(obj)
            for _, v in ipairs(obj:GetDescendants()) do
                if v:IsA("BasePart") then table.insert(allParts, v) end
            end
        end
        collect(sourceBuild)

        if #allParts == 0 then
            Rayfield:Notify({Title = "Error", Content = "No parts found in source"}) 
            return 
        end

        -- Calculate source center
        local sumX, sumY, sumZ = 0, 0, 0
        for _, p in ipairs(allParts) do
            local pos = p.Position
            sumX += pos.X; sumY += pos.Y; sumZ += pos.Z
        end
        local sourceCenter = Vector3.new(sumX/#allParts, sumY/#allParts, sumZ/#allParts)

        local destOrigin = localBuildArea.Position + Vector3.new(realOffsetX, baseHeight + realOffsetY, realOffsetZ)

        Rayfield:Notify({Title = "Copying...", Content = "Creating " .. #allParts .. " parts directly at mirrored positions...", Duration = 6})

        local createdParts = {}

        for i, sourcePart in ipairs(allParts) do
            local offset = sourcePart.Position - sourceCenter
            local targetPos = destOrigin + offset
            local targetCFrame = CFrame.new(targetPos) * sourcePart.CFrame.Rotation

            local partType = "Normal"
            local class = sourcePart.ClassName
            if class == "TrussPart" then partType = "Truss"
            elseif class == "WedgePart" then partType = "Wedge"
            elseif class == "CornerWedgePart" then partType = "Corner"
            elseif class == "Cylinder" or sourcePart.Shape == Enum.PartType.Cylinder then partType = "Cylinder"
            elseif sourcePart.Shape == Enum.PartType.Ball then partType = "Ball"
            elseif class == "Seat" then partType = "Seat"
            elseif class == "VehicleSeat" then partType = "Vehicle Seat"
            elseif class == "SpawnLocation" then partType = "Spawn"
            end

            print(string.format("[%d/%d] Creating %s at %s", i, #allParts, partType, tostring(targetPos)))

            -- Create directly at target position (your requested change)
            local newPart = remote:InvokeServer("CreatePart", partType, CFrame.new(targetPos), localBuildFolder)

            if newPart and newPart:IsA("BasePart") then
                table.insert(createdParts, newPart)

                -- Apply exact rotation
                remote:InvokeServer("SyncRotate", {{Part = newPart, CFrame = targetCFrame}}, {"AroundPivot", CFrame.new(), "Center", CFrame.new(), "Center"})
                task.wait(0.4)

                -- Final move (in case creation drifted)
                remote:InvokeServer("SyncMove", {{Part = newPart, CFrame = targetCFrame}}, {"AlongFace", Vector3.new(), "Global", CFrame.new()})
                task.wait(0.4)

                -- Resize
                remote:InvokeServer("SyncResize", {{Part = newPart, CFrame = targetCFrame, Size = sourcePart.Size}}, {"ResizeFace", Enum.NormalId.Right, 0, Vector3.new(), "X", Vector3.xAxis, "Normal"})
                task.wait(0.5)
            else
                warn("Failed to create part", i, partType)
            end
        end

        if #createdParts > 0 then
            remote:InvokeServer("CreateGroup", "Model", localBuildFolder, createdParts)
        end

        Rayfield:Notify({Title = "Finished", Content = #createdParts .. " parts created. Check your plot.", Duration = 8})
    end,
})

-- Ghost Preview (same logic as real copy)
Tab:CreateButton({
    Name = "👻 Show Ghost Preview",
    Callback = function()
        local old = Workspace:FindFirstChild("GhostPreview")
        if old then old:Destroy() end

        if not selectedPlayer then return Rayfield:Notify({Title="Error", Content="Select player"}) end

        local sourceArea = BUILDING_AREAS:FindFirstChild(selectedPlayer.Name .. "BuildArea")
        local sourceBuild = sourceArea:WaitForChild("Build")

        local allParts = {}
        local function collect(obj)
            for _, v in ipairs(obj:GetDescendants()) do if v:IsA("BasePart") then table.insert(allParts, v) end end
        end
        collect(sourceBuild)

        local sumX, sumY, sumZ = 0,0,0
        for _, p in ipairs(allParts) do
            local pos = p.Position
            sumX += pos.X; sumY += pos.Y; sumZ += pos.Z
        end
        local sourceCenter = Vector3.new(sumX/#allParts, sumY/#allParts, sumZ/#allParts)

        local ghostFolder = Instance.new("Folder")
        ghostFolder.Name = "GhostPreview"
        ghostFolder.Parent = Workspace

        local destOrigin = localBuildArea.Position + Vector3.new(ghostOffsetX, baseHeight + ghostOffsetY, ghostOffsetZ)

        for _, sourcePart in ipairs(allParts) do
            local offset = sourcePart.Position - sourceCenter
            local targetPos = destOrigin + offset
            local targetCFrame = CFrame.new(targetPos) * sourcePart.CFrame.Rotation

            local clone = sourcePart:Clone()
            clone.Anchored = true
            clone.Transparency = 0.65
            clone.Color = Color3.fromRGB(0, 255, 120)
            clone.CanCollide = false
            clone.CFrame = targetCFrame
            clone.Parent = ghostFolder
        end

        Rayfield:Notify({Title = "Ghost Preview", Content = "Check alignment & rotation", Duration = 6})
    end,
})

Tab:CreateButton({ Name = "Clear Ghost Preview", Callback = function()
    local g = Workspace:FindFirstChild("GhostPreview")
    if g then g:Destroy() end
end })

Tab:CreateButton({ Name = "Refresh Player List", Callback = function()
    refreshPlayers()
    Dropdown:Refresh(playerOptions)
end })

Rayfield:Notify({Title = "Efficient Copier Loaded", Content = "Click TEST first, then Copy Build", Duration = 8})
