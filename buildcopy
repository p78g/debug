local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Build Copier",
    LoadingTitle = "Build Copier",
    ConfigurationSaving = { Enabled = true, FolderName = "BuildCopier", FileName = "Settings" },
    Theme = "Default",
})

local MainTab = Window:CreateTab("Copy Build", "Copy")
MainTab:CreateSection("Player Selection")

local selectedPlayer = nil
local playerMapping = {}
local dropdownObject = nil

-- Helper: get the BuildArea object (model or part) – we'll use its Position as origin
local function getBuildAreaObject(folderName)
    local privateArea = workspace:FindFirstChild("Private Building Areas")
    if not privateArea then return nil end
    return privateArea:FindFirstChild(folderName)
end

-- Clear local build
local function clearLocalBuild()
    local privateArea = workspace:FindFirstChild("Private Building Areas")
    if not privateArea then return false end
    local localFolder = game.Players.LocalPlayer.Name .. "BuildArea"
    local localBuildArea = privateArea:FindFirstChild(localFolder)
    if not localBuildArea then return false end
    local buildFolder = localBuildArea:FindFirstChild("Build")
    if not buildFolder then return false end

    local count = 0
    for _, child in ipairs(buildFolder:GetChildren()) do
        if child:IsA("BasePart") then
            child:Destroy()
            count = count + 1
        end
    end
    Rayfield:Notify({ Title = "Cleared", Content = "Removed " .. count .. " parts.", Duration = 3 })
    return true
end

-- Refresh player list
local function refreshPlayerList()
    local privateArea = workspace:FindFirstChild("Private Building Areas")
    if not privateArea then return {} end
    local options = {}
    playerMapping = {}
    for _, child in ipairs(privateArea:GetChildren()) do
        local name = child.Name
        if name:sub(-9) == "BuildArea" then
            local pName = name:sub(1, -10)
            table.insert(options, pName)
            playerMapping[pName] = name
        end
    end
    return options
end

-- Copy a single part using the exact remote formats
local function copyPart(sourcePart, sourceBuildArea, localBuildArea, localBuildFolder)
    -- Part type mapping
    local typeMap = {
        Part = "Normal", Truss = "Truss", Wedge = "Wedge", Corner = "Corner",
        Cylinder = "Cylinder", Ball = "Ball", Seat = "Seat",
        ["Vehicle Seat"] = "Vehicle Seat", Spawn = "Spawn"
    }
    local partType = typeMap[sourcePart.Name] or "Normal"

    -- Use the BuildArea model's Position as the origin (centre of plot)
    local sourceOrigin = sourceBuildArea.Position
    local localOrigin = localBuildArea.Position

    -- Offset from source origin to source part
    local offset = sourcePart.Position - sourceOrigin
    local targetPos = localOrigin + offset

    -- Preserve rotation relative to world axes
    local sourceCFrame = sourcePart.CFrame
    local targetCFrame = CFrame.new(targetPos) * (sourceCFrame - sourceCFrame.Position)

    print(string.format("[COPY] %s | Offset: (%.2f, %.2f, %.2f) | Target: (%.2f, %.2f, %.2f)",
        sourcePart.Name, offset.X, offset.Y, offset.Z, targetPos.X, targetPos.Y, targetPos.Z))

    -- Get remote
    local char = game.Players.LocalPlayer.Character
    if not char then return false end
    local buildingTools = char:FindFirstChild("Building Tools")
    if not buildingTools then return false end
    local syncAPI = buildingTools:FindFirstChild("SyncAPI")
    if not syncAPI then return false end
    local remote = syncAPI:FindFirstChild("ServerEndpoint")
    if not remote then return false end

    -- 1. Create part at local origin (centre)
    local createArgs = {"CreatePart", partType, CFrame.new(localOrigin), localBuildFolder}
    local success, newPart = pcall(function() return remote:InvokeServer(unpack(createArgs)) end)
    if not success or not newPart then
        warn("CreatePart failed for " .. sourcePart.Name)
        return false
    end
    task.wait(0.1)

    -- Locate the actual part
    local actualPart = newPart
    if not actualPart:IsA("BasePart") then
        actualPart = localBuildFolder:FindFirstChild(sourcePart.Name)
    end
    if not actualPart then return false end

    -- 2. Rotate using the exact structure from the raw rotate example
    -- Compute pivot CFrame (rotation only, no translation)
    local pivotCFrame = targetCFrame - targetCFrame.Position
    -- The part's current CFrame (at local origin with identity rotation)
    local currentCFrame = CFrame.new(localOrigin)
    local rotateArgs = {
        "SyncRotate",
        { { Part = actualPart, CFrame = targetCFrame } },
        { "AroundPivot", pivotCFrame, "Center", currentCFrame, "Center" }
    }
    pcall(function() remote:InvokeServer(unpack(rotateArgs)) end)
    task.wait(0.1)

    -- 3. Move using the exact structure from the raw move example
    -- Compute delta (from current position to target position)
    local delta = targetPos - localOrigin
    -- The final CFrame for move action (position only, identity rotation)
    local moveTargetCFrame = CFrame.new(targetPos)
    local moveArgs = {
        "SyncMove",
        { { Part = actualPart, CFrame = moveTargetCFrame } },
        { "AlongFace", Vector3.new(delta.X, delta.Y, delta.Z), "Global", moveTargetCFrame }
    }
    pcall(function() remote:InvokeServer(unpack(moveArgs)) end)
    task.wait(0.1)

    -- 4. Resize using the exact structure from the raw resize example
    -- We'll resize by adjusting the face that corresponds to the size difference
    -- For simplicity, we resize to the exact size using a generic resize command
    local resizeArgs = {
        "SyncResize",
        { { Part = actualPart, CFrame = moveTargetCFrame, Size = sourcePart.Size } },
        { "ResizeFace", Enum.NormalId.Front, 1, Vector3.new(0,0,0), "Z", sourcePart.Size, "Normal" }
    }
    pcall(function() remote:InvokeServer(unpack(resizeArgs)) end)

    return true
end

-- Main copy function
local function copyBuild(playerDisplayName)
    local privateArea = workspace:FindFirstChild("Private Building Areas")
    if not privateArea then
        Rayfield:Notify({Title = "Error", Content = "Private Building Areas not found!", Duration = 5})
        return
    end

    local sourceFolderName = playerMapping[playerDisplayName]
    if not sourceFolderName then
        Rayfield:Notify({Title = "Error", Content = "Source folder not found!", Duration = 5})
        return
    end

    local sourceBuildArea = getBuildAreaObject(sourceFolderName)
    if not sourceBuildArea then
        Rayfield:Notify({Title = "Error", Content = "Source BuildArea missing!", Duration = 5})
        return
    end

    local localPlayerName = game.Players.LocalPlayer.Name
    local localFolderName = localPlayerName .. "BuildArea"
    local localBuildArea = getBuildAreaObject(localFolderName)
    if not localBuildArea then
        Rayfield:Notify({Title = "Error", Content = "Your BuildArea missing!", Duration = 5})
        return
    end

    local sourceBuildFolder = sourceBuildArea:FindFirstChild("Build")
    local localBuildFolder = localBuildArea:FindFirstChild("Build")
    if not sourceBuildFolder or not localBuildFolder then
        Rayfield:Notify({Title = "Error", Content = "Build folders missing!", Duration = 5})
        return
    end

    -- Collect all parts
    local parts = {}
    for _, child in ipairs(sourceBuildFolder:GetChildren()) do
        if child:IsA("BasePart") then
            table.insert(parts, child)
        end
    end
    if #parts == 0 then
        Rayfield:Notify({Title = "Info", Content = "No parts found to copy.", Duration = 5})
        return
    end

    Rayfield:Notify({Title = "Copying", Content = "Copying " .. #parts .. " parts...", Duration = 3})

    local successCount = 0
    for _, part in ipairs(parts) do
        if copyPart(part, sourceBuildArea, localBuildArea, localBuildFolder) then
            successCount = successCount + 1
        end
        task.wait(0.05)
    end

    Rayfield:Notify({Title = "Complete", Content = "Copied " .. successCount .. "/" .. #parts .. " parts.", Duration = 5})
end

-- Dropdown refresh
local function refreshDropdown()
    local options = refreshPlayerList()
    if dropdownObject then
        dropdownObject:SetOptions(options)
        if options[1] then
            dropdownObject:SetValue(options[1])
            selectedPlayer = options[1]
        end
    end
    if #options == 0 then
        Rayfield:Notify({Title = "Warning", Content = "No player BuildAreas found.", Duration = 5})
    end
end

-- Build UI
local initialOptions = refreshPlayerList()
dropdownObject = MainTab:CreateDropdown({
    Name = "Select Player",
    Options = initialOptions,
    CurrentOption = initialOptions[1] or "",
    Callback = function(opt) selectedPlayer = opt end
})
if initialOptions[1] then selectedPlayer = initialOptions[1] end

MainTab:CreateButton({
    Name = "Clear Your Build",
    Callback = function()
        clearLocalBuild()
    end
})

MainTab:CreateButton({
    Name = "Copy Build",
    Callback = function()
        if not selectedPlayer then
            Rayfield:Notify({Title = "Error", Content = "Select a player first.", Duration = 3})
            return
        end
        task.spawn(function() copyBuild(selectedPlayer) end)
    end
})

MainTab:CreateButton({
    Name = "Refresh Player List",
    Callback = function()
        refreshDropdown()
        Rayfield:Notify({Title = "Refreshed", Content = "Player list updated.", Duration = 2})
    end
})

Rayfield:Notify({Title = "Build Copier Ready", Content = "Clear your build first, then copy.", Duration = 5})
