-- FINAL BUILD COPIER - Uses ghost origin, debugs every step
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({Name = "Build Copier", ConfigurationSaving = {Enabled = true}, Theme = "Default"})
local MainTab = Window:CreateTab("Copy Build")

-- Offsets (manual adjustment)
local xOffset = 0
local zOffset = 0
local yExtra = 0
MainTab:CreateSlider({Name = "X Offset", Range = {-50,50}, Increment = 1, CurrentValue = 0, Callback = function(v) xOffset = v end})
MainTab:CreateSlider({Name = "Z Offset", Range = {-50,50}, Increment = 1, CurrentValue = 0, Callback = function(v) zOffset = v end})
MainTab:CreateSlider({Name = "Extra Y", Range = {-5,5}, Increment = 0.5, CurrentValue = 0, Callback = function(v) yExtra = v end})

local selectedPlayer = nil
local playerMapping = {}
local dropdown = nil

local function getBA(name) return workspace:FindFirstChild("Private Building Areas") and workspace.PrivateBuildingAreas:FindFirstChild(name) end

local function refreshPlayers()
    local pa = workspace.PrivateBuildingAreas
    if not pa then return {} end
    local opts = {}
    playerMapping = {}
    for _, c in ipairs(pa:GetChildren()) do
        local n = c.Name
        if n:sub(-9) == "BuildArea" then
            local pn = n:sub(1,-10)
            table.insert(opts, pn)
            playerMapping[pn] = n
        end
    end
    return opts
end

local function clearLocal()
    local myBA = getBA(game.Players.LocalPlayer.Name.."BuildArea")
    if myBA and myBA:FindFirstChild("Build") then
        for _, p in ipairs(myBA.Build:GetChildren()) do p:Destroy() end
        Rayfield:Notify({Title="Cleared"})
    end
end

-- Compute centre of build (average of all part positions)
local function computeCentre(buildArea)
    local build = buildArea:FindFirstChild("Build")
    if not build then return buildArea.Position end
    local parts = {}
    local function collect(obj)
        for _, ch in ipairs(obj:GetChildren()) do
            if ch:IsA("BasePart") then table.insert(parts, ch)
            elseif ch:IsA("Model") then collect(ch) end
        end
    end
    collect(build)
    if #parts == 0 then return buildArea.Position end
    local sum = Vector3.new(0,0,0)
    for _, p in ipairs(parts) do sum = sum + p.Position end
    return sum / #parts
end

-- Ghost preview (exact same origin as real copy)
local ghost = nil
local function showGhost()
    if ghost then ghost:Destroy() end
    if not selectedPlayer then Rayfield:Notify({Title="Select player"}) return end
    local srcBA = getBA(playerMapping[selectedPlayer])
    local dstBA = getBA(game.Players.LocalPlayer.Name.."BuildArea")
    if not srcBA or not dstBA then Rayfield:Notify({Title="Missing BA"}) return end
    local srcBuild = srcBA:FindFirstChild("Build")
    if not srcBuild then return end

    local srcCentre = computeCentre(srcBA)
    local dstCentre = dstBA.Position + Vector3.new(xOffset, yExtra, zOffset)
    local buildHeight = 5
    local srcOrigin = srcCentre + Vector3.new(0, buildHeight, 0)
    local dstOrigin = dstCentre + Vector3.new(0, buildHeight, 0)

    ghost = Instance.new("Model")
    ghost.Name = "Ghost"
    local function clone(obj)
        for _, ch in ipairs(obj:GetChildren()) do
            if ch:IsA("BasePart") then
                local offset = ch.Position - srcOrigin
                local pos = dstOrigin + offset
                local c = ch:Clone()
                c.Position = pos
                c.CFrame = CFrame.new(pos) * (ch.CFrame - ch.CFrame.Position)
                c.Anchored = true
                c.CanCollide = false
                c.Transparency = 0.7
                c.Material = Enum.Material.ForceField
                c.Parent = ghost
            elseif ch:IsA("Model") then clone(ch) end
        end
    end
    clone(srcBuild)
    ghost.Parent = workspace
    Rayfield:Notify({Title="Ghost shown"})
end
local function hideGhost() if ghost then ghost:Destroy() end end

-- Real copy (simplified, using same origin as ghost)
local remote = nil
local function getRemote()
    if remote then return remote end
    local char = game.Players.LocalPlayer.Character
    if not char then return nil end
    local bt = char:FindFirstChild("Building Tools")
    if not bt then return nil end
    local api = bt:FindFirstChild("SyncAPI")
    if not api then return nil end
    remote = api:FindFirstChild("ServerEndpoint")
    return remote
end

local function copyPart(part, srcOrigin, dstOrigin, dstBuild)
    local typeMap = {Part="Normal", Truss="Truss", Wedge="Wedge", Corner="Corner", Cylinder="Cylinder", Ball="Ball", Seat="Seat", ["Vehicle Seat"]="Vehicle Seat", Spawn="Spawn"}
    local pType = typeMap[part.Name] or "Normal"
    local offset = part.Position - srcOrigin
    local targetPos = dstOrigin + offset
    local targetCF = CFrame.new(targetPos) * (part.CFrame - part.CFrame.Position)
    local r = getRemote()
    if not r then return nil end

    -- Create
    local ok, newPart = pcall(function() return r:InvokeServer("CreatePart", pType, CFrame.new(dstOrigin), dstBuild) end)
    if not ok or not newPart then warn("CreatePart fail", part.Name); return nil end
    task.wait(0.1)
    local actual = newPart:IsA("BasePart") and newPart or dstBuild:FindFirstChild(part.Name)
    if not actual then return nil end

    -- Rotate (simplified)
    pcall(function() r:InvokeServer("SyncRotate", {{Part=actual, CFrame=targetCF}}, {}) end)
    task.wait(0.1)
    -- Move
    pcall(function() r:InvokeServer("SyncMove", {{Part=actual, CFrame=CFrame.new(targetPos)}}, {}) end)
    task.wait(0.1)
    -- Resize
    pcall(function() r:InvokeServer("SyncResize", {{Part=actual, CFrame=CFrame.new(targetPos), Size=part.Size}}, {"ResizeFace", Enum.NormalId.Front, 1, Vector3.new(0,0,0), "Z", part.Size, "Normal"}) end)
    return actual
end

local function copyReal()
    if not selectedPlayer then Rayfield:Notify({Title="Select player"}) return end
    hideGhost()
    clearLocal()
    task.wait(0.5)
    local srcBA = getBA(playerMapping[selectedPlayer])
    local dstBA = getBA(game.Players.LocalPlayer.Name.."BuildArea")
    if not srcBA or not dstBA then Rayfield:Notify({Title="Missing BA"}) return end
    local srcBuild = srcBA:FindFirstChild("Build")
    local dstBuild = dstBA:FindFirstChild("Build")
    if not srcBuild or not dstBuild then Rayfield:Notify({Title="Missing Build folders"}) return end

    local srcCentre = computeCentre(srcBA)
    local dstCentre = dstBA.Position + Vector3.new(xOffset, yExtra, zOffset)
    local buildHeight = 3
    local srcOrigin = srcCentre + Vector3.new(0, buildHeight, 0)
    local dstOrigin = dstCentre + Vector3.new(0, buildHeight, 0)

    -- Collect all parts
    local allParts = {}
    local function collect(obj)
        for _, ch in ipairs(obj:GetChildren()) do
            if ch:IsA("BasePart") then table.insert(allParts, ch)
            elseif ch:IsA("Model") then collect(ch) end
        end
    end
    collect(srcBuild)
    if #allParts == 0 then Rayfield:Notify({Title="No parts"}) return end
    Rayfield:Notify({Title="Copying", Content=#allParts.." parts"})
    local success = 0
    for _, p in ipairs(allParts) do
        if copyPart(p, srcOrigin, dstOrigin, dstBuild) then success = success + 1 end
        task.wait(0.05)
    end
    Rayfield:Notify({Title="Done", Content=success.."/"..#allParts.." copied"})
end

-- UI
local opts = refreshPlayers()
dropdown = MainTab:CreateDropdown({Name="Select Player", Options=opts, CurrentOption=opts[1] or "", Callback=function(opt) selectedPlayer=opt end})
if opts[1] then selectedPlayer = opts[1] end
MainTab:CreateButton({Name="Clear Your Build", Callback=clearLocal})
MainTab:CreateButton({Name="Show Ghost", Callback=showGhost})
MainTab:CreateButton({Name="Hide Ghost", Callback=hideGhost})
MainTab:CreateButton({Name="Copy Real Build", Callback=copyReal})
MainTab:CreateButton({Name="Refresh", Callback=function()
    local newOpts = refreshPlayers()
    dropdown:SetOptions(newOpts)
    if newOpts[1] then dropdown:SetValue(newOpts[1]); selectedPlayer=newOpts[1] end
end})
Rayfield:Notify({Title="Ready", Content="Adjust offsets until ghost aligns, then copy."})
