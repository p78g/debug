-- =============================================
-- BUILD COPIER using Rayfield
-- Copies any player's build to your plot
-- =============================================

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Build Copier",
    LoadingTitle = "Build Copier",
    LoadingSubtitle = "Select a player and copy their build",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "BuildCopier",
        FileName = "Settings"
    },
    Theme = "Default",
})

local MainTab = Window:CreateTab("Copy Build", "Copy")

MainTab:CreateSection("Player Selection")

-- Variables
local selectedPlayer = nil
local playerMapping = {}           -- display name -> folder name (e.g. "PlayerName" -> "PlayerNameBuildArea")
local dropdownObject = nil

-- Helper: refresh the list of players with BuildArea folders
local function refreshPlayerList()
    local privateArea = workspace:FindFirstChild("Private Building Areas")
    if not privateArea then
        Rayfield:Notify({
            Title = "Error",
            Content = "Private Building Areas not found!",
            Duration = 5
        })
        return {}
    end

    local options = {}
    playerMapping = {}
    for _, child in ipairs(privateArea:GetChildren()) do
        local name = child.Name
        if string.sub(name, -9) == "BuildArea" then
            local playerName = string.sub(name, 1, -10)
            table.insert(options, playerName)
            playerMapping[playerName] = name
        end
    end
    return options
end

-- Helper: get the plot's BasePart (the actual physical part representing the plot)
local function getPlotPart(plotFolderName)
    local privateArea = workspace:FindFirstChild("Private Building Areas")
    if not privateArea then return nil end
    local obj = privateArea:FindFirstChild(plotFolderName)
    if not obj then return nil end
    if obj:IsA("BasePart") then return obj end
    if obj:IsA("Model") then
        if obj.PrimaryPart then return obj.PrimaryPart end
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then return child end
        end
    end
    return nil
end

-- Core copy function for a single part
local function copyPart(sourcePart, sourcePlotPart, localPlotPart, localBuildFolder)
    -- Map part names to the type string expected by SyncAPI
    local typeMap = {
        Part = "Normal",
        Truss = "Truss",
        Wedge = "Wedge",
        Corner = "Corner",
        Cylinder = "Cylinder",
        Ball = "Ball",
        Seat = "Seat",
        ["Vehicle Seat"] = "Vehicle Seat",
        Spawn = "Spawn"
    }
    local partType = typeMap[sourcePart.Name] or "Normal"

    -- Origins: building surface is 3 studs above the plot part
    local sourceOrigin = sourcePlotPart.Position + Vector3.new(0, 3, 0)
    local localOrigin = localPlotPart.Position + Vector3.new(0, 3, 0)

    -- Relative offset from source plot centre
    local relativePos = sourcePart.Position - sourceOrigin
    local targetPos = localOrigin + relativePos

    -- Preserve rotation relative to the plot (since plots are axis-aligned)
    local sourceCFrame = sourcePart.CFrame
    local targetCFrame = CFrame.new(targetPos) * (sourceCFrame - sourceCFrame.Position)

    -- Get the remote function (SyncAPI)
    local player = game.Players.LocalPlayer
    local char = player.Character or player.CharacterAdded:Wait()
    local buildingTools = char:FindFirstChild("Building Tools")
    if not buildingTools then
        Rayfield:Notify({Title = "Error", Content = "Building Tools not found in character", Duration = 5})
        return false
    end
    local syncAPI = buildingTools:FindFirstChild("SyncAPI")
    if not syncAPI then
        Rayfield:Notify({Title = "Error", Content = "SyncAPI not found", Duration = 5})
        return false
    end
    local remote = syncAPI:FindFirstChild("ServerEndpoint")
    if not remote then
        Rayfield:Notify({Title = "Error", Content = "ServerEndpoint not found in SyncAPI", Duration = 5})
        return false
    end

    -- 1. Create part at local plot centre
    local createArgs = {"CreatePart", partType, CFrame.new(localOrigin), localBuildFolder}
    local success, newPart = pcall(function()
        return remote:InvokeServer(unpack(createArgs))
    end)
    if not success or not newPart then
        warn("CreatePart failed for", sourcePart.Name)
        return false
    end

    -- 2. Rotate to match source
    local rotateArgs = {
        "SyncRotate",
        {{Part = newPart, CFrame = targetCFrame}},
        {"AroundPivot", CFrame.new(targetPos), "Center", CFrame.new(targetPos), "Center"}
    }
    pcall(function() remote:InvokeServer(unpack(rotateArgs)) end)

    -- 3. Move to exact position (already correct after rotation but ensures)
    local moveArgs = {
        "SyncMove",
        {{Part = newPart, CFrame = targetCFrame}},
        {"AlongFace", Vector3.new(0,0,0), "Global", targetCFrame}
    }
    pcall(function() remote:InvokeServer(unpack(moveArgs)) end)

    -- 4. Resize to match source
    local resizeArgs = {
        "SyncResize",
        {{Part = newPart, CFrame = targetCFrame, Size = sourcePart.Size}},
        {"ResizeFace", Enum.NormalId.Front, 1, Vector3.zAxis, "Z", sourcePart.Size, "Normal"}
    }
    pcall(function() remote:InvokeServer(unpack(resizeArgs)) end)

    return true
end

-- Main copy function
local function copyBuild(playerDisplayName)
    local privateArea = workspace:FindFirstChild("Private Building Areas")
    if not privateArea then
        Rayfield:Notify({Title = "Error", Content = "Private Building Areas not found!", Duration = 5})
        return
    end

    -- Source (selected player)
    local sourceFolderName = playerMapping[playerDisplayName]
    if not sourceFolderName then
        Rayfield:Notify({Title = "Error", Content = "Source folder not found for " .. playerDisplayName, Duration = 5})
        return
    end
    local sourceBuildArea = privateArea:FindFirstChild(sourceFolderName)
    local sourcePlotPart = getPlotPart(sourceFolderName)
    if not sourceBuildArea or not sourcePlotPart then
        Rayfield:Notify({Title = "Error", Content = "Could not locate source plot or build area", Duration = 5})
        return
    end

    -- Destination (local player)
    local localPlayerName = game.Players.LocalPlayer.Name
    local localFolderName = localPlayerName .. "BuildArea"
    local localBuildArea = privateArea:FindFirstChild(localFolderName)
    local localPlotPart = getPlotPart(localFolderName)
    if not localBuildArea or not localPlotPart then
        Rayfield:Notify({Title = "Error", Content = "Could not locate your plot or build area", Duration = 5})
        return
    end

    -- Build folders (where parts are stored)
    local sourceBuildFolder = sourceBuildArea:FindFirstChild("Build")
    local localBuildFolder = localBuildArea:FindFirstChild("Build")
    if not sourceBuildFolder or not localBuildFolder then
        Rayfield:Notify({Title = "Error", Content = "Build folder missing in source or destination", Duration = 5})
        return
    end

    -- Collect all base parts from source
    local parts = {}
    for _, child in ipairs(sourceBuildFolder:GetChildren()) do
        if child:IsA("BasePart") then
            table.insert(parts, child)
        end
    end
    if #parts == 0 then
        Rayfield:Notify({Title = "Info", Content = "No parts found to copy.", Duration = 5})
        return
    end

    Rayfield:Notify({Title = "Copying", Content = "Copying " .. #parts .. " parts...", Duration = 3})

    local successCount = 0
    for _, part in ipairs(parts) do
        if copyPart(part, sourcePlotPart, localPlotPart, localBuildFolder) then
            successCount = successCount + 1
        end
        task.wait(0.05)  -- small delay to avoid flooding the server
    end

    Rayfield:Notify({
        Title = "Complete",
        Content = "Copied " .. successCount .. "/" .. #parts .. " parts.",
        Duration = 5
    })
end

-- Refresh the dropdown list
local function refreshDropdown()
    local options = refreshPlayerList()
    if dropdownObject then
        dropdownObject:SetOptions(options)
        if options[1] then
            dropdownObject:SetValue(options[1])
            selectedPlayer = options[1]
        else
            selectedPlayer = nil
        end
    end
    if #options == 0 then
        Rayfield:Notify({Title = "Warning", Content = "No player BuildAreas found.", Duration = 5})
    end
end

-- Create dropdown
local initialOptions = refreshPlayerList()
dropdownObject = MainTab:CreateDropdown({
    Name = "Select Player",
    Options = initialOptions,
    CurrentOption = initialOptions[1] or "",
    Callback = function(option)
        selectedPlayer = option
        print("[Build Copier] Selected:", option)
    end
})
if initialOptions[1] then selectedPlayer = initialOptions[1] end

-- Copy button
MainTab:CreateButton({
    Name = "Copy Build",
    Callback = function()
        if selectedPlayer and selectedPlayer ~= "" then
            copyBuild(selectedPlayer)
        else
            Rayfield:Notify({Title = "Error", Content = "Please select a player first.", Duration = 3})
        end
    end
})

-- Refresh button
MainTab:CreateButton({
    Name = "Refresh Player List",
    Callback = function()
        refreshDropdown()
        Rayfield:Notify({Title = "Refreshed", Content = "Player list updated.", Duration = 2})
    end
})

-- Final notification
Rayfield:Notify({
    Title = "Build Copier Ready",
    Content = "Select a player and click 'Copy Build'.",
    Duration = 5
})

print("✅ Build Copier loaded – Rayfield menu should appear.")
