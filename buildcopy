local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Window = Rayfield:CreateWindow({Name = "One Part Copy Test"})
local MainTab = Window:CreateTab("Test")

local selectedPlayer = nil
local playerMapping = {}
local remote = nil

local function getBuildArea(folderName)
    local pa = workspace:FindFirstChild("Private Building Areas")
    return pa and pa:FindFirstChild(folderName)
end

local function refreshPlayers()
    local pa = workspace:FindFirstChild("Private Building Areas")
    if not pa then return {} end
    local opts = {}
    playerMapping = {}
    for _, c in ipairs(pa:GetChildren()) do
        local name = c.Name
        if name:sub(-9) == "BuildArea" then
            local pn = name:sub(1, -10)
            table.insert(opts, pn)
            playerMapping[pn] = name
        end
    end
    return opts
end

local function getRemote()
    if remote then return remote end
    local char = game.Players.LocalPlayer.Character
    if not char then return nil end
    local bt = char:FindFirstChild("Building Tools")
    if not bt then return nil end
    local api = bt:FindFirstChild("SyncAPI")
    if not api then return nil end
    remote = api:FindFirstChild("ServerEndpoint")
    return remote
end

local function testOneClick()
    if not selectedPlayer then
        Rayfield:Notify({Title = "Error", Content = "Select a player first"})
        return
    end

    local srcFolder = playerMapping[selectedPlayer]
    local srcBA = getBuildArea(srcFolder)
    if not srcBA then
        Rayfield:Notify({Title = "Error", Content = "Source BuildArea not found."})
        return
    end

    local srcBuild = srcBA:FindFirstChild("Build")
    if not srcBuild then
        Rayfield:Notify({Title = "Error", Content = "Source Build Folder not found."})
        return
    end

    -- Find first part (any BasePart)
    local sourcePart = nil
    local function findFirstPart(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then
                sourcePart = child
                return true
            elseif child:IsA("Model") then
                if findFirstPart(child) then return true end
            end
        end
        return false
    end
    findFirstPart(srcBuild)

    if not sourcePart then
        Rayfield:Notify({Title = "Error", Content = "No parts found in source build."})
        return
    end

    -- Get your plot reference
    local dstBA = getBuildArea(game.Players.LocalPlayer.Name .. "BuildArea")
    if not dstBA then
        Rayfield:Notify({Title = "Error", Content = "Your BuildArea not found."})
        return
    end

    local dstBuild = dstBA:FindFirstChild("Build")
    if not dstBuild then
        Rayfield:Notify({Title = "Error", Content = "Your Build Folder not found."})
        return
    end

    -- Clear your plot
    for _, p in ipairs(dstBuild:GetChildren()) do
        p:Destroy()
    end

    -- Get remote
    local remoteEndpoint = getRemote()
    if not remoteEndpoint then
        Rayfield:Notify({Title = "Error", Content = "ServerEndpoint not found."})
        return
    end

    -- Calculate offsets (using your previous numbers)
    local xCorrection = -28.637
    local zCorrection = -17.512
    local baseHeight = 3  -- building surface is 3 studs above plot floor

    -- Determine source centre automatically
    local srcCentre = srcBA.Position
    local srcOrigin = srcCentre + Vector3.new(0, baseHeight, 0)
    local dstOrigin = dstBA.Position + Vector3.new(xCorrection, baseHeight, zCorrection)

    local offset = sourcePart.Position - srcOrigin
    local targetPos = dstOrigin + offset
    local targetCF = CFrame.new(targetPos) * (sourcePart.CFrame - sourcePart.CFrame.Position)

    local partType = "Normal" -- part type mapping

    -- Prepare the remote call arguments (as seen in your original working example)
    local argsCreate = {
        "CreatePart",
        partType,
        CFrame.new(dstOrigin),
        dstBuild
    }

    print("=== ATTEMPTING CREATE PART ===")
    local ok, result = pcall(function() 
        return remoteEndpoint:InvokeServer(unpack(argsCreate)) 
    end)

    if not ok then
        warn("CreatePart FAILED:", result)
        Rayfield:Notify({Title = "CreatePart Failed", Content = "Check console for details."})
        return
    end

    print("CreatePart SUCCESS:", result)
    local newPart = result
    if not newPart:IsA("BasePart") then
        newPart = dstBuild:FindFirstChild(sourcePart.Name)
    end

    -- SyncRotate
    local pivot = targetCF - targetCF.Position
    local rotArgs = {"SyncRotate", {{Part = newPart, CFrame = targetCF}}, {"AroundPivot", pivot, "Center", CFrame.new(dstOrigin), "Center"}}
    pcall(function() remoteEndpoint:InvokeServer(unpack(rotArgs)) end)
    print("Rotate attempted")

    -- SyncMove
    local delta = targetPos - dstOrigin
    local moveArgs = {"SyncMove", {{Part = newPart, CFrame = CFrame.new(targetPos)}}, {"AlongFace", delta, "Global", CFrame.new(targetPos)}}
    pcall(function() remoteEndpoint:InvokeServer(unpack(moveArgs)) end)
    print("Move attempted")

    -- SyncResize
    local resizeArgs = {"SyncResize", {{Part = newPart, CFrame = CFrame.new(targetPos), Size = sourcePart.Size}}, {"ResizeFace", Enum.NormalId.Front, 0, Vector3.zero, "Z", sourcePart.Size, "Normal"}}
    pcall(function() remoteEndpoint:InvokeServer(unpack(resizeArgs)) end)
    print("Resize attempted")

    Rayfield:Notify({ Title = "Test Complete", Content = "Part created. Check its position/rotation/size." })
end

-- Build UI
local initOpts = refreshPlayers()
local dropdown = MainTab:CreateDropdown({
    Name = "Select Player",
    Options = initOpts,
    CurrentOption = initOpts[1] or "",
    Callback = function(opt) selectedPlayer = opt end
})
MainTab:CreateButton({ Name = "Test One Part", Callback = testOneClick })

Rayfield:Notify({ Title = "Ready", Content = "Select a player, then click 'Test One Part'." })
