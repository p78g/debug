MainTab:CreateSection("Player Selection")
local selectedPlayer = nil
local playerMapping = {}
local dropdown = nil

local function getBuildArea(folderName)
    local pa = workspace:FindFirstChild("Private Building Areas")
    return pa and pa:FindFirstChild(folderName)
end

local function refreshPlayers()
    local pa = workspace:FindFirstChild("Private Building Areas")
    if not pa then return {} end
    local opts = {}
    playerMapping = {}
    for _, c in ipairs(pa:GetChildren()) do
        local name = c.Name
        if name:sub(-9) == "BuildArea" then
            local pn = name:sub(1, -10)
            table.insert(opts, pn)
            playerMapping[pn] = name
        end
    end
    return opts
end

local remote = nil
local function getRemote()
    if remote then return remote end
    local char = game.Players.LocalPlayer.Character
    if not char then return nil end
    local bt = char:FindFirstChild("Building Tools")
    if not bt then return nil end
    local api = bt:FindFirstChild("SyncAPI")
    if not api then return nil end
    remote = api:FindFirstChild("ServerEndpoint")
    return remote
end

local function vec(v) return vector.create(v.X, v.Y, v.Z) end

-- Clear your plot's Build folder
local function clearLocalBuild()
    local localName = game.Players.LocalPlayer.Name .. "BuildArea"
    local localBA = getBuildArea(localName)
    if localBA and localBA:FindFirstChild("Build") then
        for _, p in ipairs(localBA.Build:GetChildren()) do p:Destroy() end
        print("[DEBUG] Cleared local Build folder")
    end
end

-- Compute centre of source build (average of all part positions, recursive)
local function computeSourceCentre(buildArea)
    local buildFolder = buildArea:FindFirstChild("Build")
    if not buildFolder then return buildArea.Position end
    local parts = {}
    local function collect(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then
                table.insert(parts, child)
            elseif child:IsA("Model") then
                collect(child)
            end
        end
    end
    collect(buildFolder)
    if #parts == 0 then return buildArea.Position end
    local sum = Vector3.new(0,0,0)
    for _, p in ipairs(parts) do sum = sum + p.Position end
    local centre = sum / #parts
    print("[DEBUG] Source centre (average of parts):", centre)
    return centre
end

-- Place a marker
local function placeMarker(pos, color, name)
    local m = Instance.new("Part")
    m.Size = Vector3.new(1,1,1)
    m.Color = color
    m.Material = Enum.Material.Neon
    m.Position = pos
    m.Anchored = true
    m.CanCollide = false
    m.Name = name or "Marker"
    m.Parent = workspace
    game:GetService("Debris"):AddItem(m, 10)
end

-- Copy a single part (the first part found)
local function copyOnePart()
    if not selectedPlayer then
        Rayfield:Notify({Title = "Error", Content = "Select a player"})
        return
    end

    local srcFolder = playerMapping[selectedPlayer]
    local srcBA = getBuildArea(srcFolder)
    local dstBA = getBuildArea(game.Players.LocalPlayer.Name .. "BuildArea")
    if not srcBA or not dstBA then
        Rayfield:Notify({Title = "Error", Content = "BuildAreas missing"})
        return
    end

    local srcBuild = srcBA:FindFirstChild("Build")
    if not srcBuild then
        Rayfield:Notify({Title = "Error", Content = "Source has no Build folder"})
        return
    end

    -- Find first BasePart (anywhere inside Build folder)
    local sourcePart = nil
    local function findFirstPart(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then
                sourcePart = child
                return true
            elseif child:IsA("Model") then
                if findFirstPart(child) then return true end
            end
        end
        return false
    end
    if not findFirstPart(srcBuild) then
        Rayfield:Notify({Title = "Error", Content = "No parts found in source"})
        return
    end

    -- Determine part type
    local partTypeMap = {
        Part = "Normal", Truss = "Truss", Wedge = "Wedge", Corner = "Corner",
        Cylinder = "Cylinder", Ball = "Ball", Seat = "Seat",
        ["Vehicle Seat"] = "Vehicle Seat", Spawn = "Spawn"
    }
    local partType = partTypeMap[sourcePart.Name] or "Normal"

    -- Compute source centre (auto-centre) and origin (3 studs above centre)
    local srcCentre = computeSourceCentre(srcBA)
    local finalY = 3 + yExtra  -- base building height + extra
    local srcOrigin = srcCentre + Vector3.new(0, finalY, 0)
    local dstOrigin = dstBA.Position + Vector3.new(xOffset, finalY, zOffset)

    -- Relative offset from source origin to source part
    local offset = sourcePart.Position - srcOrigin
    local targetPos = dstOrigin + offset

    -- Target CFrame with rotation
    local targetCFrame = CFrame.new(targetPos) * (sourcePart.CFrame - sourcePart.CFrame.Position)

    print("===== COPY ONE PART DEBUG =====")
    print("Source part:", sourcePart.Name, "Position:", sourcePart.Position)
    print("Source centre (auto):", srcCentre)
    print("Source origin (centre + 3 + yExtra):", srcOrigin)
    print("Offset from origin to part:", offset)
    print("Your BuildArea position:", dstBA.Position)
    print("Destination origin (your BuildArea + offsets):", dstOrigin)
    print("Calculated target position:", targetPos)
    print("Target CFrame (with rotation):", targetCFrame)
    print("Part size:", sourcePart.Size)
    print("Part type:", partType)

    -- Place green marker at destination origin (where creation happens)
    placeMarker(dstOrigin, Color3.fromRGB(0,255,0), "OriginMarker")
    -- Place red marker at target position
    placeMarker(targetPos, Color3.fromRGB(255,0,0), "TargetMarker")

    local r = getRemote()
    if not r then
        Rayfield:Notify({Title = "Error", Content = "No remote"})
        return
    end

    -- Clear local build to avoid name conflicts
    clearLocalBuild()
    task.wait(0.5)

    -- Create part
    local createArgs = {"CreatePart", partType, CFrame.new(dstOrigin), dstBuild}
    print("CreatePart args:", createArgs)
    local ok, newPart = pcall(function() return r:InvokeServer(unpack(createArgs)) end)
    if not ok or not newPart then
        warn("CreatePart failed:", ok, newPart)
        Rayfield:Notify({Title = "Error", Content = "CreatePart failed"})
        return
    end
    print("CreatePart returned:", newPart, "type:", typeof(newPart))
    task.wait(0.2)

    -- Locate the part
    local actualPart = newPart
    if not actualPart:IsA("BasePart") then
        actualPart = dstBuild:FindFirstChild(sourcePart.Name)
    end
    if not actualPart then
        warn("Could not locate created part")
        Rayfield:Notify({Title = "Error", Content = "Part not found after creation"})
        return
    end
    print("Actual part located:", actualPart, "Position:", actualPart.Position)

    -- Rotate
    local pivotCFrame = targetCFrame - targetCFrame.Position
    local currentCFrame = CFrame.new(dstOrigin)
    local rotArgs = {
        "SyncRotate",
        { { Part = actualPart, CFrame = targetCFrame } },
        { "AroundPivot", pivotCFrame, "Center", currentCFrame, "Center" }
    }
    print("Rotate args:", rotArgs)
    pcall(function() r:InvokeServer(unpack(rotArgs)) end)
    task.wait(0.5)

    -- Move
    local delta = targetPos - dstOrigin
    local moveArgs = {
        "SyncMove",
        { { Part = actualPart, CFrame = CFrame.new(targetPos) } },
        { "AlongFace", vec(delta), "Global", CFrame.new(targetPos) }
    }
    print("Move args:", moveArgs)
    pcall(function() r:InvokeServer(unpack(moveArgs)) end)
    task.wait(0.5)

    -- Resize
    local resizeArgs = {
        "SyncResize",
        { { Part = actualPart, CFrame = CFrame.new(targetPos), Size = vec(sourcePart.Size) } },
        { "ResizeFace", Enum.NormalId.Front, 1, vec(Vector3.new(0,0,0)), "Z", sourcePart.Size, "Normal" }
    }
    print("Resize args:", resizeArgs)
    pcall(function() r:InvokeServer(unpack(resizeArgs)) end)

    Rayfield:Notify({Title = "Done", Content = "Check markers and part position"})
    print("===== END DEBUG =====")
end

