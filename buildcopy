-- =============================================
-- TOWN BUILD COPIER – FIXED ROTATE, MOVE, RESIZE
-- Uses exact remote call structures
-- =============================================

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Town Copier – Fixed",
    Theme = "Default",
})

local Tab = Window:CreateTab("Copier", "hammer")

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

local BUILDING_AREAS = workspace:WaitForChild("Private Building Areas")

local function getRemote()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local tool = char:WaitForChild("Building Tools", 5)
    if not tool then error("Equip Building Tools!") end
    return tool:WaitForChild("SyncAPI"):WaitForChild("ServerEndpoint")
end

local localBuildArea = BUILDING_AREAS:WaitForChild(LocalPlayer.Name .. "BuildArea")
local localBuildFolder = localBuildArea:WaitForChild("Build")

local BASE_Y = 4
local X_OFFSET = -28.637
local Z_OFFSET = -17.512
local selectedPlayer = nil
local playerOptions = {}

local function refreshPlayers()
    playerOptions = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and BUILDING_AREAS:FindFirstChild(plr.Name .. "BuildArea") then
            table.insert(playerOptions, plr.Name)
        end
    end
end
refreshPlayers()

Tab:CreateSection("Player")
local Dropdown = Tab:CreateDropdown({
    Name = "Select Player to Copy From",
    Options = playerOptions,
    CurrentOption = {},
    MultipleOptions = false,
    Callback = function(Option)
        selectedPlayer = (typeof(Option) == "table" and #Option > 0) and Players:FindFirstChild(Option[1]) or nil
    end,
})

Tab:CreateSection("Offsets")
Tab:CreateSlider({ Name = "X Offset", Range = {-100, 100}, Increment = 0.01, CurrentValue = X_OFFSET, Callback = function(v) X_OFFSET = v end })
Tab:CreateSlider({ Name = "Z Offset", Range = {-100, 100}, Increment = 0.01, CurrentValue = Z_OFFSET, Callback = function(v) Z_OFFSET = v end })

-- Helper: convert Vector3 to vector.create (used by server)
local function vec(v) return vector.create(v.X, v.Y, v.Z) end

Tab:CreateButton({
    Name = "🔄 Copy Build (Fixed Remote Calls)",
    Description = "Full rotation, position, size exact",
    Callback = function()
        if not selectedPlayer then
            Rayfield:Notify({Title = "Error", Content = "Select player!"}) 
            return 
        end

        local remote = getRemote()
        local sourceArea = BUILDING_AREAS:FindFirstChild(selectedPlayer.Name .. "BuildArea")
        if not sourceArea then return Rayfield:Notify({Title = "Error", Content = "Source not found"}) end

        local sourceBuild = sourceArea:WaitForChild("Build")

        -- Collect all BaseParts (flatten models)
        local allParts = {}
        for _, v in ipairs(sourceBuild:GetDescendants()) do
            if v:IsA("BasePart") then table.insert(allParts, v) end
        end

        if #allParts == 0 then
            Rayfield:Notify({Title = "Error", Content = "No parts found"}) 
            return 
        end

        -- Auto‑centre (average of source part positions)
        local sum = Vector3.zero
        for _, p in ipairs(allParts) do sum = sum + p.Position end
        local sourceCenter = sum / #allParts

        local destOrigin = localBuildArea.Position + Vector3.new(X_OFFSET, BASE_Y, Z_OFFSET)

        Rayfield:Notify({Title = "Copying...", Content = #allParts .. " parts", Duration = 6})

        local createdParts = {}

        for _, sourcePart in ipairs(allParts) do
            -- 1. Determine part type from Name (as in your raw logs)
            local partType = "Normal"
            local name = sourcePart.Name
            if name == "Truss" then partType = "Truss"
            elseif name == "Wedge" then partType = "Wedge"
            elseif name == "Corner" then partType = "Corner"
            elseif name == "Cylinder" then partType = "Cylinder"
            elseif name == "Ball" then partType = "Ball"
            elseif name == "Seat" then partType = "Seat"
            elseif name == "Vehicle Seat" then partType = "Vehicle Seat"
            elseif name == "Spawn" then partType = "Spawn"
            end

            -- 2. Compute offset from source centre and target position
            local offset = sourcePart.Position - sourceCenter
            local targetPos = destOrigin + offset
            local targetCFrame = CFrame.new(targetPos) * (sourcePart.CFrame - sourcePart.CFrame.Position)

            -- 3. Create part at destination origin (centre of your plot + offsets)
            local createArgs = {"CreatePart", partType, CFrame.new(destOrigin), localBuildFolder}
            local ok, newPart = pcall(function() return remote:InvokeServer(unpack(createArgs)) end)
            if not ok or not newPart then
                warn("CreatePart failed for", sourcePart.Name)
                goto continue
            end
            task.wait(0.1)

            -- Ensure we have the part instance
            local actualPart = newPart:IsA("BasePart") and newPart or localBuildFolder:FindFirstChild(sourcePart.Name)
            if not actualPart then
                warn("Could not locate created part:", sourcePart.Name)
                goto continue
            end
            table.insert(createdParts, actualPart)

            -- 4. SyncRotate – exact structure from raw log
            local pivotCFrame = targetCFrame - targetCFrame.Position
            local currentCFrame = CFrame.new(destOrigin)
            local rotArgs = {
                "SyncRotate",
                { { Part = actualPart, CFrame = targetCFrame } },
                { "AroundPivot", pivotCFrame, "Center", currentCFrame, "Center" }
            }
            pcall(function() remote:InvokeServer(unpack(rotArgs)) end)
            task.wait(0.5)

            -- 5. SyncMove – exact structure from raw log
            local delta = targetPos - destOrigin
            local moveArgs = {
                "SyncMove",
                { { Part = actualPart, CFrame = CFrame.new(targetPos) } },
                { "AlongFace", vec(delta), "Global", CFrame.new(targetPos) }
            }
            pcall(function() remote:InvokeServer(unpack(moveArgs)) end)
            task.wait(0.5)

            -- 6. SyncResize – exact structure (using dummy ResizeFace, server applies Size from first table)
            local resizeArgs = {
                "SyncResize",
                { { Part = actualPart, CFrame = CFrame.new(targetPos), Size = vec(sourcePart.Size) } },
                { "ResizeFace", Enum.NormalId.Front, 1, vec(Vector3.zero), "Z", sourcePart.Size, "Normal" }
            }
            pcall(function() remote:InvokeServer(unpack(resizeArgs)) end)
            task.wait(0.5)

            ::continue::
        end

        -- Optional: group copied parts into a Model (mirror source grouping? Not required for basic copy)
        if #createdParts > 0 then
            -- You can call CreateGroup if you want to group them all; otherwise skip.
            -- remote:InvokeServer("CreateGroup", "Model", localBuildFolder, createdParts)
        end

        Rayfield:Notify({Title = "Finished", Content = #createdParts .. " parts copied", Duration = 8})
    end,
})

Tab:CreateButton({ Name = "Refresh Player List", Callback = function()
    refreshPlayers()
    Dropdown:SetOptions(playerOptions)
    if #playerOptions > 0 then Dropdown:SetValue({playerOptions[1]}) end
end })

Rayfield:Notify({Title = "Fixed Version Loaded", Content = "Uses exact remote call structures", Duration = 8})
