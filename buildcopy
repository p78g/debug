-- BUILD COPIER – Auto Centre Detection (Radar)
-- Scans source build, computes centre from all parts
-- =============================================

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Build Copier",
    ConfigurationSaving = { Enabled = true, FolderName = "BuildCopier" },
    Theme = "Default",
})

local MainTab = Window:CreateTab("Copy Build")
MainTab:CreateSection("Alignment")

local useAutoCentre = true
local manualX = 0
local manualZ = 0
local manualY = 0

MainTab:CreateToggle({
    Name = "Auto-detect plot centre (recommended)",
    CurrentValue = true,
    Callback = function(v) useAutoCentre = v end
})

MainTab:CreateSlider({ Name = "Manual X Offset", Range = {-50, 50}, Increment = 1, CurrentValue = 0, Callback = function(v) manualX = v end })
MainTab:CreateSlider({ Name = "Manual Z Offset", Range = {-50, 50}, Increment = 1, CurrentValue = 0, Callback = function(v) manualZ = v end })
MainTab:CreateSlider({ Name = "Manual Y Offset", Range = {-5, 5}, Increment = 0.5, CurrentValue = 0, Callback = function(v) manualY = v end })

MainTab:CreateSection("Player Selection")

local selectedPlayer = nil
local playerMapping = {}
local dropdown = nil

local function getBuildArea(folderName)
    local pa = workspace:FindFirstChild("Private Building Areas")
    return pa and pa:FindFirstChild(folderName)
end

local function refreshPlayers()
    local pa = workspace:FindFirstChild("Private Building Areas")
    if not pa then return {} end
    local opts = {}
    playerMapping = {}
    for _, c in ipairs(pa:GetChildren()) do
        local name = c.Name
        if name:sub(-9) == "BuildArea" then
            local pn = name:sub(1, -10)
            table.insert(opts, pn)
            playerMapping[pn] = name
        end
    end
    return opts
end

local function clearLocalBuild()
    local localName = game.Players.LocalPlayer.Name .. "BuildArea"
    local localBA = getBuildArea(localName)
    if localBA and localBA:FindFirstChild("Build") then
        for _, p in ipairs(localBA.Build:GetChildren()) do p:Destroy() end
        Rayfield:Notify({Title = "Cleared", Content = "Your build cleared."})
    end
end

-- Auto centre: average of all part positions in the Build folder (recursive)
local function computeCentre(buildArea)
    local buildFolder = buildArea:FindFirstChild("Build")
    if not buildFolder then return buildArea.Position end
    local parts = {}
    local function collect(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then
                table.insert(parts, child)
            elseif child:IsA("Model") then
                collect(child)
            end
        end
    end
    collect(buildFolder)
    if #parts == 0 then return buildArea.Position end
    local sum = Vector3.new(0,0,0)
    for _, p in ipairs(parts) do sum = sum + p.Position end
    return sum / #parts
end

-- Ghost preview
local ghostModel = nil
local function showGhost()
    if ghostModel then ghostModel:Destroy() end
    if not selectedPlayer then Rayfield:Notify({Title = "Error", Content = "Select a player."}) return end
    local srcFolder = playerMapping[selectedPlayer]
    local srcBA = getBuildArea(srcFolder)
    local dstBA = getBuildArea(game.Players.LocalPlayer.Name .. "BuildArea")
    if not srcBA or not dstBA then return end
    local srcBuild = srcBA:FindFirstChild("Build")
    if not srcBuild then return end

    local srcCentre = computeCentre(srcBA)
    local dstCentre = dstBA.Position
    if not useAutoCentre then dstCentre = dstCentre + Vector3.new(manualX, manualY, manualZ) end

    local buildHeight = 3
    local srcOrigin = srcCentre + Vector3.new(0, buildHeight, 0)
    local dstOrigin = dstCentre + Vector3.new(0, buildHeight, 0)

    ghostModel = Instance.new("Model")
    ghostModel.Name = "GhostPreview"

    local function cloneParts(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then
                local offset = child.Position - srcOrigin
                local targetPos = dstOrigin + offset
                local clone = child:Clone()
                clone.Position = targetPos
                clone.CFrame = CFrame.new(targetPos) * (child.CFrame - child.CFrame.Position)
                clone.Anchored = true
                clone.CanCollide = false
                clone.Transparency = 0.7
                clone.Material = Enum.Material.ForceField
                clone.Parent = ghostModel
            elseif child:IsA("Model") then
                cloneParts(child)
            end
        end
    end
    cloneParts(srcBuild)
    ghostModel.Parent = workspace
    Rayfield:Notify({Title = "Ghost", Content = "Preview shown. Adjust offsets if needed."})
end

local function hideGhost()
    if ghostModel then ghostModel:Destroy() end
end

-- Real copy using exact remote structures
local remote = nil
local function getRemote()
    if remote then return remote end
    local char = game.Players.LocalPlayer.Character
    if not char then return nil end
    local bt = char:FindFirstChild("Building Tools")
    if not bt then return nil end
    local api = bt:FindFirstChild("SyncAPI")
    if not api then return nil end
    remote = api:FindFirstChild("ServerEndpoint")
    return remote
end

local function copySinglePart(part, srcOrigin, dstOrigin, dstBuild)
    local typeMap = { Part = "Normal", Truss = "Truss", Wedge = "Wedge", Corner = "Corner", Cylinder = "Cylinder", Ball = "Ball", Seat = "Seat", ["Vehicle Seat"] = "Vehicle Seat", Spawn = "Spawn" }
    local partType = typeMap[part.Name] or "Normal"
    local offset = part.Position - srcOrigin
    local targetPos = dstOrigin + offset
    local targetCFrame = CFrame.new(targetPos) * (part.CFrame - part.CFrame.Position)
    local r = getRemote()
    if not r then return nil end

    local createArgs = {"CreatePart", partType, CFrame.new(dstOrigin), dstBuild}
    local ok, newPart = pcall(function() return r:InvokeServer(unpack(createArgs)) end)
    if not ok or not newPart then return nil end
    task.wait(0.1)
    local actual = newPart
    if not actual:IsA("BasePart") then actual = dstBuild:FindFirstChild(part.Name) end
    if not actual then return nil end

    local pivot = targetCFrame - targetCFrame.Position
    local cur = CFrame.new(dstOrigin)
    local rotArgs = {"SyncRotate", {{Part = actual, CFrame = targetCFrame}}, {"AroundPivot", pivot, "Center", cur, "Center"}}
    pcall(function() r:InvokeServer(unpack(rotArgs)) end)
    task.wait(0.1)
    local delta = targetPos - dstOrigin
    local moveArgs = {"SyncMove", {{Part = actual, CFrame = CFrame.new(targetPos)}}, {"AlongFace", delta, "Global", CFrame.new(targetPos)}}
    pcall(function() r:InvokeServer(unpack(moveArgs)) end)
    task.wait(0.1)
    local resizeArgs = {"SyncResize", {{Part = actual, CFrame = CFrame.new(targetPos), Size = part.Size}}, {"ResizeFace", Enum.NormalId.Front, 1, Vector3.new(0,0,0), "Z", part.Size, "Normal"}}
    pcall(function() r:InvokeServer(unpack(resizeArgs)) end)
    return actual
end

local function copyReal()
    if not selectedPlayer then Rayfield:Notify({Title = "Error", Content = "Select a player."}) return end
    hideGhost()
    clearLocalBuild()
    task.wait(0.5)
    local srcFolder = playerMapping[selectedPlayer]
    local srcBA = getBuildArea(srcFolder)
    local dstBA = getBuildArea(game.Players.LocalPlayer.Name .. "BuildArea")
    if not srcBA or not dstBA then Rayfield:Notify({Title = "Error", Content = "BuildAreas missing."}) return end
    local srcBuild = srcBA:FindFirstChild("Build")
    local dstBuild = dstBA:FindFirstChild("Build")
    if not srcBuild or not dstBuild then Rayfield:Notify({Title = "Error", Content = "Build folders missing."}) return end

    local srcCentre = computeCentre(srcBA)
    local dstCentre = dstBA.Position
    if not useAutoCentre then dstCentre = dstCentre + Vector3.new(manualX, manualY, manualZ) end
    local buildHeight = 3
    local srcOrigin = srcCentre + Vector3.new(0, buildHeight, 0)
    local dstOrigin = dstCentre + Vector3.new(0, buildHeight, 0)

    local allParts = {}
    local function collect(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then table.insert(allParts, child)
            elseif child:IsA("Model") then collect(child) end
        end
    end
    collect(srcBuild)
    if #allParts == 0 then Rayfield:Notify({Title = "Info", Content = "No parts."}) return end
    Rayfield:Notify({Title = "Copying", Content = #allParts .. " parts..."})
    local success = 0
    for _, p in ipairs(allParts) do
        if copySinglePart(p, srcOrigin, dstOrigin, dstBuild) then success = success + 1 end
        task.wait(0.05)
    end
    Rayfield:Notify({Title = "Done", Content = success .. "/" .. #allParts .. " parts copied."})
end

