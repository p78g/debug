local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Build Copier",
    LoadingTitle = "Build Copier",
    ConfigurationSaving = { Enabled = true, FolderName = "BuildCopier", FileName = "Settings" },
    Theme = "Default",
})

local MainTab = Window:CreateTab("Copy Build", "Copy")
MainTab:CreateSection("Player Selection")

local selectedPlayer = nil
local playerMapping = {}
local dropdownObject = nil

-- Helper: get the plot’s root part (respects rotation)
local function getPlotPart(plotFolderName)
    local privateArea = workspace:FindFirstChild("Private Building Areas")
    if not privateArea then return nil end
    local obj = privateArea:FindFirstChild(plotFolderName)
    if not obj then return nil end
    if obj:IsA("BasePart") then return obj end
    if obj:IsA("Model") then
        if obj.PrimaryPart then return obj.PrimaryPart end
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then return child end
        end
    end
    return nil
end

-- Clear all parts from local Build folder
local function clearLocalBuild()
    local privateArea = workspace:FindFirstChild("Private Building Areas")
    if not privateArea then return false end
    local localFolder = game.Players.LocalPlayer.Name .. "BuildArea"
    local localBuildArea = privateArea:FindFirstChild(localFolder)
    if not localBuildArea then return false end
    local buildFolder = localBuildArea:FindFirstChild("Build")
    if not buildFolder then return false end

    local count = 0
    for _, child in ipairs(buildFolder:GetChildren()) do
        if child:IsA("BasePart") then
            child:Destroy()
            count = count + 1
        end
    end
    Rayfield:Notify({ Title = "Cleared", Content = "Removed " .. count .. " parts from your plot.", Duration = 3 })
    return true
end

-- Refresh player list
local function refreshPlayerList()
    local privateArea = workspace:FindFirstChild("Private Building Areas")
    if not privateArea then return {} end
    local options = {}
    playerMapping = {}
    for _, child in ipairs(privateArea:GetChildren()) do
        local name = child.Name
        if name:sub(-9) == "BuildArea" then
            local pName = name:sub(1, -10)
            table.insert(options, pName)
            playerMapping[pName] = name
        end
    end
    return options
end

-- Core copy function (with detailed logs)
local function copyPart(sourcePart, sourcePlotPart, localPlotPart, localBuildFolder)
    -- Part type mapping
    local typeMap = {
        Part = "Normal", Truss = "Truss", Wedge = "Wedge", Corner = "Corner",
        Cylinder = "Cylinder", Ball = "Ball", Seat = "Seat",
        ["Vehicle Seat"] = "Vehicle Seat", Spawn = "Spawn"
    }
    local partType = typeMap[sourcePart.Name] or "Normal"

    -- Use CFrame for origin (respects plot rotation)
    local sourceOriginCF = sourcePlotPart.CFrame * CFrame.new(0, 3, 0)
    local localOriginCF = localPlotPart.CFrame * CFrame.new(0, 3, 0)

    -- Relative offset in world space (source part position relative to source origin)
    local relativeOffset = sourcePlotPart.CFrame:Inverse() * sourcePart.CFrame.Position
    local targetPos = localPlotPart.CFrame * relativeOffset + Vector3.new(0, 3, 0)

    -- Preserve rotation relative to the plot
    local sourceRot = sourcePart.CFrame - sourcePart.CFrame.Position
    local targetCFrame = CFrame.new(targetPos) * (sourceRot)

    print(string.format("[COPY] %s | Type: %s | Rel: (%.2f,%.2f,%.2f) | Target: (%.2f,%.2f,%.2f)",
        sourcePart.Name, partType, relativeOffset.X, relativeOffset.Y, relativeOffset.Z,
        targetPos.X, targetPos.Y, targetPos.Z))

    -- Get remote
    local char = game.Players.LocalPlayer.Character
    if not char then return false end
    local buildingTools = char:FindFirstChild("Building Tools")
    if not buildingTools then return false end
    local syncAPI = buildingTools:FindFirstChild("SyncAPI")
    if not syncAPI then return false end
    local remote = syncAPI:FindFirstChild("ServerEndpoint")
    if not remote then return false end

    -- Create part
    local createArgs = {"CreatePart", partType, localOriginCF, localBuildFolder}
    local success, newPart = pcall(function() return remote:InvokeServer(unpack(createArgs)) end)
    if not success or not newPart then
        warn("CreatePart failed for " .. sourcePart.Name)
        return false
    end
    task.wait(0.1)

    -- Locate actual part
    local actualPart = newPart
    if not actualPart:IsA("BasePart") then
        actualPart = localBuildFolder:FindFirstChild(sourcePart.Name)
    end
    if not actualPart then return false end

    -- Rotate
    local rotArgs = {"SyncRotate", {{Part = actualPart, CFrame = targetCFrame}}, {}}
    pcall(function() remote:InvokeServer(unpack(rotArgs)) end)
    task.wait(0.1)

    -- Move
    local moveArgs = {"SyncMove", {{Part = actualPart, CFrame = CFrame.new(targetPos)}}, {}}
    pcall(function() remote:InvokeServer(unpack(moveArgs)) end)
    task.wait(0.1)

    -- Resize
    local resizeArgs = {
        "SyncResize",
        {{Part = actualPart, CFrame = CFrame.new(targetPos), Size = sourcePart.Size}},
        {"ResizeFace", Enum.NormalId.Front, 1, Vector3.zAxis, "Z", sourcePart.Size, "Normal"}
    }
    pcall(function() remote:InvokeServer(unpack(resizeArgs)) end)

    return true
end

-- Main copy function
local function copyBuild(playerDisplayName)
    local privateArea = workspace:FindFirstChild("Private Building Areas")
    if not privateArea then
        Rayfield:Notify({Title = "Error", Content = "Private Building Areas not found!", Duration = 5})
        return
    end

    local sourceFolder = playerMapping[playerDisplayName]
    if not sourceFolder then
        Rayfield:Notify({Title = "Error", Content = "Source folder not found!", Duration = 5})
        return
    end

    local sourceBuildArea = privateArea:FindFirstChild(sourceFolder)
    local sourcePlot = getPlotPart(sourceFolder)
    if not sourceBuildArea or not sourcePlot then
        Rayfield:Notify({Title = "Error", Content = "Source plot missing!", Duration = 5})
        return
    end

    local localPlayerName = game.Players.LocalPlayer.Name
    local localFolder = localPlayerName .. "BuildArea"
    local localBuildArea = privateArea:FindFirstChild(localFolder)
    local localPlot = getPlotPart(localFolder)
    if not localBuildArea or not localPlot then
        Rayfield:Notify({Title = "Error", Content = "Your plot missing!", Duration = 5})
        return
    end

    local sourceBuild = sourceBuildArea:FindFirstChild("Build")
    local localBuild = localBuildArea:FindFirstChild("Build")
    if not sourceBuild or not localBuild then
        Rayfield:Notify({Title = "Error", Content = "Build folders missing!", Duration = 5})
        return
    end

    -- Collect parts
    local parts = {}
    for _, v in ipairs(sourceBuild:GetChildren()) do
        if v:IsA("BasePart") then table.insert(parts, v) end
    end
    if #parts == 0 then
        Rayfield:Notify({Title = "Info", Content = "No parts found to copy.", Duration = 5})
        return
    end

    Rayfield:Notify({Title = "Copying", Content = "Copying " .. #parts .. " parts...", Duration = 3})

    local successCount = 0
    for _, part in ipairs(parts) do
        if copyPart(part, sourcePlot, localPlot, localBuild) then
            successCount = successCount + 1
        end
        task.wait(0.05)
    end

    Rayfield:Notify({Title = "Complete", Content = successCount .. "/" .. #parts .. " parts copied.", Duration = 5})
end

-- Dropdown refresh
local function refreshDropdown()
    local options = refreshPlayerList()
    if dropdownObject then
        dropdownObject:SetOptions(options)
        if options[1] then
            dropdownObject:SetValue(options[1])
            selectedPlayer = options[1]
        end
    end
    if #options == 0 then
        Rayfield:Notify({Title = "Warning", Content = "No player BuildAreas found.", Duration = 5})
    end
end

-- Build UI
local initialOptions = refreshPlayerList()
dropdownObject = MainTab:CreateDropdown({
    Name = "Select Player",
    Options = initialOptions,
    CurrentOption = initialOptions[1] or "",
    Callback = function(opt) selectedPlayer = opt end
})
if initialOptions[1] then selectedPlayer = initialOptions[1] end

MainTab:CreateButton({
    Name = "Clear Your Build",
    Callback = function()
        clearLocalBuild()
    end
})

MainTab:CreateButton({
    Name = "Copy Build",
    Callback = function()
        if not selectedPlayer then
            Rayfield:Notify({Title = "Error", Content = "Select a player first.", Duration = 3})
            return
        end
        task.spawn(function() copyBuild(selectedPlayer) end)
    end
})

MainTab:CreateButton({
    Name = "Refresh Player List",
    Callback = function()
        refreshDropdown()
        Rayfield:Notify({Title = "Refreshed", Content = "Player list updated.", Duration = 2})
    end
})

Rayfield:Notify({Title = "Build Copier Ready", Content = "Use 'Clear Your Build' before copying to avoid errors.", Duration = 5})
print("✅ Build Copier loaded – fixed positioning and clearing.")
