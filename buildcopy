MainTab:CreateSection("Manual Offsets (studs)")

local xOffset = 0
local zOffset = 0
local yExtra = 0

MainTab:CreateSlider({ Name = "X Offset (left/right)", Range = {-100, 100}, Increment = 1, CurrentValue = 0, Callback = function(v) xOffset = v end })
MainTab:CreateSlider({ Name = "Z Offset (forward/back)", Range = {-100, 100}, Increment = 1, CurrentValue = 0, Callback = function(v) zOffset = v end })
