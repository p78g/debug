local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Town Copier - Advanced",
    LoadingTitle = "Initializing...",
    Theme = "Default"
})

local Tab = Window:CreateTab("Copier", "hammer")
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer
local BUILDING_AREAS = Workspace:WaitForChild("Private Building Areas")

local function getRemote()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local tool = char:WaitForChild("Building Tools", 5)
    if not tool then error("Equip Building Tools!") end
    return tool:WaitForChild("SyncAPI"):WaitForChild("ServerEndpoint")
end

local localBuildArea = BUILDING_AREAS:WaitForChild(LocalPlayer.Name .. "BuildArea")
local localBuildFolder = localBuildArea:WaitForChild("Build")

local X_OFFSET, Z_OFFSET = -28.637, -17.512
local selectedPlayer = nil
local playerOptions = {}

local function refreshPlayers()
    playerOptions = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and BUILDING_AREAS:FindFirstChild(plr.Name .. "BuildArea") then
            table.insert(playerOptions, plr.Name)
        end
    end
end
refreshPlayers()

Tab:CreateDropdown({
    Name = "Select Player",
    Options = playerOptions,
    Callback = function(Option)
        selectedPlayer = Players:FindFirstChild(Option[1])
    end,
})

Tab:CreateSlider({ Name = "X Offset", Range = {-100, 100}, Increment = 0.1, CurrentValue = X_OFFSET, Callback = function(v) X_OFFSET = v end })
Tab:CreateSlider({ Name = "Z Offset", Range = {-100, 100}, Increment = 0.1, CurrentValue = Z_OFFSET, Callback = function(v) Z_OFFSET = v end })

Tab:CreateButton({
    Name = "Copy Build",
    Callback = function()
        if not selectedPlayer then return end
        local remote = getRemote()
        local sourceBuild = BUILDING_AREAS:FindFirstChild(selectedPlayer.Name .. "BuildArea"):WaitForChild("Build")
        local allParts = {}
        for _, v in ipairs(sourceBuild:GetDescendants()) do if v:IsA("BasePart") then table.insert(allParts, v) end end

        local sumX, sumY, sumZ = 0, 0, 0
        for _, p in ipairs(allParts) do sumX += p.Position.X; sumY += p.Position.Y; sumZ += p.Position.Z end
        local sourceCenter = Vector3.new(sumX/#allParts, sumY/#allParts, sumZ/#allParts)
        local destOrigin = localBuildArea.Position + Vector3.new(X_OFFSET, 4, Z_OFFSET)

        local createdParts = {}
        for _, sourcePart in ipairs(allParts) do
            local offset = sourcePart.Position - sourceCenter
            local targetCFrame = CFrame.new(destOrigin + offset) * (sourcePart.CFrame - sourcePart.Position)
            
            local newPart = remote:InvokeServer("CreatePart", "Normal", targetCFrame, localBuildFolder)
            if newPart then
                table.insert(createdParts, newPart)
                
                remote:InvokeServer("SyncRotate", {{Part = newPart, CFrame = targetCFrame}}, {"AroundPivot", targetCFrame, "Center", targetCFrame, "Center"})
                task.wait(0.15)
                
                remote:InvokeServer("SyncResize", 
                    {{Part = newPart, CFrame = targetCFrame, Size = sourcePart.Size}},
                    {"ResizeFace", Enum.NormalId.Right, 0, Vector3.new(1, 0, 0), "X", Vector3.xAxis, "Normal"}
                )
                task.wait(0.15)
            end
        end
        remote:InvokeServer("CreateGroup", "Model", localBuildFolder, createdParts)
        Rayfield:Notify({Title = "Done", Content = "Copied " .. #createdParts .. " parts."})
    end,
})
