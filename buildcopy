local function getBuildArea(folderName)
    local pa = workspace:FindFirstChild("Private Building Areas")
    return pa and pa:FindFirstChild(folderName)
end

local function refreshPlayers()
    local pa = workspace:FindFirstChild("Private Building Areas")
    if not pa then return {} end
    local opts = {}
    playerMapping = {}
    for _, c in ipairs(pa:GetChildren()) do
        local name = c.Name
        if name:sub(-9) == "BuildArea" then
            local pn = name:sub(1, -10)
            table.insert(opts, pn)
            playerMapping[pn] = name
        end
    end
    return opts
end

local function clearLocalBuild()
    local localName = game.Players.LocalPlayer.Name .. "BuildArea"
    local localBA = getBuildArea(localName)
    if localBA and localBA:FindFirstChild("Build") then
        for _, p in ipairs(localBA.Build:GetChildren()) do p:Destroy() end
        Rayfield:Notify({ Title = "Cleared", Content = "Your Build folder emptied." })
    end
end

-- Auto‑centre of source build (average of all part positions)
local function computeSourceCentre(buildArea)
    local buildFolder = buildArea:FindFirstChild("Build")
    if not buildFolder then return buildArea.Position end
    local parts = {}
    local function collect(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then
                table.insert(parts, child)
            elseif child:IsA("Model") then
                collect(child)
            end
        end
    end
    collect(buildFolder)
    if #parts == 0 then return buildArea.Position end
    local sum = Vector3.new(0,0,0)
    for _, p in ipairs(parts) do sum = sum + p.Position end
    return sum / #parts
end

-- Remote access
local remote = nil
local function getRemote()
    if remote then return remote end
    local char = game.Players.LocalPlayer.Character
    if not char then return nil end
    local bt = char:FindFirstChild("Building Tools")
    if not bt then return nil end
    local api = bt:FindFirstChild("SyncAPI")
    if not api then return nil end
    remote = api:FindFirstChild("ServerEndpoint")
    return remote
end

local function vec(v) return vector.create(v.X, v.Y, v.Z) end

-- Copy a single part using remote calls – no clones, no renaming
local function copySinglePart(sourcePart, srcOrigin, dstOrigin, dstBuild)
    -- Determine part type based on source part's name
    local partType = nil
    local name = sourcePart.Name
    if name == "Part" then partType = "Normal"
    elseif name == "Truss" then partType = "Truss"
    elseif name == "Wedge" then partType = "Wedge"
    elseif name == "Corner" then partType = "Corner"
    elseif name == "Cylinder" then partType = "Cylinder"
    elseif name == "Ball" then partType = "Ball"
    elseif name == "Seat" then partType = "Seat"
    elseif name == "Vehicle Seat" then partType = "Vehicle Seat"
    elseif name == "Spawn" then partType = "Spawn"
    else partType = "Normal"
    end

    local offset = sourcePart.Position - srcOrigin
    local targetPos = dstOrigin + offset
    local targetCFrame = CFrame.new(targetPos) * (sourcePart.CFrame - sourcePart.CFrame.Position)

    local r = getRemote()
    if not r then return nil end

    -- Create at destination origin
    local createArgs = {"CreatePart", partType, CFrame.new(dstOrigin), dstBuild}
    local ok, newPart = pcall(function() return r:InvokeServer(unpack(createArgs)) end)
    if not ok or not newPart then
        warn("CreatePart failed for", sourcePart.Name)
        return nil
    end
    task.wait(0.1)

    -- The new part is the instance we will operate on
    local actualPart = newPart
    if not actualPart:IsA("BasePart") then
        actualPart = dstBuild:FindFirstChild(sourcePart.Name)  -- fallback
    end
    if not actualPart then
        warn("Could not locate created part for", sourcePart.Name)
        return nil
    end

    -- Rotate (exact pattern from your example)
    local pivotCFrame = targetCFrame - targetCFrame.Position
    local currentCFrame = CFrame.new(dstOrigin)
    local rotArgs = {
        "SyncRotate",
        { { Part = actualPart, CFrame = targetCFrame } },
        { "AroundPivot", pivotCFrame, "Center", currentCFrame, "Center" }
    }
    pcall(function() r:InvokeServer(unpack(rotArgs)) end)
    task.wait(0.5)

    -- Move (exact pattern from your example)
    local delta = targetPos - dstOrigin
    local moveArgs = {
        "SyncMove",
        { { Part = actualPart, CFrame = CFrame.new(targetPos) } },
        { "AlongFace", vec(delta), "Global", CFrame.new(targetPos) }
    }
    pcall(function() r:InvokeServer(unpack(moveArgs)) end)
    task.wait(0.5)

    -- Resize (using your example pattern; we pass the target size)
    -- The ResizeFace part may be ignored by the server; it only cares about the Size in the first table.
    local resizeArgs = {
        "SyncResize",
        { { Part = actualPart, CFrame = CFrame.new(targetPos), Size = vec(sourcePart.Size) } },
        { "ResizeFace", Enum.NormalId.Front, 1, vec(Vector3.new(0,0,0)), "Z", sourcePart.Size, "Normal" }
    }
    pcall(function() r:InvokeServer(unpack(resizeArgs)) end)
    task.wait(0.5)

    return actualPart
end

-- Main copy function using remote calls with real offsets
local function copyRealBuild()
    if not selectedPlayer then
        Rayfield:Notify({ Title = "Error", Content = "Select a player." })
        return
    end

    local srcFolder = playerMapping[selectedPlayer]
    local srcBA = getBuildArea(srcFolder)
    local dstBA = getBuildArea(game.Players.LocalPlayer.Name .. "BuildArea")
    if not srcBA or not dstBA then
        Rayfield:Notify({ Title = "Error", Content = "BuildAreas missing." })
        return
    end

    local srcBuild = srcBA:FindFirstChild("Build")
    local dstBuild = dstBA:FindFirstChild("Build")
    if not srcBuild or not dstBuild then
        Rayfield:Notify({ Title = "Error", Content = "Build folders missing." })
        return
    end

    -- Compute source centre (auto-centre)
    local srcCentre = computeSourceCentre(srcBA)
    local finalY = baseHeight + realYextra
    local srcOrigin = srcCentre + Vector3.new(0, finalY, 0)
    local dstOrigin = dstBA.Position + Vector3.new(realX, finalY, realZ)

    -- Collect all BaseParts recursively (flatten models)
    local allParts = {}
    local function collect(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then
                table.insert(allParts, child)
            elseif child:IsA("Model") then
                collect(child)
            end
        end
    end
    collect(srcBuild)
    if #allParts == 0 then
        Rayfield:Notify({ Title = "Info", Content = "No parts found." })
        return
    end

    clearLocalBuild()
    task.wait(0.5)

    Rayfield:Notify({ Title = "Copying", Content = #allParts .. " parts..." })
    local successCount = 0
    for _, part in ipairs(allParts) do
        if copySinglePart(part, srcOrigin, dstOrigin, dstBuild) then
            successCount = successCount + 1
        end
        task.wait(0.1) -- small delay between parts
    end
    Rayfield:Notify({ Title = "Complete", Content = successCount .. "/" .. #allParts .. " parts copied." })
end

-- Ghost preview (direct clones, no remote, uses ghost offsets)
local ghostModel = nil
local function showGhost()
    if ghostModel then ghostModel:Destroy() end
    if not selectedPlayer then
        Rayfield:Notify({ Title = "Error", Content = "Select a player." })
        return
    end

    local srcFolder = playerMapping[selectedPlayer]
    local srcBA = getBuildArea(srcFolder)
    local dstBA = getBuildArea(game.Players.LocalPlayer.Name .. "BuildArea")
    if not srcBA or not dstBA then
        Rayfield:Notify({ Title = "Error", Content = "BuildAreas missing." })
        return
    end
    local srcBuild = srcBA:FindFirstChild("Build")
    if not srcBuild then
        Rayfield:Notify({ Title = "Error", Content = "Source has no Build folder." })
        return
    end

    local srcCentre = computeSourceCentre(srcBA)
    local finalY = baseHeight + ghostYextra
    local srcOrigin = srcCentre + Vector3.new(0, finalY, 0)
    local dstOrigin = dstBA.Position + Vector3.new(ghostX, finalY, ghostZ)

    ghostModel = Instance.new("Model")
    ghostModel.Name = "GhostPreview"

    local function cloneParts(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then
                local offset = child.Position - srcOrigin
                local targetPos = dstOrigin + offset
                local clone = child:Clone()
                clone.Position = targetPos
                clone.CFrame = CFrame.new(targetPos) * (child.CFrame - child.CFrame.Position)
                clone.Anchored = true
                clone.CanCollide = false
                clone.Transparency = 0.7
                clone.Material = Enum.Material.ForceField
                clone.Parent = ghostModel
            elseif child:IsA("Model") then
                cloneParts(child)
            end
        end
    end
    cloneParts(srcBuild)
    ghostModel.Parent = workspace
    Rayfield:Notify({ Title = "Ghost Preview", Content = "Ghost uses its own offsets. Real copy uses separate offsets (default 0)." })
end

local function hideGhost()
    if ghostModel then ghostModel:Destroy() end
end

-- Place a marker at real destination origin
local function showRealMarker()
    if not selectedPlayer then
        Rayfield:Notify({ Title = "Error", Content = "Select a player." })
        return
    end
    local dstBA = getBuildArea(game.Players.LocalPlayer.Name .. "BuildArea")
    if not dstBA then return end
    local finalY = baseHeight + realYextra
    local dstOrigin = dstBA.Position + Vector3.new(realX, finalY, realZ)
    local marker = Instance.new("Part")
    marker.Size = Vector3.new(1, 1, 1)
    marker.Color = Color3.fromRGB(0, 255, 0)
    marker.Material = Enum.Material.Neon
    marker.Position = dstOrigin
    marker.Anchored = true
    marker.CanCollide = false
    marker.Parent = workspace
    game:GetService("Debris"):AddItem(marker, 5)
    Rayfield:Notify({ Title = "Marker", Content = "Green marker at REAL copy origin (real offsets)." })
end

