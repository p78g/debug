-- Load Rayfield (use the working URL)
local Rayfield = loadstring(game:HttpGet("https://raw.githubusercontent.com/SiriusSoftwareLtd/Rayfield/main/init.lua"))()

-- Services
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Workspace = game:GetService("Workspace")

-- Wait for character and Building Tools
local function waitForCharacter()
    if not LocalPlayer.Character or not LocalPlayer.Character.Parent then
        LocalPlayer.CharacterAdded:Wait()
    end
    return LocalPlayer.Character
end

waitForCharacter()
local char = LocalPlayer.Character

local buildingTools = char:WaitForChild("Building Tools", 10)
if not buildingTools then
    Rayfield:Notify({Title = "Error", Content = "Building Tools not found! Cannot proceed.", Duration = 10})
    error("Building Tools missing")
end

local syncAPI = buildingTools:FindFirstChild("SyncAPI")
if not syncAPI then
    Rayfield:Notify({Title = "Error", Content = "SyncAPI not found!", Duration = 10})
    error("SyncAPI missing")
end

-- Find the remote (try common names)
local remote = syncAPI:FindFirstChild("ServerEndpoint") or syncAPI:FindFirstChild("Remote") or syncAPI:FindFirstChild("Function")
if not remote then
    Rayfield:Notify({Title = "Error", Content = "No remote function found in SyncAPI. Check console.", Duration = 10})
    error("No remote in SyncAPI")
end

print("[Build Copier] Using remote:", remote.Name, remote.ClassName)

-- Test remote connection
local function testRemote()
    local success, result = pcall(function()
        return remote:InvokeServer("Ping")  -- dummy call
    end)
    if success then
        Rayfield:Notify({Title = "Success", Content = "Remote is reachable!", Duration = 3})
        print("[Test] Remote responded:", result)
    else
        Rayfield:Notify({Title = "Error", Content = "Remote call failed: " .. tostring(result), Duration = 5})
        warn("[Test] Remote error:", result)
    end
end

-- Helper: get plot part
local function getPlotPart(plotFolderName)
    local privateArea = Workspace:FindFirstChild("Private Building Areas")
    if not privateArea then return nil end
    local plot = privateArea:FindFirstChild(plotFolderName)
    if plot and plot:IsA("BasePart") then return plot end
    if plot and plot:IsA("Model") then
        if plot.PrimaryPart then return plot.PrimaryPart end
        for _, child in ipairs(plot:GetChildren()) do
            if child:IsA("BasePart") then return child end
        end
    end
    return nil
end

-- Copy a single part (with pcall)
local function copyPart(sourcePart, sourcePlotPart, localPlotPart, buildFolder)
    local typeMap = {
        Part = "Normal", Truss = "Truss", Wedge = "Wedge", Corner = "Corner",
        Cylinder = "Cylinder", Ball = "Ball", Seat = "Seat",
        ["Vehicle Seat"] = "Vehicle Seat", Spawn = "Spawn"
    }
    local partType = typeMap[sourcePart.Name] or "Normal"

    local sourceOrigin = sourcePlotPart.Position + Vector3.new(0, 3, 0)
    local localOrigin = localPlotPart.Position + Vector3.new(0, 3, 0)

    local relativePos = sourcePart.Position - sourceOrigin
    local targetPos = localOrigin + relativePos

    local sourceCFrame = sourcePart.CFrame
    local targetCFrame = CFrame.new(targetPos) * (sourceCFrame - sourceCFrame.Position)

    -- Create part
    local createArgs = {"CreatePart", partType, CFrame.new(localOrigin), buildFolder}
    local success, newPart = pcall(function()
        return remote:InvokeServer(unpack(createArgs))
    end)

    if not success or not newPart then
        warn("CreatePart failed:", sourcePart.Name, success, newPart)
        return
    end

    -- Rotate
    local rotateArgs = {
        "SyncRotate",
        {{Part = newPart, CFrame = targetCFrame}},
        {"AroundPivot", CFrame.new(targetPos), "Center", CFrame.new(targetPos), "Center"}
    }
    pcall(function() remote:InvokeServer(unpack(rotateArgs)) end)

    -- Move
    local moveArgs = {
        "SyncMove",
        {{Part = newPart, CFrame = targetCFrame}},
        {"AlongFace", Vector3.new(0,0,0), "Global", targetCFrame}
    }
    pcall(function() remote:InvokeServer(unpack(moveArgs)) end)

    -- Resize
    local resizeArgs = {
        "SyncResize",
        {{Part = newPart, CFrame = targetCFrame, Size = sourcePart.Size}},
        {"ResizeFace", Enum.NormalId.Front, 1, Vector3.zAxis, "Z", sourcePart.Size, "Normal"}
    }
    pcall(function() remote:InvokeServer(unpack(resizeArgs)) end)
end

-- Main copy function
local function copyBuild(selectedPlayerName, playerMapping)
    local privateArea = Workspace:FindFirstChild("Private Building Areas")
    if not privateArea then
        Rayfield:Notify({Title = "Error", Content = "Private Building Areas not found!", Duration = 5})
        return
    end

    local sourceFolderName = playerMapping[selectedPlayerName]
    if not sourceFolderName then
        Rayfield:Notify({Title = "Error", Content = "Source folder not found!", Duration = 5})
        return
    end

    local sourceBuildArea = privateArea:FindFirstChild(sourceFolderName)
    local sourcePlotPart = getPlotPart(sourceFolderName)
    if not sourceBuildArea or not sourcePlotPart then
        Rayfield:Notify({Title = "Error", Content = "Could not locate source plot or build area!", Duration = 5})
        return
    end

    local localPlayerName = LocalPlayer.Name
    local localFolderName = localPlayerName .. "BuildArea"
    local localBuildArea = privateArea:FindFirstChild(localFolderName)
    local localPlotPart = getPlotPart(localFolderName)
    if not localBuildArea or not localPlotPart then
        Rayfield:Notify({Title = "Error", Content = "Could not locate your plot or build area!", Duration = 5})
        return
    end

    local sourceBuildFolder = sourceBuildArea:FindFirstChild("Build")
    local localBuildFolder = localBuildArea:FindFirstChild("Build")
    if not sourceBuildFolder or not localBuildFolder then
        Rayfield:Notify({Title = "Error", Content = "Build folder missing!", Duration = 5})
        return
    end

    local parts = {}
    for _, child in ipairs(sourceBuildFolder:GetChildren()) do
        if child:IsA("BasePart") then table.insert(parts, child) end
    end

    if #parts == 0 then
        Rayfield:Notify({Title = "Info", Content = "No parts found to copy.", Duration = 5})
        return
    end

    Rayfield:Notify({Title = "Copying", Content = "Copying " .. #parts .. " parts...", Duration = 3})

    for i, part in ipairs(parts) do
        copyPart(part, sourcePlotPart, localPlotPart, localBuildFolder)
        task.wait(0.05)
    end

    Rayfield:Notify({Title = "Success", Content = "Build copied successfully!", Duration = 5})
end

-- Build UI
local Window = Rayfield:CreateWindow({Name = "Build Copier", Theme = "Default"})
local MainTab = Window:CreateTab("Copy Build")

local selectedPlayer = nil
local playerMapping = {}

local function refreshPlayerList()
    local privateArea = Workspace:FindFirstChild("Private Building Areas")
    if not privateArea then return {} end
    local options = {}
    playerMapping = {}
    for _, child in ipairs(privateArea:GetChildren()) do
        local name = child.Name
        if name:sub(-9) == "BuildArea" then
            local pName = name:sub(1, -10)
            table.insert(options, pName)
            playerMapping[pName] = name
        end
    end
    return options
end

local options = refreshPlayerList()
local dropdown = MainTab:CreateDropdown({
    Name = "Select Player",
    Options = options,
    CurrentOption = options[1] or "",
    Callback = function(opt) selectedPlayer = opt end
})

MainTab:CreateButton({
    Name = "Copy Build",
    Callback = function()
        if selectedPlayer and selectedPlayer ~= "" then
            copyBuild(selectedPlayer, playerMapping)
        else
            Rayfield:Notify({Title = "Error", Content = "Select a player first!", Duration = 3})
        end
    end
})

MainTab:CreateButton({
    Name = "Refresh Player List",
    Callback = function()
        local newOpts = refreshPlayerList()
        dropdown:SetOptions(newOpts)
        if newOpts[1] then
            dropdown:SetValue(newOpts[1])
            selectedPlayer = newOpts[1]
        end
        Rayfield:Notify({Title = "Refreshed", Content = "Player list updated.", Duration = 2})
    end
})

MainTab:CreateButton({
    Name = "Test Remote Connection",
    Callback = testRemote
})

print("[Build Copier] UI ready. Use 'Test Remote Connection' to verify.")
