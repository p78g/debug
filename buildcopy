-- Town Build Copier - Ultra Diagnostic Version (0 parts issue)
-- Run this and check F9 console carefully

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Town Copier - Diagnostic",
    LoadingTitle = "Diagnostic Mode",
    LoadingSubtitle = "Finding why 0 parts spawn",
    Theme = "Default"
})

local Tab = Window:CreateTab("Diagnostic Copier", "hammer")

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

local BUILDING_AREAS = Workspace:WaitForChild("Private Building Areas")

local function getRemote()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local tool = char:WaitForChild("Building Tools", 10)
    if not tool then
        Rayfield:Notify({Title = "Error", Content = "Equip Building Tools first!", Duration = 10})
        error("No Building Tools")
    end
    return tool:WaitForChild("SyncAPI"):WaitForChild("ServerEndpoint")
end

local localBuildArea = BUILDING_AREAS:WaitForChild(LocalPlayer.Name .. "BuildArea")
local localBuildFolder = localBuildArea:WaitForChild("Build")

local baseHeight = 5
local selectedPlayer = nil

local realOffsetX, realOffsetY, realOffsetZ = -28.637, -17.512, 0

local playerOptions = {}

local function refreshPlayers()
    playerOptions = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and BUILDING_AREAS:FindFirstChild(plr.Name .. "BuildArea") then
            table.insert(playerOptions, plr.Name)
        end
    end
end
refreshPlayers()

Tab:CreateSection("Test (Should Still Work)")
Tab:CreateButton({
    Name = "🧪 Test Single Part",
    Callback = function()
        local remote = getRemote()
        local testPos = localBuildArea.Position + Vector3.new(0, baseHeight + 10, 0)
        local newPart = remote:InvokeServer("CreatePart", "Normal", CFrame.new(testPos), localBuildFolder)
        if newPart and newPart:IsA("BasePart") then
            Rayfield:Notify({Title = "Test OK", Content = "Single part created", Duration = 5})
        else
            Rayfield:Notify({Title = "Test Failed", Content = "Check F9 console", Duration = 8})
        end
    end,
})

Tab:CreateSection("Copy Settings")
local Dropdown = Tab:CreateDropdown({
    Name = "Select Player to Copy",
    Options = playerOptions,
    CurrentOption = {},
    MultipleOptions = false,
    Callback = function(Option)
        selectedPlayer = (typeof(Option) == "table" and #Option > 0) and Players:FindFirstChild(Option[1]) or nil
    end,
})

Tab:CreateSlider({ Name = "Real X Offset", Range = {-100, 100}, Increment = 0.01, CurrentValue = realOffsetX, Callback = function(v) realOffsetX = v end })
Tab:CreateSlider({ Name = "Real Y Offset", Range = {-50, 150}, Increment = 0.01, CurrentValue = -17.512, Callback = function(v) realOffsetY = v end })
Tab:CreateSlider({ Name = "Real Z Offset", Range = {-100, 100}, Increment = 0.01, CurrentValue = 0, Callback = function(v) realOffsetZ = v end })

Tab:CreateButton({
    Name = "🔍 Start Diagnostic Copy (Very Slow)",
    Description = "Use on a SMALL build first (5-10 parts)",
    Callback = function()
        if not selectedPlayer then
            Rayfield:Notify({Title = "Error", Content = "Select a player!", Duration = 5})
            return
        end

        local remote = getRemote()
        local sourceArea = BUILDING_AREAS:FindFirstChild(selectedPlayer.Name .. "BuildArea")
        if not sourceArea then
            Rayfield:Notify({Title = "Error", Content = "Source plot not found"}) 
            return 
        end

        local sourceBuild = sourceArea:WaitForChild("Build")

        local allParts = {}
        local function collect(obj)
            for _, v in ipairs(obj:GetDescendants()) do
                if v:IsA("BasePart") and not v:IsA("Terrain") then
                    table.insert(allParts, v)
                end
            end
        end
        collect(sourceBuild)

        print("=== DIAGNOSTIC START ===")
        print("Total parts found in source:", #allParts)
        print("Your Build Folder:", localBuildFolder:GetFullName())

        if #allParts == 0 then
            Rayfield:Notify({Title = "Error", Content = "No parts found in source build"}) 
            return 
        end

        -- Calculate source center
        local sumX, sumY, sumZ = 0, 0, 0
        for _, p in ipairs(allParts) do
            local pos = p.Position
            sumX += pos.X; sumY += pos.Y; sumZ += pos.Z
        end
        local sourceCenter = Vector3.new(sumX/#allParts, sumY/#allParts, sumZ/#allParts)

        local destOrigin = localBuildArea.Position + Vector3.new(realOffsetX, baseHeight + realOffsetY, realOffsetZ)

        Rayfield:Notify({Title = "Diagnostic Copy Started", Content = "Creating " .. #allParts .. " parts slowly...", Duration = 8})

        local createdCount = 0

        for i, sourcePart in ipairs(allParts) do
            local offset = sourcePart.Position - sourceCenter
            local targetPos = destOrigin + offset
            local targetCFrame = CFrame.new(targetPos) * sourcePart.CFrame.Rotation

            local partType = "Normal"
            local class = sourcePart.ClassName
            if class == "TrussPart" then partType = "Truss"
            elseif class == "WedgePart" then partType = "Wedge"
            elseif class == "CornerWedgePart" then partType = "Corner"
            elseif class == "Cylinder" or sourcePart.Shape == Enum.PartType.Cylinder then partType = "Cylinder"
            elseif sourcePart.Shape == Enum.PartType.Ball then partType = "Ball"
            elseif class == "Seat" then partType = "Seat"
            elseif class == "VehicleSeat" then partType = "Vehicle Seat"
            elseif class == "SpawnLocation" then partType = "Spawn"
            end

            -- Fresh folder reference every time
            local currentFolder = localBuildArea:WaitForChild("Build")

            print(string.format("Attempt %d/%d | Type: %s | Target Pos: %s", i, #allParts, partType, tostring(targetPos)))

            local success, newPart = pcall(function()
                return remote:InvokeServer("CreatePart", partType, CFrame.new(targetPos), currentFolder)
            end)

            if success and newPart and newPart:IsA("BasePart") then
                createdCount = createdCount + 1
                print("✓ SUCCESS: Part created -", newPart:GetFullName())

                -- Apply rotation, move, resize with longer delays
                task.wait(0.5)
                remote:InvokeServer("SyncRotate", {{Part = newPart, CFrame = targetCFrame}}, {"AroundPivot", CFrame.new(), "Center", CFrame.new(), "Center"})
                task.wait(0.5)
                remote:InvokeServer("SyncMove", {{Part = newPart, CFrame = targetCFrame}}, {"AlongFace", Vector3.new(), "Global", CFrame.new()})
                task.wait(0.5)
                remote:InvokeServer("SyncResize", {{Part = newPart, CFrame = targetCFrame, Size = sourcePart.Size}}, {"ResizeFace", Enum.NormalId.Right, 0, Vector3.new(), "X", Vector3.xAxis, "Normal"})
                task.wait(0.6)
            else
                print("✗ FAILED: Part", i, "Type:", partType)
                warn("CreatePart result:", newPart)
            end

            task.wait(0.4) -- breathing room
        end

        print("=== DIAGNOSTIC END === Created:", createdCount, "/", #allParts)
        Rayfield:Notify({Title = "Diagnostic Finished", Content = createdCount .. " / " .. #allParts .. " parts created. Check F9 console!", Duration = 12})
    end,
})

Tab:CreateButton({ Name = "Refresh Player List", Callback = function()
    refreshPlayers()
    Dropdown:Refresh(playerOptions)
end })

Rayfield:Notify({Title = "Diagnostic Script Loaded", Content = "Run on a SMALL build and check F9 console", Duration = 10})
