-- Your measured corrections (applied to destination)
local xCorrection = -28.637
local zCorrection = -17.512
local yExtra = 0
local baseHeight = 3  -- build surface height above plot part

MainTab:CreateSlider({ Name = "X Correction", Range = {-100, 100}, Increment = 0.5, CurrentValue = xCorrection, Callback = function(v) xCorrection = v end })
MainTab:CreateSlider({ Name = "Z Correction", Range = {-100, 100}, Increment = 0.5, CurrentValue = zCorrection, Callback = function(v) zCorrection = v end })
MainTab:CreateSlider({ Name = "Extra Y", Range = {-10, 10}, Increment = 0.5, CurrentValue = yExtra, Callback = function(v) yExtra = v end })
MainTab:CreateSlider({ Name = "Base Height", Range = {0, 10}, Increment = 0.5, CurrentValue = baseHeight, Callback = function(v) baseHeight = v end })

MainTab:CreateSection("Player Selection")

local selectedPlayer = nil
local playerMapping = {}
local dropdown = nil

local function getBuildArea(folderName)
    local pa = workspace:FindFirstChild("Private Building Areas")
    return pa and pa:FindFirstChild(folderName)
end

local function refreshPlayers()
    local pa = workspace:FindFirstChild("Private Building Areas")
    if not pa then return {} end
    local opts = {}
    playerMapping = {}
    for _, c in ipairs(pa:GetChildren()) do
        local name = c.Name
        if name:sub(-9) == "BuildArea" then
            local pn = name:sub(1, -10)
            table.insert(opts, pn)
            playerMapping[pn] = name
        end
    end
    return opts
end

-- Compute centre of all parts in a BuildArea (auto‑centre)
local function computeCentre(buildArea)
    local buildFolder = buildArea:FindFirstChild("Build")
    if not buildFolder then return buildArea.Position end
    local parts = {}
    local function collect(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then
                table.insert(parts, child)
            elseif child:IsA("Model") then
                collect(child)
            end
        end
    end
    collect(buildFolder)
    if #parts == 0 then return buildArea.Position end
    local sum = Vector3.new(0,0,0)
    for _, p in ipairs(parts) do sum = sum + p.Position end
    return sum / #parts
end

-- Remote access
local remote = nil
local function getRemote()
    if remote then return remote end
    local char = game.Players.LocalPlayer.Character
    if not char then return nil end
    local bt = char:FindFirstChild("Building Tools")
    if not bt then return nil end
    local api = bt:FindFirstChild("SyncAPI")
    if not api then return nil end
    remote = api:FindFirstChild("ServerEndpoint")
    return remote
end

local function vec(v) return vector.create(v.X, v.Y, v.Z) end

-- Test copy of a single part
local function testCopyOnePart()
    if not selectedPlayer then
        Rayfield:Notify({Title="Error", Content="Select a player first."})
        return
    end

    local srcFolder = playerMapping[selectedPlayer]
    local srcBA = getBuildArea(srcFolder)
    local dstBA = getBuildArea(game.Players.LocalPlayer.Name .. "BuildArea")
    if not srcBA or not dstBA then
        Rayfield:Notify({Title="Error", Content="BuildAreas not found."})
        return
    end

    local srcBuild = srcBA:FindFirstChild("Build")
    local dstBuild = dstBA:FindFirstChild("Build")
    if not srcBuild or not dstBuild then
        Rayfield:Notify({Title="Error", Content="Build folders missing."})
        return
    end

    -- Find first part in source (any BasePart, go through models)
    local sourcePart = nil
    local function findFirstPart(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then
                sourcePart = child
                return true
            elseif child:IsA("Model") then
                if findFirstPart(child) then return true end
            end
        end
        return false
    end
    if not findFirstPart(srcBuild) then
        Rayfield:Notify({Title="Error", Content="No parts found in source build."})
        return
    end

    -- Compute source centre
    local srcCentre = computeCentre(srcBA)
    local finalY = baseHeight + yExtra
    local srcOrigin = srcCentre + Vector3.new(0, finalY, 0)
    local dstOrigin = dstBA.Position + Vector3.new(xCorrection, finalY, zCorrection)

    -- Offset from source centre to the part
    local offset = sourcePart.Position - srcOrigin
    local targetPos = dstOrigin + offset

    -- Preserve rotation
    local targetCFrame = CFrame.new(targetPos) * (sourcePart.CFrame - sourcePart.CFrame.Position)

    -- Determine part type
    local typeMap = {
        Part = "Normal", Truss = "Truss", Wedge = "Wedge", Corner = "Corner",
        Cylinder = "Cylinder", Ball = "Ball", Seat = "Seat",
        ["Vehicle Seat"] = "Vehicle Seat", Spawn = "Spawn"
    }
    local partType = typeMap[sourcePart.Name] or "Normal"

    print("=== COPY ONE PART DEBUG ===")
    print("Source part:", sourcePart.Name, "Position:", sourcePart.Position)
    print("Source centre:", srcCentre)
    print("Source origin (centre + Y):", srcOrigin)
    print("Offset:", offset)
    print("Destination origin (your plot):", dstOrigin)
    print("Target position:", targetPos)
    print("Target CFrame (with rotation):", targetCFrame)
    print("Part size:", sourcePart.Size)
    print("Part type:", partType)

    local r = getRemote()
    if not r then
        Rayfield:Notify({Title="Error", Content="Remote endpoint not found."})
        return
    end

    -- Clear local build folder to avoid duplicate names
    for _, p in ipairs(dstBuild:GetChildren()) do p:Destroy() end
    Rayfield:Notify({Title="Cleared", Content="Your build folder emptied."})
    task.wait(0.5)

    -- 1. CreatePart at destination origin
    local createArgs = {"CreatePart", partType, CFrame.new(dstOrigin), dstBuild}
    local ok, newPart = pcall(function() return r:InvokeServer(unpack(createArgs)) end)
    if not ok or not newPart then
        warn("CreatePart failed:", ok, newPart)
        Rayfield:Notify({Title="CreatePart Failed", Content=tostring(newPart), Duration=8})
        return
    end
    print("CreatePart succeeded, returned:", newPart)
    task.wait(0.1)

    local actualPart = newPart
    if not actualPart:IsA("BasePart") then
        actualPart = dstBuild:FindFirstChild(sourcePart.Name)
    end
    if not actualPart then
        Rayfield:Notify({Title="Error", Content="Could not locate created part."})
        return
    end

    -- 2. SyncRotate
    local pivotCFrame = targetCFrame - targetCFrame.Position
    local currentCFrame = CFrame.new(dstOrigin)
    local rotArgs = {
        "SyncRotate",
        { { Part = actualPart, CFrame = targetCFrame } },
        { "AroundPivot", pivotCFrame, "Center", currentCFrame, "Center" }
    }
    local rotOk, rotErr = pcall(function() return r:InvokeServer(unpack(rotArgs)) end)
    if not rotOk then warn("Rotate error:", rotErr) end
    task.wait(0.5)

    -- 3. SyncMove
    local delta = targetPos - dstOrigin
    local moveArgs = {
        "SyncMove",
        { { Part = actualPart, CFrame = CFrame.new(targetPos) } },
        { "AlongFace", vec(delta), "Global", CFrame.new(targetPos) }
    }
    local moveOk, moveErr = pcall(function() return r:InvokeServer(unpack(moveArgs)) end)
    if not moveOk then warn("Move error:", moveErr) end
    task.wait(0.5)

    -- 4. SyncResize
    local resizeArgs = {
        "SyncResize",
        { { Part = actualPart, CFrame = CFrame.new(targetPos), Size = vec(sourcePart.Size) } },
        { "ResizeFace", Enum.NormalId.Front, 1, vec(Vector3.new(0,0,0)), "Z", sourcePart.Size, "Normal" }
    }
    local resizeOk, resizeErr = pcall(function() return r:InvokeServer(unpack(resizeArgs)) end)
    if not resizeOk then warn("Resize error:", resizeErr) end

    Rayfield:Notify({Title="Test Complete", Content="Check console for details. Part should match source."})
end

