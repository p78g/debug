-- Main Copy Button
Tab:CreateButton({
    Name = "🔄 Copy Build (Real)",
    Description = "Copies the selected player's build into your plot using remotes only",
    Callback = function()
        if not selectedPlayer then
            Rayfield:Notify({Title = "Error", Content = "No player selected!", Duration = 5})
            return
        end

        local sourceArea = BUILDING_AREAS:FindFirstChild(selectedPlayer.Name .. "BuildArea")
        if not sourceArea then
            Rayfield:Notify({Title = "Error", Content = "Source plot not found!", Duration = 5})
            return
        end

        local sourceBuild = sourceArea:WaitForChild("Build")

        -- Collect all BaseParts (flatten models)
        local allParts = {}
        local function collect(obj)
            for _, v in ipairs(obj:GetDescendants()) do
                if v:IsA("BasePart") then
                    table.insert(allParts, v)
                end
            end
        end
        collect(sourceBuild)

        if #allParts == 0 then
            Rayfield:Notify({Title = "Error", Content = "No parts found in source build!", Duration = 5})
            return
        end

        -- Calculate source center
        local sumX, sumY, sumZ = 0, 0, 0
        for _, p in ipairs(allParts) do
            local pos = p.Position
            sumX += pos.X; sumY += pos.Y; sumZ += pos.Z
        end
        local sourceCenter = Vector3.new(sumX / #allParts, sumY / #allParts, sumZ / #allParts)

        local destOrigin = localBuildArea.Position + Vector3.new(realOffsetX, baseHeight + realOffsetY, realOffsetZ)

        Rayfield:Notify({Title = "Copying...", Content = "Starting remote copy of " .. #allParts .. " parts...", Duration = 6})

        local createdParts = {}  -- for later grouping

        for _, sourcePart in ipairs(allParts) do
            local offset = sourcePart.Position - sourceCenter
            local targetPos = destOrigin + offset

            local partType = "Normal"
            if sourcePart.Name == "Truss" then partType = "Truss"
            elseif sourcePart.ClassName == "WedgePart" then partType = "Wedge"
            elseif sourcePart.ClassName == "CornerWedgePart" then partType = "Corner"
            elseif sourcePart.ClassName == "Cylinder" or sourcePart.Shape == Enum.PartType.Cylinder then partType = "Cylinder"
            elseif sourcePart.Shape == Enum.PartType.Ball then partType = "Ball"
            elseif sourcePart.ClassName == "Seat" then partType = "Seat"
            elseif sourcePart.ClassName == "VehicleSeat" then partType = "Vehicle Seat"
            elseif sourcePart.ClassName == "SpawnLocation" then partType = "Spawn"
            end

            -- 1. CreatePart
            local createArgs = {
                "CreatePart",
                partType,
                CFrame.new(targetPos.X, targetPos.Y, targetPos.Z),
                localBuildFolder
            }
            local newPart = remote:InvokeServer(unpack(createArgs))

            if newPart and newPart:IsA("BasePart") then
                table.insert(createdParts, newPart)

                -- 2. SyncRotate (preserve original rotation)
                local rotArgs = {
                    "SyncRotate",
                    {{ Part = newPart, CFrame = sourcePart.CFrame }},
                    { "AroundPivot", CFrame.new(), "Center", CFrame.new(), "Center" }
                }
                remote:InvokeServer(unpack(rotArgs))
                task.wait(0.5)

                -- 3. SyncMove (final position)
                local moveArgs = {
                    "SyncMove",
                    {{ Part = newPart, CFrame = CFrame.new(targetPos) }},
                    { "AlongFace", Vector3.new(), "Global", CFrame.new() }
                }
                remote:InvokeServer(unpack(moveArgs))
                task.wait(0.5)

                -- 4. SyncResize (preserve size)
                local resizeArgs = {
                    "SyncResize",
                    {{ Part = newPart, CFrame = CFrame.new(targetPos), Size = sourcePart.Size }},
                    { "ResizeFace", Enum.NormalId.Right, 0, Vector3.new(), "X", Vector3.xAxis, "Normal" }
                }
                remote:InvokeServer(unpack(resizeArgs))
                task.wait(0.5)
            end
        end

        -- Optional: Recreate groups (simple version - groups all new parts into one model)
        if #createdParts > 0 then
            local groupArgs = {
                "CreateGroup",
                "Model",
                localBuildFolder,
                createdParts
            }
            remote:InvokeServer(unpack(groupArgs))
        end

        Rayfield:Notify({Title = "Success!", Content = "Build copied! (" .. #allParts .. " parts)", Duration = 8})
    end,
})

-- Ghost Preview Button
Tab:CreateButton({
    Name = "👻 Show Ghost Preview",
    Description = "Shows transparent preview with current ghost offsets",
    Callback = function()
        -- Clear old ghosts first (simple way: destroy any existing "GhostPreview" folder)
        local oldGhost = Workspace:FindFirstChild("GhostPreview")
        if oldGhost then oldGhost:Destroy() end

        if not selectedPlayer then
            Rayfield:Notify({Title = "Error", Content = "Select a player first!", Duration = 4})
            return
        end

        local sourceArea = BUILDING_AREAS:FindFirstChild(selectedPlayer.Name .. "BuildArea")
        if not sourceArea then return end

        local sourceBuild = sourceArea:WaitForChild("Build")
        local allParts = {}
        local function collect(obj)
            for _, v in ipairs(obj:GetDescendants()) do
                if v:IsA("BasePart") then table.insert(allParts, v) end
            end
        end
        collect(sourceBuild)

        local sumX, sumY, sumZ = 0, 0, 0
        for _, p in ipairs(allParts) do
            local pos = p.Position
            sumX += pos.X; sumY += pos.Y; sumZ += pos.Z
        end
        local sourceCenter = Vector3.new(sumX/#allParts, sumY/#allParts, sumZ/#allParts)

        local ghostFolder = Instance.new("Folder")
        ghostFolder.Name = "GhostPreview"
        ghostFolder.Parent = Workspace

        local destOrigin = localBuildArea.Position + Vector3.new(ghostOffsetX, baseHeight + ghostOffsetY, ghostOffsetZ)

        for _, sourcePart in ipairs(allParts) do
            local offset = sourcePart.Position - sourceCenter
            local targetPos = destOrigin + offset

            local clone = sourcePart:Clone()
            clone.Anchored = true
            clone.Transparency = 0.7
            clone.Color = Color3.fromRGB(0, 255, 100)
            clone.CanCollide = false
            clone.CFrame = CFrame.new(targetPos) * (sourcePart.CFrame - sourcePart.Position)
            clone.Parent = ghostFolder
        end

        Rayfield:Notify({Title = "Ghost Preview", Content = "Preview created. Adjust offsets and copy when ready.", Duration = 6})
    end,
})

Tab:CreateButton({
    Name = "Clear Ghost Preview",
    Callback = function()
        local ghost = Workspace:FindFirstChild("GhostPreview")
        if ghost then ghost:Destroy() end
    end,
})

Tab:CreateButton({
    Name = "Refresh Player List",
    Callback = function()
        refreshPlayers()
        Dropdown:Refresh(playerOptions)  -- Rayfield dropdown refresh method
        Rayfield:Notify({Title = "Refreshed", Content = "Player list updated", Duration = 3})
    end,
})

Rayfield:Notify({
    Title = "Town Copier Loaded",
    Content = "Select a player → adjust offsets → use Copy Build",
    Duration = 8
})
