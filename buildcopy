-- Helper: update status
local function setStatus(msg, isError)
    statusLabel.Text = msg
    statusLabel.TextColor3 = isError and Color3.fromRGB(255, 100, 100) or Color3.fromRGB(200, 200, 200)
    print("[Build Copier] " .. msg)
end

-- Helper: get plot part (BasePart)
local function getPlotPart(plotFolderName)
    local privateArea = Workspace:FindFirstChild("Private Building Areas")
    if not privateArea then return nil end
    local obj = privateArea:FindFirstChild(plotFolderName)
    if not obj then return nil end
    if obj:IsA("BasePart") then return obj end
    if obj:IsA("Model") then
        if obj.PrimaryPart then return obj.PrimaryPart end
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("BasePart") then return child end
        end
    end
    return nil
end

-- Refresh player list from workspace
local function refreshPlayerList()
    local privateArea = Workspace:FindFirstChild("Private Building Areas")
    if not privateArea then
        setStatus("Private Building Areas not found!", true)
        return {}
    end
    
    local players = {}
    playerMapping = {}
    for _, child in ipairs(privateArea:GetChildren()) do
        local name = child.Name
        if name:sub(-9) == "BuildArea" then
            local playerName = name:sub(1, -10)
            table.insert(players, playerName)
            playerMapping[playerName] = name
        end
    end
    return players
end

-- Build dropdown UI
local function rebuildDropdown(players)
    -- Clear existing buttons
    for _, btn in ipairs(dropdownButtons) do
        btn:Destroy()
    end
    dropdownButtons = {}
    
    -- Create new buttons
    local y = 0
    for _, pName in ipairs(players) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 30)
        btn.Position = UDim2.new(0, 0, 0, y)
        btn.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
        btn.Text = pName
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.Font = Enum.Font.Gotham
        btn.TextSize = 13
        btn.Parent = dropdownList
        
        btn.MouseButton1Click:Connect(function()
            selectedPlayerName = pName
            dropdownBtn.Text = pName
            dropdownList.Visible = false
            setStatus("Selected: " .. pName)
        end)
        
        table.insert(dropdownButtons, btn)
        y = y + 30
    end
    
    dropdownList.CanvasSize = UDim2.new(0, 0, 0, y)
end

-- Core copy logic (with pcall and detailed logging)
local function copyPart(sourcePart, sourcePlotPart, localPlotPart, buildFolder)
    -- Part type mapping
    local typeMap = {
        Part = "Normal",
        Truss = "Truss",
        Wedge = "Wedge",
        Corner = "Corner",
        Cylinder = "Cylinder",
        Ball = "Ball",
        Seat = "Seat",
        ["Vehicle Seat"] = "Vehicle Seat",
        Spawn = "Spawn"
    }
    local partType = typeMap[sourcePart.Name] or "Normal"
    
    -- Origins (3 studs above plot)
    local sourceOrigin = sourcePlotPart.Position + Vector3.new(0, 3, 0)
    local localOrigin = localPlotPart.Position + Vector3.new(0, 3, 0)
    
    local relativePos = sourcePart.Position - sourceOrigin
    local targetPos = localOrigin + relativePos
    
    local sourceCFrame = sourcePart.CFrame
    local targetCFrame = CFrame.new(targetPos) * (sourceCFrame - sourceCFrame.Position)
    
    -- Get remote
    local char = LocalPlayer.Character
    if not char then
        warn("No character")
        return false
    end
    local buildingTools = char:FindFirstChild("Building Tools")
    if not buildingTools then
        warn("Building Tools missing")
        return false
    end
    local syncAPI = buildingTools:FindFirstChild("SyncAPI")
    if not syncAPI then
        warn("SyncAPI missing")
        return false
    end
    local remote = syncAPI:FindFirstChild("ServerEndpoint") or syncAPI:FindFirstChild("Remote") or syncAPI:FindFirstChild("Function")
    if not remote or remote.ClassName ~= "RemoteFunction" then
        warn("No valid RemoteFunction found in SyncAPI")
        return false
    end
    
    -- Create part
    local createArgs = {"CreatePart", partType, CFrame.new(localOrigin), buildFolder}
    local success, newPart = pcall(function()
        return remote:InvokeServer(unpack(createArgs))
    end)
    if not success or not newPart then
        warn("CreatePart failed:", sourcePart.Name, success, newPart)
        return false
    end
    
    -- Rotate
    local rotateArgs = {
        "SyncRotate",
        {{Part = newPart, CFrame = targetCFrame}},
        {"AroundPivot", CFrame.new(targetPos), "Center", CFrame.new(targetPos), "Center"}
    }
    pcall(function() remote:InvokeServer(unpack(rotateArgs)) end)
    
    -- Move
    local moveArgs = {
        "SyncMove",
        {{Part = newPart, CFrame = targetCFrame}},
        {"AlongFace", Vector3.new(0,0,0), "Global", targetCFrame}
    }
    pcall(function() remote:InvokeServer(unpack(moveArgs)) end)
    
    -- Resize
    local resizeArgs = {
        "SyncResize",
        {{Part = newPart, CFrame = targetCFrame, Size = sourcePart.Size}},
        {"ResizeFace", Enum.NormalId.Front, 1, Vector3.zAxis, "Z", sourcePart.Size, "Normal"}
    }
    pcall(function() remote:InvokeServer(unpack(resizeArgs)) end)
    
    return true
end

local function copyEntireBuild(playerDisplayName)
    local privateArea = Workspace:FindFirstChild("Private Building Areas")
    if not privateArea then
        setStatus("Private Building Areas not found!", true)
        return
    end
    
    local sourceFolderName = playerMapping[playerDisplayName]
    if not sourceFolderName then
        setStatus("Source folder not found for " .. playerDisplayName, true)
        return
    end
    
    local sourceBuildArea = privateArea:FindFirstChild(sourceFolderName)
    local sourcePlotPart = getPlotPart(sourceFolderName)
    if not sourceBuildArea or not sourcePlotPart then
        setStatus("Cannot find source plot or build area", true)
        return
    end
    
    local localPlayerName = LocalPlayer.Name
    local localFolderName = localPlayerName .. "BuildArea"
    local localBuildArea = privateArea:FindFirstChild(localFolderName)
    local localPlotPart = getPlotPart(localFolderName)
    if not localBuildArea or not localPlotPart then
        setStatus("Cannot find your build area or plot", true)
        return
    end
    
    local sourceBuildFolder = sourceBuildArea:FindFirstChild("Build")
    local localBuildFolder = localBuildArea:FindFirstChild("Build")
    if not sourceBuildFolder or not localBuildFolder then
        setStatus("Build folder missing in source or destination", true)
        return
    end
    
    local parts = {}
    for _, child in ipairs(sourceBuildFolder:GetChildren()) do
        if child:IsA("BasePart") then
            table.insert(parts, child)
        end
    end
    
    if #parts == 0 then
        setStatus("No parts found in source build", true)
        return
    end
    
    setStatus("Copying " .. #parts .. " parts...")
    
    local successCount = 0
    for i, part in ipairs(parts) do
        local ok = copyPart(part, sourcePlotPart, localPlotPart, localBuildFolder)
        if ok then successCount = successCount + 1 end
        task.wait(0.05)
    end
    
    setStatus("Done! Copied " .. successCount .. "/" .. #parts .. " parts.")
end

-- UI interactions
local function updatePlayerList()
    local players = refreshPlayerList()
    if #players == 0 then
        setStatus("No player builds found", true)
        dropdownBtn.Text = "No players"
        selectedPlayerName = nil
    else
        dropdownBtn.Text = "Select Player"
        selectedPlayerName = nil
        rebuildDropdown(players)
        setStatus("Found " .. #players .. " players. Click dropdown to select.")
    end
end

dropdownBtn.MouseButton1Click:Connect(function()
    dropdownList.Visible = not dropdownList.Visible
end)

copyBtn.MouseButton1Click:Connect(function()
    if not selectedPlayerName then
        setStatus("Please select a player from the dropdown first.", true)
        return
    end
    -- Run in a separate thread to keep UI responsive
    task.spawn(function()
        copyEntireBuild(selectedPlayerName)
    end)
end)

refreshBtn.MouseButton1Click:Connect(function()
    updatePlayerList()
end)

-- Hide dropdown when clicking outside
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        local mousePos = UserInputService:GetMouseLocation()
        local dropdownAbsPos = dropdownList.AbsolutePosition
        local dropdownSize = dropdownList.AbsoluteSize
        if not (mousePos.X >= dropdownAbsPos.X and mousePos.X <= dropdownAbsPos.X + dropdownSize.X and
                mousePos.Y >= dropdownAbsPos.Y and mousePos.Y <= dropdownAbsPos.Y + dropdownSize.Y) then
            dropdownList.Visible = false
        end
    end
end)

-- Initial load
updatePlayerList()
setStatus("Ready. Click dropdown to see players.")
