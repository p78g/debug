local ReGui = loadstring(game:HttpGet("https://api.lithium.wtf/misc/regui"))()
local Window = ReGui:Window({
    Title = "RakNet Desync (Stable-ish)",
    Size = UDim2.fromOffset(220, 180),
})

local plsraknet = Raknet or raknet or rnet
if not plsraknet then
    local Popup = Window:PopupModal({ Title = "Error" })
    Popup:Label({ Text = "No RakNet library detected!" })
    Popup:Separator()
    Popup:Button({
        Text = "Close",
        Callback = function() Popup:ClosePopup() end,
    })
    return  -- stop script
end

Window:Label({ Text = "Warning: Long desync often causes reconnects/kicks" })

local desyncActive = false
local maxDuration = 8  -- seconds before auto-disable (change this)
local durationSlider = Window:Slider({
    Label = "Max desync duration (sec)",
    Min = 3,
    Max = 30,
    Default = maxDuration,
    Callback = function(Value)
        maxDuration = Value
    end,
})

local statusLabel = Window:Label({ Text = "Status: OFF" })

local function updateStatus()
    statusLabel:SetText("Status: " .. (desyncActive and "ON (auto-off in ~" .. maxDuration .. "s)" or "OFF"))
end

local checkbox = Window:Checkbox({
    Value = false,
    Label = "Enable Desync",
    Callback = function(self, Value: boolean)
        if not plsraknet.desync then
            warn("plsraknet.desync function missing!")
            self:SetValue(false)
            return
        end

        plsraknet.desync(Value)
        desyncActive = Value

        updateStatus()

        if Value then
            print("[Desync] Enabled – will auto-disable in " .. maxDuration .. " seconds")
            task.delay(maxDuration, function()
                if desyncActive then
                    plsraknet.desync(false)
                    desyncActive = false
                    checkbox:SetValue(false)
                    updateStatus()
                    print("[Desync] Auto-disabled to prevent reconnect")
                end
            end)
        else
            print("[Desync] Disabled manually")
        end
    end,
})

-- Optional: force off on script end / character respawn
game:BindToClose(function()
    if desyncActive and plsraknet.desync then
        plsraknet.desync(false)
    end
end)
