--[[
    Car Chopper Script - Stable Iris GUI
    - Fixed "too few calls to Iris.End()" error
    - Buttons stay in correct position
    - Wheels + extra handlers deleted only once
--]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StarterGui = game:GetService("StarterGui")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

local localPlayer = Players.LocalPlayer

-- ========== Helpers ==========
local function waitForCharacter()
    local char = localPlayer.Character
    if not char or not char.Parent then
        char = localPlayer.CharacterAdded:Wait()
    end
    return char
end

-- ========== Inventory Protection ==========
coroutine.wrap(function()
    while true do
        task.wait(0.15)
        pcall(function()
            StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, true)
            StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Inventory, true)
        end)
    end
end)()

-- ========== Initial Setup ==========
local function doInitialSetup()
    ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("ATM"):FireServer("Withdraw", 5050)
    task.wait(0.5)

    ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("ControllerRemote"):FireServer("/respawn")
    task.wait(1.6)

    local root = waitForCharacter():FindFirstChild("HumanoidRootPart")
    if root then root.CFrame = CFrame.new(1053, 54, -104) end
    task.wait(0.8)

    local gunPrompt = Workspace:FindFirstChild("Map", true) 
        and Workspace.Map:FindFirstChild("GunStore", true)
        and Workspace.Map.GunStore:FindFirstChild("GunTable", true)
        and Workspace.Map.GunStore.GunTable:FindFirstChild("ProPad", true)
        and Workspace.Map.GunStore.GunTable.ProPad:FindFirstChild("Handle", true)
        and Workspace.Map.GunStore.GunTable.ProPad.Handle:FindFirstChild("ProximityPrompt")

    if gunPrompt then
        local targetPart = gunPrompt.Parent:IsA("BasePart") and gunPrompt.Parent or gunPrompt.Parent:FindFirstChildWhichIsA("BasePart")
        if targetPart and root then
            root.CFrame = CFrame.new(targetPart.Position + Vector3.new(0, 4, 0))
            task.wait(0.4)
            gunPrompt:InputHoldBegin()
            task.wait(2)
            gunPrompt:InputHoldEnd()
        end
    end

    ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Buy"):FireServer("SkiMask", 50)
    task.wait(0.5)
end

doInitialSetup()

-- ========== Chop Logic ==========
local selectedCar = nil
local selectedDisplay = nil
local spamConnection = nil

local function startProPadSpam(carInstance)
    if spamConnection then spamConnection:Disconnect() end
    spamConnection = RunService.Heartbeat:Connect(function()
        if carInstance and carInstance.Parent then
            local args = { carInstance, true }
            ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("ProPad"):FireServer(unpack(args))
        end
    end)
end

local function stopProPadSpam()
    if spamConnection then
        spamConnection:Disconnect()
        spamConnection = nil
    end
end

local function chopCar(carInstance, displayName)
    if not carInstance then return end

    -- Initial 5 fires
    for i = 1, 5 do
        local args = { carInstance, true }
        ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("ProPad"):FireServer(unpack(args))
        task.wait(0.2)
    end

    task.wait(0.1)

    startProPadSpam(carInstance)

    -- Teleport 40 studs up
    local rootPart = waitForCharacter():FindFirstChild("HumanoidRootPart")
    if rootPart then
        rootPart.CFrame = rootPart.CFrame + Vector3.new(0, 40, 0)
    end

    task.wait(1.5)

    -- Teleport to DriveSeat
    local driveSeat = carInstance:FindFirstChild("DriveSeat")
    if driveSeat and rootPart then
        rootPart.CFrame = driveSeat.CFrame + Vector3.new(0, 3, 0)
    end

    task.wait(13)

    -- Delete wheels + extra handlers (once only)
    local wheels = carInstance:FindFirstChild("Wheels")
    if wheels then
        for _, name in {"FL", "FR", "RL", "RR"} do
            local wheel = wheels:FindFirstChild(name)
            if wheel then wheel:Destroy() end
        end
    end

    local extra = {"VehicleSoundsEvent", "Friction", "ExhaustHandler", "MiscHandler"}
    for _, name in ipairs(extra) do
        local obj = carInstance:FindFirstChild(name)
        if obj then obj:Destroy() end
    end

    -- Final safe spot + 20s anchor
    local finalRoot = waitForCharacter():FindFirstChild("HumanoidRootPart")
    if finalRoot then
        finalRoot.CFrame = CFrame.new(1096, 70, 608)
        task.wait(0.1)
        finalRoot.Anchored = true
        task.wait(20)
        finalRoot.Anchored = false
    end

    stopProPadSpam()
end

-- ========== Stable Iris GUI ==========
local Iris = loadstring(game:HttpGet("https://raw.githubusercontent.com/x0581/Iris-Exploit-Bundle/main/bundle.lua"))().Init(game.CoreGui)
Iris.UpdateGlobalConfig(Iris.TemplateConfig.colorDark)

Iris:Connect(function()
    Iris.Window({"Car Chopper"}, {size = Iris.State(Vector2.new(400, 520))})

        Iris.Text({"Select Car to Chop:"})

        -- Car List Tree
        Iris.Tree({"Available Cars"})
            for _, car in ipairs(Workspace.Vehicles:GetChildren()) do
                if car.Name:find("'s Car") then
                    local carType = car:GetAttribute("CarType") or "Unknown"
                    local display = car.Name .. " - " .. carType

                    if Iris.Button({display}).clicked then
                        selectedCar = car
                        selectedDisplay = display
                    end

                    if selectedDisplay == display then
                        Iris.SameLine()
                        Iris.Text({" ✓ Selected"})
                    end
                end
            end
        Iris.End()  -- End Tree

        Iris.Separator()

        -- Action Buttons (outside tree)
        if Iris.Button({"Chop Selected Car"}).clicked then
            if selectedCar then
                chopCar(selectedCar, selectedDisplay)
            end
        end

        if Iris.Button({"Redo Initial Setup"}).clicked then
            doInitialSetup()
        end

        if Iris.Button({"Refresh Car List"}).clicked then
            -- Refresh
        end

        Iris.Text({"Selected: " .. (selectedDisplay or "None")})

    Iris.End()  -- End Window
end)
